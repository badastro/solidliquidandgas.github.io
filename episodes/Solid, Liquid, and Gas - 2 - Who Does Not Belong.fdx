<?xml version="1.0" encoding="UTF-8" standalone="no" ?>
<FinalDraft DocumentType="Script" Template="No" Version="6">

  <DocumentRef DateTime="20250719T225100" id="311bf653-30ed-4d65-a49b-1d9bc7012bab">
    <XRef DateTime="20250719T224917" id="326d3bbb-277d-4966-b8b4-fc0c38660087"/>
  </DocumentRef>

  <Content>
    <Paragraph Type="New Act" id="6b67055e-8e0a-4c01-b26e-48bdef828a9a">
      <Text>Hot Open</Text>
    </Paragraph>
    <Paragraph Type="Scene Heading" id="7a191388-955c-486e-bbff-929364f3da4b">
      <SceneProperties Length="1" Page="1" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="CLAY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="CLAY &amp; RAY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="RAY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>Int. ElementARY SCHOOL - Library - Day (2005)</Text>
    </Paragraph>
    <Paragraph Type="Action" id="c4f3ca9f-c9e2-48f0-9855-65db19151bc9">
      <Text>It is every student’s favorite day: Scholastic Book Fair.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="ec40fd1b-93dd-453d-97c1-10d46c3a2157">
      <Text>Clay (28) sits at a table, signing autographs. Stardust stickers and cards litter around.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="9a67083f-e942-4b0c-8c42-381f1bca3836">
      <Text>Ray (8) is last in line and now in the spotlight.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="e322d1e8-a2b3-4b39-9314-2aa7dc7afd4b">
      <Text>CLAY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="e42d7139-d366-48ca-a31b-8c23ca5b1ce0">
      <Text>Last never least. What’s your name?</Text>
    </Paragraph>
    <Paragraph Type="Character" id="a22bc7f0-88c4-4874-837f-aa18729f6038">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="4960bc1e-e406-4256-bee4-80ad4199d482">
      <Text>Trini Reyes.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="599a073b-6b25-4288-af1b-a91eb6aef53b">
      <Text>ClAY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="31dcdf6b-3798-4dbc-8349-af15055feff0">
      <Text>Ray-</Text>
      <Text AdornmentStyle="-1">ez</Text>
      <Text>, huh? Your last name rhymes with mine. May I call you, “Ray”?</Text>
    </Paragraph>
    <Paragraph Type="Action" id="834661bf-749a-461f-8d85-6e51d01c9ad7">
      <Text>Ray nods her head in acceptance.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="525bf920-e90d-4ca6-8158-867af596dec0">
      <Text>ClAY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="561cd397-6225-4695-ab3e-62681074fce3">
      <Text>What would you like signed, Ray?</Text>
    </Paragraph>
    <Paragraph Type="Action" id="b49aa887-cccd-4e3d-9694-519843e00640">
      <Text>Ray hands Clay a notebook titled “The Girl Who Set Everything on Fire.”</Text>
    </Paragraph>
    <Paragraph Type="Character" id="b9045922-7835-4042-b00e-471b350266fb">
      <Text>ClAY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="6b5fba1a-f35c-4ad0-ad8f-5f753f134c61">
      <Text>Woah, hot off the presses.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="91eeffbf-62a4-4dee-bda3-d93420056464">
      <Text>Clay opens the book, realizing it is an empty notebook.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="a5969339-da9d-4304-8a1b-292df14a85d2">
      <Text>RAY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="5489332d-8697-4664-b2d7-9374c89449f5">
      <Text>I still need to write the book.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="dd661ea3-d41e-4779-be3b-3d75c8f4596f">
      <Text>ClAY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="4c1b281c-e057-4476-8be3-0081e5628f1e">
      <Text>Well, Ray, I cannot wait to read it. Try not to be the girl who sets everything on fire.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="38efb0e9-0caf-436e-b3a6-6cc80d1ac02b">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="e5d531ba-10ed-45aa-9985-317097e37e17">
      <Text>Can we...? Let’s...?</Text>
    </Paragraph>
    <Paragraph Type="Action" id="18d4ef8e-0167-489d-b718-58a408936b89">
      <Text>Clay stands up and joins her in a dance.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="c7c940f6-d617-4188-9383-808824d35e4f">
      <Text>Clay &amp; Ray</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="d334b134-2a30-4d13-b8eb-1526b7cf6ae9">
      <Text Style="AllCaps">Let’s land on this planet
I wonder if we’ll call it home?</Text>
    </Paragraph>
    <Paragraph Type="Action" id="28757441-7a0e-4746-b0de-be11f808ce68">
      <Text>They pose together.</Text>
    </Paragraph>
    <Paragraph Alignment="Center" FirstIndent="0.00" Leading="Regular" LeftIndent="1.00" RightIndent="7.50" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="End of Act" id="8320508a-6b7a-43cd-9457-386c90d1a8a4">
      <Text>End of Hot Open</Text>
    </Paragraph>
    <Paragraph Type="New Act" id="1b7e5dc9-80e1-45fb-9e46-269c17b41982">
      <Text>ACT One</Text>
    </Paragraph>
    <Paragraph Type="Scene Heading" id="0d401827-e758-4bd5-a61a-bfc2672207b6">
      <SceneProperties Length="2/8" Page="2" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="CLAY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="RAY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text Style="Bold+AllCaps">over black.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="b2ecb31d-dfdd-4cbd-ae1c-d3a9db53e10f">
      <Text>Ray (V.O.)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="33c8e16e-d140-451c-a7e5-56b3e05cd2f7">
      <Text>Clay... Stardust is in trouble and she needs your help. I need your help. We all need your help.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="9c0a60a4-dd7d-48ad-ba7e-91d74701a1de">
      <Text>ClAY (V.O.)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="4c16ae60-ef3e-4e4d-80ec-0ed4192f4157">
      <Text>You... It’s you.</Text>
    </Paragraph>
    <Paragraph Type="Scene Heading" id="0d401827-e758-4bd5-a61a-bfc2672207b6">
      <SceneProperties Length="5/8" Page="2" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="CLAY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="KWAN">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="RAY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text Style="Bold+AllCaps">Ext. Clay’s Apartment - Morning (2025)</Text>
    </Paragraph>
    <Paragraph Type="Action" id="c67a8205-0caf-449d-bca7-11876d5c2d88">
      <Text>Clay (46) unblocks the camera, continuing from the pilot. He looks off, not directly at the camera as he wants to.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="e9a9cde1-b651-4a45-a1f7-19d71579b86f">
      <Text>ClAY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="8fee6bcf-8866-4736-bbec-f669b12bfca5">
      <Text>Real world! It’s me... </Text>
      <Text Style="AllCaps">Billy</Text>
      <Text>... Do I look like I care? Where is my care? I cannot seem to find care... Oh care no longer exists? Carry on.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="8b7aae06-b265-406c-801b-cd60f660512d">
      <Text>Clay slams the door in Ray’s face.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="82f7b7c0-67e7-41b6-bfed-104eec0e7918">
      <Text>Ray (29) looks at the camera in shock. The camera turns to face a confused Kwan (24), zooming in.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="e4b4c573-7dfd-4abe-9006-84a6155fb3a0">
      <Text>Kwan</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="96043fab-8a46-4298-9d6d-3e3000ad7f1b">
      <Text>Care to explain who he’s talking</Text>
      <Text Size="10"> </Text>
      <Text>to?</Text>
    </Paragraph>
    <Paragraph Type="Action" id="15550b33-9eea-4250-8746-77109ab828b0">
      <Text>Unable to utter a word, Ray rips up Clay’s letter and dumps it in a random trash can. She marches past Kwan.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="8d9e4511-88b5-495d-908a-9b712f33647b">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="7f9399a0-dedf-4162-890d-48bd75aadc37">
      <Text>That’s all the mentorship I need, bruh. Let’s go home.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="9465cbc3-2d6a-4d73-ada1-0f8d27149d27">
      <Text>Kwan looks at her walk away then back at the trash can.</Text>
    </Paragraph>
    <Paragraph Type="Scene Heading" id="2226115f-df5d-4b14-857c-b7fb3cfd8d28">
      <SceneProperties Length="1/8" Page="2" Title="">
        <SceneArcBeats/>
      </SceneProperties>
      <Text Style="Bold+AllCaps">Int. Clay’s APARTMENT - MomENTS LATER</Text>
    </Paragraph>
    <Paragraph Type="Action" id="ce78b784-e1ea-4628-bd87-4ed5684af146">
      <Text>The envelop pieces roll underneath the front door.</Text>
    </Paragraph>
    <Paragraph Type="Scene Heading" id="e2398b68-bcd8-4fcb-9da3-efdda8bd41f4">
      <SceneProperties Length="7/8" Page="2" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="KWAN">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="RAY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text Style="Bold+AllCaps">INt. Kwan’s Car - Moments LATER</Text>
    </Paragraph>
    <Paragraph Type="Action" id="a0b33663-d086-4a56-91ea-452a2e6b5485">
      <Text>Window down, in the passenger seat, Ray looks at the camera.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="c041c0b4-4a7f-4f50-b9c2-a35f5f560453">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="6792307a-c42a-4347-bddf-26ea1a9c40e6">
      <Text>What now, world? Should I stop caring or should I </Text>
      <Text Style="Italic+AllCaps">stop</Text>
      <Text Style="Italic"> </Text>
      <Text AdornmentStyle="-1" Style="Italic">caringgggg</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="5aa19d05-db2d-4d88-a9af-7df4ae3979a7">
      <Text>(Pause)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="6792307a-c42a-4347-bddf-26ea1a9c40e6">
      <Text Style="Italic">Stop which? Caring or altogether?</Text>
    </Paragraph>
    <Paragraph Type="Action" id="6eb2e6dc-12bd-4007-8f4e-a0a138e2e76e">
      <Text>Ray motions like she is slitting her own throat.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="6f692890-3db7-4cf1-9e37-5db4191cb68d">
      <Text>A pair of sock puppets, resembling Stardust on the left hand and Rocket on the right, pop up outside the passenger window.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="8de0c23a-23de-4122-889a-25fe586fcf9b">
      <Text>RAY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="db34c878-bebc-4d43-a72a-f4c2270d39ce">
      <Text Style="AllCaps">Stop it</Text>
      <Text>!</Text>
    </Paragraph>
    <Paragraph Type="Character" id="aa5e8511-3753-47e4-a196-af1c1337a1ad">
      <Text>KwaN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="07a59224-0b30-43e3-ad33-12a10b96251e">
      <Text Style="AllCaps">Start</Text>
      <Text>! Start caring and carry on cause we’re in the Big Apple!</Text>
    </Paragraph>
    <Paragraph Type="Character" id="608b240b-d889-4ee0-85b5-800d571fb66d">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="5e1dbbbb-8868-46b3-a898-2da338431bbb">
      <Text>I hate apples... reminds me of teachers which I’m no good at being-</Text>
    </Paragraph>
    <Paragraph Type="Character" id="b767504b-2e15-480d-91bd-6d2523d19439">
      <Text>KWAN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="f78b4578-d816-42a7-90c7-bb897f66db41">
      <Text>You sound just as miserable as a New Yorker. You’ll fit right in. Come on. There’s Vietnamese nearby.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="56605710-a9f4-411b-8712-a29993f6199a">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="7871bf89-90d4-4d21-9b3b-e86c298b7cf2">
      <Text>What the pho...</Text>
    </Paragraph>
    <Paragraph Type="Action" id="26e57b7b-8797-4568-9906-a0b5a35ec8a9">
      <Text>Ray steps out of the car and shuts the door.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="5bd69e55-53ca-4f97-98af-0b323cf1d94f">
      <Text>KwAN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="e86c067e-3227-4695-833a-648f93325643">
      <Text>Who needs heroes? You’re making progress!</Text>
    </Paragraph>
    <Paragraph Type="Character" id="58af906c-b36f-402a-99b9-11a48acfd356">
      <Text>RAY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="c2b19b64-41f0-4be2-8ceb-01beb123613e">
      <Text>Progress in the most progressive city in the world, after all...</Text>
    </Paragraph>
    <Paragraph Type="Action" id="085d96ba-97ae-4244-90f5-50df295fba2f">
      <Text Style="AllCaps">Pre-lap</Text>
      <Text>: The sound of protestors.</Text>
    </Paragraph>
    <Paragraph Type="Scene Heading" id="f6a0eb19-b50f-4a63-b9aa-4a050930d1c9">
      <SceneProperties Length="4/8" Page="3" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="COOPER">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="KWAN">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text Style="Bold+AllCaps">Ext. New York City Streets - Noon</Text>
    </Paragraph>
    <Paragraph Type="Action" id="198b5ef6-48a1-4222-813e-7114786d9d01">
      <Text>A small but vocal </Text>
      <Text Style="AllCaps">crowd</Text>
      <Text> has gathered. They brandish hand-painted signs: “</Text>
      <Text Style="AllCaps">Gravity is just a theory</Text>
      <Text>”, “</Text>
      <Text Style="AllCaps">Birds ain’t real</Text>
      <Text>”, and “</Text>
      <Text Style="AllCaps">Climate change is a hoax</Text>
      <Text>”.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="d07966c5-22a8-4822-ba29-ac81fdb1263b">
      <Text>KwAN (O.S.)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="fc118ab0-8bcc-4d98-b45f-9cceb71ce7eb">
      <Text>What a backwards town!</Text>
    </Paragraph>
    <Paragraph Type="Action" id="2b6612a4-7bb6-4fc7-be12-038bde483281">
      <Text>Ray and Kwan try to side-step them, but protestor </Text>
      <Text Style="AllCaps">Cooper Owens</Text>
      <Text> (36) thrusts a flyer into her chest.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="ecd93934-b05f-4149-869c-7460686b5e9b">
      <Text>Cooper</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="49c43bef-3bbb-4e5f-a8bf-f8a47bd53179">
      <Text>Don’t let the government “scientists” lie to you, </Text>
      <Text AdornmentStyle="-1">sistah</Text>
      <Text>! The moon landing was just a giant green screen directed by Kubrick!</Text>
    </Paragraph>
    <Paragraph Type="Action" id="02851753-1ead-4b5d-9ef7-bb0c47649752">
      <Text>Ray looks at the anti-science flyer.</Text>
    </Paragraph>
    <Paragraph Type="Transition" id="78317a21-ee16-4166-ae5d-cf2a1aa0229e">
      <Text>Match cut to:</Text>
    </Paragraph>
    <Paragraph Type="Scene Heading" id="731bf318-21ec-43df-a211-bc790c67b043">
      <SceneProperties Length="2 7/8" Page="4" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="AURORA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="CLAY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="KWAN">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="RAY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text Style="Bold+AllCaps">Int. Vietnamese Restaurant - Later</Text>
    </Paragraph>
    <Paragraph Type="Action" id="a375a81f-80a7-4dc6-b371-0dd036620d51">
      <Text>The flyer lies on a zodiac placement on a table.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="a375a81f-80a7-4dc6-b371-0dd036620d51">
      <Text>Ray and Kwan sit at a table with bowls of pho. Kwan is scrolling on his phone. Ray turns to the camera.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="b44115b1-173e-4b45-934d-e2836b5bb369">
      <Text>RAY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="21b3ddf6-0fc5-4599-9e01-8daaf647b6a7">
      <Text>What is the world coming to?</Text>
    </Paragraph>
    <Paragraph Type="Character" id="a222bedb-3b10-46a3-8712-2597475529a0">
      <Text>KwaN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="8788ed3a-9484-46e6-ba41-997804184b07">
      <Text>The Earth will continue orbiting the sun at about 29.78 kilometers a second for five-</Text>
      <Text AdornmentStyle="-1">ish</Text>
      <Text> billion years-</Text>
    </Paragraph>
    <Paragraph Type="Character" id="de5a6a84-4597-4a83-98f2-2acda3f2848e">
      <Text>RAY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="1ea4212b-add5-4b19-b8bf-e1b9f44d40a5">
      <Text>Can’t the sun swallow us up sooner? And before you say anything, please shut your wormhole.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="d971175d-44ea-4acc-a157-38b862da4570">
      <Text>Kwan zips his mouth and tosses away the invisible keys.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="0ac1dc9b-4801-4c80-9580-5d3a26370bc3">
      <Text>Kwan</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="cb8b1abc-5734-4ae8-be45-3d67c605e0fc">
      <Text Style="Italic">Wormhole shut</Text>
      <Text>. But I still have my rabbit hole!</Text>
    </Paragraph>
    <Paragraph Type="Action" id="5022796e-2580-4f0c-bc7b-070dacd87711">
      <Text>Kwan turns his phone around to reveal Ms. Aurora’s latest video: “New Stuff from Stardust.”</Text>
    </Paragraph>
    <Paragraph Type="Character" id="a374775c-2823-40f7-9509-c908f2bb324d">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="433170f3-8030-4121-9d39-df230c4a357d">
      <Text>Stop showing me this A-hole.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="35a3c99c-3032-4f2a-816a-7456d5cf168b">
      <Text Style="Bold+AllCaps">On the phone:</Text>
      <Text> Aurora walks out of a library, filming herself.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="497fce60-0279-4afb-9e9e-ed5b8e6d4c45">
      <Text>Aurora</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="5c9e2ec7-7107-4d8b-b97b-b7dc87a34f0b">
      <Text AdornmentStyle="-1">Wowza</Text>
      <Text>, it’s Ms. Aurora. Support your local libraries. I just got a surprise call from... Well...</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="53ef6f7c-4c45-47ef-8339-d8cf9248e428">
      <Text>(Perfect impression)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="0adce17d-82f4-466f-b4eb-9bbf66353b3a">
      <Text Style="Italic">Twinkle </Text>
      <Text AdornmentStyle="-1" Style="Italic">twinkle</Text>
      <Text Style="Italic"> </Text>
      <Text AdornmentStyle="-1" Style="Italic">twinkle</Text>
      <Text>!</Text>
    </Paragraph>
    <Paragraph Type="Action" id="0879d09c-52eb-4b68-952b-0a7196557ba3">
      <Text>A figure approaches Ray and Kwan’s table.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="e6bae1ef-e78c-443d-9fa6-9edd78db63b8">
      <Text>AuroRA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="0adce17d-82f4-466f-b4eb-9bbf66353b3a">
      <Text>You’ve guessed it! The voice behind your childhood. I can’t say much yet, NDAs and all, to my loyal </Text>
      <Text AdornmentStyle="-1">novas</Text>
      <Text>... the future is us. Trust in yourself-</Text>
    </Paragraph>
    <Paragraph Type="Character" id="95e39130-a6e3-450b-a6b4-43b066a3e7b9">
      <Text>Clay (o.S.)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="1cc99243-5e61-4180-9498-c6bf9777d333">
      <Text>They’re just running the show without letting me know, huh?</Text>
    </Paragraph>
    <Paragraph Type="Action" id="9ec30b89-3cdd-41a4-87de-4959ec533a35">
      <Text>Ray turns around to see Clay looking over her shoulder.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="4e42832e-824c-4fb7-b80f-afb8a145667a">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="612da336-df89-4bbd-b2b2-7c24e6c484c7">
      <Text>What are you doing here? Shouldn’t you be out crushing dreams?!</Text>
    </Paragraph>
    <Paragraph Type="Character" id="5f6f1162-75e5-4d42-adba-889e99cac625">
      <Text>ClAY</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="937ceec9-73d7-4164-a09e-10c0909b2c24">
      <Text>(in Vietnamese; subtitled)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="91e0b008-f8dd-47e6-89b7-e051f47adbc6">
      <Text>I tutor that cashier over there.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="81571530-cf28-4561-9787-d71f668fb3bf">
      <Text>The </Text>
      <Text Style="AllCaps">cashier</Text>
      <Text> (8, Vietnamese child) takes time away from writing on a long receipt to wave back.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="14d20c8a-724e-4c26-ace2-b5dfcd472dc0">
      <Text>ClAY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="44af4c08-3c6c-46a2-8449-220d0a5a42b4">
      <Text>They’re falling behind in triple integrals, but they got astrodynamics down to the G.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="4dd88928-627a-49d1-a0f4-2a43eea76948">
      <Text>Clay glares at the anti-science flyer on the table.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="b5b178d2-fc78-4c3f-bc54-d5fe3ed73d11">
      <Text>ClAY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="5ad64e89-8b4b-43e3-9ba3-63a2ea56b31b">
      <Text>How could you trust MSG seeing that you attend anti-science rallies? And before you ask why I’m here.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="73be35fb-d615-4607-9ecb-be9eb101f098">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="e84568bb-7f0b-4d31-80a0-e659236d7c27">
      <Text>G is gravitational force. No one believes in science more than me.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="ff6cbebc-7bf1-4924-939b-f495186ba5dd">
      <Text>ClAY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="53bc7899-9dd3-4657-aea3-845c1ea4c7c3">
      <Text>And I believe in you. Both of you.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="94ddf1e1-30d0-411b-a203-445f3f5dc1c1">
      <Text>RAY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="b2f89ac6-5f01-4889-90fb-43a717b9a360">
      <Text Style="Italic">You told thin air you don’t care</Text>
      <Text>...</Text>
    </Paragraph>
    <Paragraph Type="Action" id="3936dbac-55eb-4397-a4a3-0ffea40b5b1d">
      <Text>Clay tries to turn towards the camera but veers too far off.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="72a7bd7e-1053-4bc1-b7db-092cb20d0b31">
      <Text>ClAY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="ec09db84-8471-4a66-aece-7e7fa4423f4b">
      <Text>And I’m sorry for making you feel like thin air. I care.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="dda110fa-1131-4cd0-a83d-68a45e3870c1">
      <Text>Ray looks where Clay is staring. It is nothing of relevance. She looks to the camera, weirded out.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="63b255a9-8d95-408b-88cf-85d6a37b8b74">
      <Text>Kwan looks where the two are looking, even more weirded out.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="36ecc0f3-f249-4779-9080-6b395f050aea">
      <Text>KWAN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="9af54e3f-8722-41f2-8a1d-378c5f7eaca6">
      <Text>Looks like there’s someone who sees our world differently like you.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="47c29031-58d3-40f2-b924-ca312fce727f">
      <Text>RaY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="011f1aa9-5d28-4f45-b21d-8dc59a6e9850">
      <Text>Too bad he don’t know where to</Text>
      <Text Size="10"> </Text>
      <Text>look.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="797a8076-b514-4520-ba06-5f952726454e">
      <Text>ClAY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="27f4f995-b58a-4d15-94ab-4c01928cc686">
      <Text>Not anymore. But with your guidance, perhaps I can return.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="c318a3fa-466e-45f1-95f1-988063755982">
      <Text>Ray looks at the camera.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="c3ff61ff-58ac-4903-b25c-b52d7c555086">
      <Text>RAY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="d5ce0806-9b53-4070-af43-364fde475396">
      <Text>I’m the mentor?!</Text>
    </Paragraph>
    <Paragraph Type="Character" id="70a6dbb5-69a7-4269-87a6-aba95f1e0d42">
      <Text>ClAY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="36bd3c85-c7b9-4c05-b051-550d8c8b2e6c">
      <Text>Exactly! Like what you’re doing.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="cf9183cb-e5c6-4c5f-88ad-217f14efd0e8">
      <Text>RAY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="e6635078-12cf-4d3d-80f2-82e7c56ef96f">
      <Text>You’re playing me for a fool.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="e1ba7ea5-e802-4e83-aa30-3cb84b4d5176">
      <Text>ClAY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="860f7c71-bc12-468f-a18f-dd4c49362681">
      <Text>Not at all. But my two </Text>
      <Text AdornmentStyle="-1">bestest</Text>
      <Text> friends in the world have...</Text>
    </Paragraph>
    <Paragraph Type="Character" id="a61c3c96-d44f-44d9-813c-611fbf4151cd">
      <Text>RAY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="8ac7b717-cf31-4d54-9b71-0bd053ad2ff8">
      <Text>They really didn’t tell you...?</Text>
    </Paragraph>
    <Paragraph Type="Character" id="bcddbf3c-b44f-4d07-a256-528c6cd1a1fa">
      <Text>ClAY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="d9d4715b-4408-4657-a1cb-7888f08c30c1">
      <Text>How could they? How would they approach someone more cartoonish than cartoons?</Text>
    </Paragraph>
    <Paragraph Type="Character" id="c44ae047-1fab-4cba-8fc7-21f4d3df6d6c">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="2a429a5a-15b1-4fd5-ab6e-7bd2addb97a0">
      <Text>Well, nothing matters... They’ve got Ms. Aurora. The perfect host.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="c79da7e0-d439-4dc0-b64b-53c1b7904566">
      <Text>ClAY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="70b4ab0a-95a9-4fdc-8081-53ea032eff47">
      <Text>Ray... You’ve got something this Ms. Aurora don’t got...</Text>
    </Paragraph>
    <Paragraph Type="Character" id="5a7944a4-c2af-4f87-b3da-7ab9ee1f4249">
      <Text>KWAN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="ebf1c7c6-f98e-428b-ae73-b33ea3e9f88b">
      <Text>Anger management.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="49e5ba28-0a10-45ec-84a0-7764a35dc7b5">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="606de58c-e804-4534-bfdd-53e55f2cf8f7">
      <Text>(in Tagalog; subtitled)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="55e122da-9dbc-41b2-b2b9-7757d615bee7">
      <Text>Shut up!</Text>
    </Paragraph>
    <Paragraph Type="Character" id="35ce848f-4f35-4bdb-b6f0-800738b19036">
      <Text>ClAY</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="7b30b33f-d6b1-43c0-8340-c8e0c4dd0297">
      <Text>(in Tagalog; subtitled)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="ac0e1860-1a5c-4437-8512-050aaa703b40">
      <Text>You’ve got my blessing.</Text>
    </Paragraph>
    <Paragraph Type="Scene Heading" id="3d721ddb-2f68-4502-87b8-8e6e9cf2cfe0">
      <SceneProperties Length="3/8" Page="6" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="CASHIER">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="RAY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text Style="Bold+AllCaps">Int. Kitchen</Text>
    </Paragraph>
    <Paragraph Type="Action" id="54f22948-cd46-4ea7-841f-37b13061530b">
      <Text>Ray is back in the kitchen. This time, it is empty.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="a2f50900-afe1-4f72-9a34-220a8798e609">
      <Text>RAY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="2e6b22e1-ba6b-40d5-be00-621e79c44732">
      <Text>I can’t believe Clay is doing me a solid! It was off to a rocky start. Now, a foundation. Plus, he can speak Tagalog, Viet. </Text>
      <Text AdornmentStyle="-1" Style="AllCaps">Oooeee</Text>
      <Text>-</Text>
    </Paragraph>
    <Paragraph Type="Action" id="99e50279-ff10-496c-9514-8c6ff181633a">
      <Text>The Cashier kid pushes Ray out of view.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="630c43d4-6889-4084-8565-9c003ceaeccd">
      <Text>Cashier</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="d4aef347-a730-41c3-a0e1-484d05e19a10">
      <Text>(in Vietnamese; subtitled)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="e6962d8b-c628-476f-acd0-96b6e0d81944">
      <Text>His Vietnamese needs work. Now girl, get out of the kitchen!</Text>
    </Paragraph>
    <Paragraph Type="End of Act" id="7d3b6731-5a4c-47e2-9afe-5fcdc6bb06d3">
      <Text>End of Act One</Text>
    </Paragraph>
    <Paragraph Type="New Act" id="1b7e5dc9-80e1-45fb-9e46-269c17b41982">
      <Text>ACT Two</Text>
    </Paragraph>
    <Paragraph Type="Scene Heading" id="696f694f-6582-439d-9cbc-d45b43622a56">
      <SceneProperties Length="2" Page="8" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="CLAY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="KWAN">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="RAY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text Style="Bold+AllCaps">Int. Clay’s Apartment - Late Afternoon</Text>
    </Paragraph>
    <Paragraph Type="Action" id="ebd73234-02b3-470e-b3c5-617e2c3525ee">
      <Text>This place is a hoard of space junk.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="ebd73234-02b3-470e-b3c5-617e2c3525ee">
      <Text>Ray and Kwan walk by a </Text>
      <Text Style="AllCaps">rocket ship hatch</Text>
      <Text> now used as a table. There are crates of unopen fan mail. Kwan blocks his nose.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="889a698d-c92a-4e22-b1de-1467d7fe0098">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="38528006-4158-49b1-9b90-266a38b703f8">
      <Text>A </Text>
      <Text AdornmentStyle="-1">Miniverse</Text>
      <Text> all in one New York apartment...</Text>
    </Paragraph>
    <Paragraph Type="Character" id="e92c391e-840f-4879-aab6-1f95e5bc6725">
      <Text>KWAN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="a2e7eff2-7bc1-4ef5-a324-f7e79acb5fce">
      <Text>Who knew the </Text>
      <Text AdornmentStyle="-1">Miniverse</Text>
      <Text> is 26.8 percent dark matter and 68.2 percent methane?</Text>
    </Paragraph>
    <Paragraph Type="Action" id="ebd73234-02b3-470e-b3c5-617e2c3525ee">
      <Text>Clay settles into a stellar armchair. Ray and Kwan sits opposite him on set pieces.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="176b2f6a-9162-4fa3-99f9-04b8ea35af51">
      <Text>CLAY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="e0f9936b-fe8e-462c-82d8-5431bf7152fc">
      <Text>The methane is hard to clear out, so let’s instead get straight to the heart of the matter...</Text>
    </Paragraph>
    <Paragraph Type="Character" id="43f300c5-176b-430d-ba03-4f48eb8e3697">
      <Text>RAY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="a5941d93-a949-4aee-b520-a5933bb6daae">
      <Text>You really think this would work?</Text>
    </Paragraph>
    <Paragraph Type="Action" id="469fb935-f4e2-49f7-ac94-c9fcb89871d4">
      <Text>Clay faces the camera but veers off once again.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="f3ea6b8d-a393-445a-989c-33ddefa22abb">
      <Text>ClAY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="8f2bab2b-54dc-4239-9a38-8232abd86d55">
      <Text>Will recording Ray’s audition video with my cameo work out? Would it help Ray or hurt my credibility? Would it hurt Ray or help my credibility? Do you even know what “credibility” even means?</Text>
    </Paragraph>
    <Paragraph Type="Character" id="17af1ed9-fbb1-4c1c-a9ff-c64f8e45479f">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="1a59ef5d-b512-4d03-a597-1adc031cb9e7">
      <Text>(to camera)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="9def31d6-e6e2-426e-922f-22d36ce14e0c">
      <Text>This is... </Text>
      <Text Style="Italic">incredibly</Text>
      <Text> weird. Who is this guy even talking to?</Text>
    </Paragraph>
    <Paragraph Type="Action" id="b337899f-5177-404c-af3f-b5a00367b3eb">
      <Text>Clay sits on a chair, reading a script off a tablet.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="bd5d2719-8615-4819-9055-a67b6a990c59">
      <Text>ClAY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="9b4bf588-e9f2-4463-8144-ae752dd0c0d5">
      <Text>Science communicators?</Text>
    </Paragraph>
    <Paragraph Type="Character" id="b74f5b6a-5ee9-446f-ac8a-5acce088cd42">
      <Text>RaY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="0bf4ae91-848d-4b7a-aa35-8f89be6a96b0">
      <Text>That’s me.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="da3e813c-3809-4eb4-827f-dfd8543a1b08">
      <Text>ClAY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="d707f149-9fc7-4899-b0b5-62a4bcc518b3">
      <Text>That’s what they’re calling it now.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="b337899f-5177-404c-af3f-b5a00367b3eb">
      <Text>Ray tries positioning Clay to get as much sunlight as possible. Kwan vertically holds up Ray’s phone.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="e561d732-d28d-4434-8183-315db20e2cc2">
      <Text>Ray gestures Kwan to rotate it from vertical to horizontal. After he does so, Ray gives a thumbs up. Clay reciprocates.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="36e68381-474a-4f4a-b2f3-b0519ac08b71">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="e936f03f-1070-4c79-9104-cfbfe9d5c7ab">
      <Text>Got your lines down?</Text>
    </Paragraph>
    <Paragraph Type="Character" id="89261bbc-e55f-47e3-a48c-67a51084d423">
      <Text>ClAY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="86485112-88d9-441d-8890-620bf35b1662">
      <Text>Absolutely, and I won’t take it lying down.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="bfe54d3e-65bf-4940-84f6-ca7cd635917a">
      <Text>Kwan taps </Text>
      <Text Style="AllCaps">record</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="7c71157c-4e80-4707-974f-a0fb4b2520e9">
      <Text Style="Bold+AllCaps">Through the camera</Text>
      <Text>: Ray stands behind a sitting Clay.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="8a1e3038-6abc-4cab-be0d-461a0a8a140b">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="b6079437-1a51-4af4-861b-ab62fa3e9fa4">
      <Text>Planets, comets, gals everywhere! It’s me, Trini Reyes, but you-</Text>
    </Paragraph>
    <Paragraph Type="Character" id="be7f370b-4fbb-477f-bf75-33eae3d74a81">
      <Text>CLAY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="30cc8c76-4583-4471-b058-3c4459269ec9">
      <Text>You can call me Ray- Clay- </Text>
      <Text Style="AllCaps">Clay</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="e1e6163d-f672-40be-910c-000bc8d26bf7">
      <Text>RAY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="9f3fca20-5528-426b-b9fd-b98068694091">
      <Text>Wow, our names rhyme. My nickname is Ray, just to clarify. I’m here with the one and only!</Text>
    </Paragraph>
    <Paragraph Type="Character" id="66021686-457d-418a-a0c9-0281700ec346">
      <Text>CLAY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="2377dac2-1dfd-4e2c-a3da-9b55641dd4c5">
      <Text>I’ve never revealed my cousin, Ray. Or the </Text>
      <Text Style="AllCaps">big news</Text>
      <Text>: Stardust is coming back in a new TV show. She’ll need one of us to help her back on her feet, or wings, or whatever she has. I stand behind Ray, as-</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="0594f116-19b5-4dbf-8cc1-66e5c7e20d7d">
      <Text>(Breaking character)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="6c7736ae-2992-4fed-94a7-2e9e8bc8e414">
      <Text>Actually, shouldn’t you be sitting and I be standing behind you?</Text>
    </Paragraph>
    <Paragraph Type="Character" id="0c796d75-9c57-41c5-964c-5d2a7ae3292c">
      <Text>KwAN (o.S.)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="eb6449e8-0697-4451-97c3-89c842296d90">
      <Text>Finish this take. Then we reshoot.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="daf19874-fb27-4db2-9851-b10a972f46c7">
      <Text>RaY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="a280b040-f991-42e2-84a0-31ca1d13e6d8">
      <Text>Okay, director. Trying to get Razzie Awards’ attention, huh?</Text>
    </Paragraph>
    <Paragraph Type="Character" id="6a7520de-d223-41e8-900a-064ff754e763">
      <Text>ClAY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="79673531-f6fe-446a-8b8e-57196e4ca4fd">
      <Text>As I was saying...</Text>
    </Paragraph>
    <Paragraph Type="Transition" id="5ed38373-b1af-44f2-8a7f-da5a1e0ffccf">
      <Text>Match cut to:</Text>
    </Paragraph>
    <Paragraph Type="Scene Heading" id="c6e28d60-8bc4-41c2-a8e6-8cdd5eede14e">
      <SceneProperties Length="4/8" Page="10" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="CLAY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text Style="Bold+AllCaps">Ext. Plaza - Day</Text>
    </Paragraph>
    <Paragraph Type="Action" id="9c83e87e-141f-45f4-b07b-07087081039f">
      <Text>A </Text>
      <Text Style="AllCaps">kid</Text>
      <Text> shows the tablet to a </Text>
      <Text Style="AllCaps">parent</Text>
      <Text>. They share</Text>
      <Text Size="10"> </Text>
      <Text>a</Text>
      <Text Size="10"> </Text>
      <Text>happy</Text>
      <Text Size="10"> </Text>
      <Text>moment.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="c1e7432b-a17b-4c2e-a489-5bb28c9eb965">
      <Text Style="Bold+AllCaps">Through the tablet</Text>
      <Text>: Ray is now sitting on the armchair. Clay stands behind her. He is definitely reading cue cards.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="bccaceec-2766-45fc-9e78-f05329ebbda5">
      <Text Style="AllCaps">Montage</Text>
      <Text>: As Clay speaks, children from around the world react to the news. Many adult fans prepare their auditions.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="528d6651-3c3a-4b01-9cd7-8475cfddc6c9">
      <Text>ClAY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="0508eaed-a8f8-4cb7-b668-d1681fb8f010">
      <Text>I stand behind Ray and a journey she might have with Stardust. She’s what it means to be a science communicator. It’s brave of her to send audition number one to us. Now, for anyone else interested in being considered and judged by the almighty Stardust, get your tapes in soon. More info’s probably on the </Text>
      <Text AdornmentStyle="-1">RBS</Text>
      <Text> website.</Text>
    </Paragraph>
    <Paragraph Type="Scene Heading" id="887fcb61-425e-4450-946c-72e099bea070">
      <SceneProperties Length="1" Page="10" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="CLAY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="KID">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="PARENT">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="RIVER">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text Style="Bold+AllCaps">Park - Day</Text>
    </Paragraph>
    <Paragraph Type="Action" id="4e4da860-8e47-4fde-bc86-5734342f439e">
      <Text>River is jogging through a park.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="9c8f2de7-9c39-4c3c-b1fc-09c55087e75d">
      <Text>ClAY (V.O.)</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="8d64ffc4-d367-4e98-aeff-0d3cdef55b06">
      <Text>(with pettiness)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="acc33549-2e2c-45a9-8709-de26d2756ffd">
      <Text>On behalf of River Matthews and Skye Park... They would love to go through all your auditions...</Text>
    </Paragraph>
    <Paragraph Type="Action" id="4e4da860-8e47-4fde-bc86-5734342f439e">
      <Text>River stretches by a tree. A </Text>
      <Text Style="AllCaps">kid</Text>
      <Text> and a </Text>
      <Text Style="AllCaps">parent</Text>
      <Text> cross her path.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="6e09e16f-ac1f-47b5-9cfd-cc6b861d9452">
      <Text>Kid</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="8f46ee51-ae57-4c51-bf16-60bb7d4cfa87">
      <Text>Twinkle, twinkle, twinkle!</Text>
    </Paragraph>
    <Paragraph Type="Character" id="1d126695-0a6d-4a58-8321-9814ca7b83f1">
      <Text>RiVER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="0b8243e1-3022-4fcf-b4fd-2517c714682f">
      <Text>Twinkle! Oh wow. It’s an honor to be recognized in the wild!</Text>
    </Paragraph>
    <Paragraph Type="Character" id="9e9f9070-a29b-41ac-9419-dc2574db8257">
      <Text>Parent</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="e9ee0cfd-9d6e-4a57-8cce-fe9048c1fa51">
      <Text>Can my kid get a picture with you?</Text>
    </Paragraph>
    <Paragraph Type="Character" id="ea69224d-292a-4405-8e68-a5dc13101204">
      <Text>River</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="4eb3a814-ad2c-44da-a7b8-62b0bd1e7068">
      <Text>Twinkle absolutely!</Text>
    </Paragraph>
    <Paragraph Type="Action" id="1ba22298-56cc-47ce-8645-095bcff27158">
      <Text>River poses with the kid. Their parent snaps a picture.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="6ca6dc65-9cc0-4c33-a3f2-3431f72f0564">
      <Text>PareNT</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="f79c7c63-0716-40c8-a5aa-5df8810b089b">
      <Text>Do you still do studio audiences?</Text>
    </Paragraph>
    <Paragraph Type="Character" id="df1d3bf3-b41a-4995-a3c7-4bb96e8b74cb">
      <Text>RiVER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="a2af4b24-e7de-4b50-a886-8a55109a94f2">
      <Text>We’ve tried a few times. But the pauses never worked out for our host. The kids... They were too fast, too bright. Like you.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="06987ef1-8c35-4808-8abc-61fc4a096db9">
      <Text>ParenT</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="c0f1cd49-e68a-4533-997f-229edcc45722">
      <Text>Mine sure is bright but takes their time. If you do consider a live audiences for your upcoming revival, please invite us!</Text>
    </Paragraph>
    <Paragraph Type="Action" id="e6ace2e0-e4b3-4b56-80b9-9fb8372c8751">
      <Text>The parent and kid walk away.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="5b699157-5d1e-4b39-86bc-2dcf3f740619">
      <Text>RiVER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="3a32f231-463e-4eed-acde-ea49976235a0">
      <Text>R-r-revival? How did you know we’re coming back? Did </Text>
      <Text AdornmentStyle="-1">RBS</Text>
      <Text> send you to spy on us?!</Text>
    </Paragraph>
    <Paragraph Type="Action" id="b126b147-c8ce-41c1-af7c-b4faeba06796">
      <Text>River notices a claystone below her. She tries to ignore it, only to kick it away into oblivion.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="aade3192-e762-472d-a209-8c073418d4fd">
      <Text>River (Pre-lap)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="82b8885b-c390-4a09-b7c5-64b3bd55db81">
      <Text>Clay is all over the world!</Text>
    </Paragraph>
    <Paragraph Type="Scene Heading" id="c89bd954-a01b-42aa-8b01-8ab19d01d538">
      <SceneProperties Length="2 1/8" Page="11" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="AURORA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="CLAY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="RIVER">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="SKYE">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text Style="Bold+AllCaps">Rainbow Broadcasting Service Offices - Writer’s Room - Day</Text>
    </Paragraph>
    <Paragraph Type="Action" id="b0aca12c-068e-4554-bbf4-11a45ba27c96">
      <Text>On the white board are countless pictures of Ms. Aurora.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="a05bae22-4871-4a91-b7ac-c2bd8e631be3">
      <Text>Skye</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="500d542c-70a2-4f3b-ae1b-ab6ba755f2e0">
      <Text>Clay is found in oceans, lakes, </Text>
      <Text AdornmentStyle="-1">riv</Text>
      <Text>-</Text>
    </Paragraph>
    <Paragraph Type="Character" id="6cbdf708-14ad-43ac-a22e-63d9759b9973">
      <Text>RivER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="f8f341bd-8d9f-4372-9398-b2d96022dad7">
      <Text>Skye...</Text>
    </Paragraph>
    <Paragraph Type="Character" id="3def3b13-aff7-439e-8f2b-009e3757588e">
      <Text>SkYE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="89d350e3-d5cb-499c-a2ab-1c257b751b96">
      <Text>Clay is not known to be airborne...</Text>
    </Paragraph>
    <Paragraph Type="Character" id="19b726d6-dbe0-438d-be16-fb77868ac88f">
      <Text>RivER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="5125f7ca-bc18-4b15-9817-14656707913b">
      <Text>Seriously, Ray’s video is on Stardust’s official YouTube page!</Text>
    </Paragraph>
    <Paragraph Type="Character" id="a40d5d6f-8fd5-47bc-a173-b1a7d26ac930">
      <Text>Skye</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="598a2a59-5ad8-49e5-a396-734d59280188">
      <Text>Long form videos aren’t in anymore. Kids are all over Click Clock!</Text>
    </Paragraph>
    <Paragraph Type="Character" id="19b726d6-dbe0-438d-be16-fb77868ac88f">
      <Text>RiVER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="80f80908-3536-4ad5-a11d-fa5ca18a3998">
      <Text>Ding dong for brains. They also uploaded on our Click Clock. You didn’t think to change the password after he uploaded his anniversary video? Well? Go delete his new one!</Text>
    </Paragraph>
    <Paragraph Type="Action" id="55b1fde4-f153-457a-bc52-d8bdd37ce802">
      <Text>Skye tries to work the tablet.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="470afcc8-10f9-4382-96ab-58e89bf67d9d">
      <Text>Skye</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="af45fe9c-6ba5-4d9c-bcd5-476b261049b8">
      <Text>I can’t... </Text>
      <Text Style="Italic">He changed the password</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="3f6d275e-ee17-449a-a9d3-0bfdac8da514">
      <Text>RiVER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="0d9077ec-f200-4a6d-973e-c4c097b994a0">
      <Text>Maybe, we could put it out there that Stardust channel was hacked or that this video was AI.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="9b456a3d-aeb1-41eb-86b4-2cf943d7b131">
      <Text>SkYE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="af45fe9c-6ba5-4d9c-bcd5-476b261049b8">
      <Text>Clay would be literal clay if AI tried to make clay happen. No one wants to see Clay now, washed up and balding-</Text>
    </Paragraph>
    <Paragraph Type="Character" id="d756c76a-688e-4fab-aba4-538e34c6f057">
      <Text>RiVER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="dfef5f76-e744-4586-8acb-99c8a8b944c0">
      <Text>They see themselves in him. That’s why they watch.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="0390bad5-c848-4558-bfc6-169053d17030">
      <Text>Skye</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="4c8d460b-53dd-460f-80a4-a96d98c840c4">
      <Text>Maybe... we should ask Clay back.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="2668faf0-2c99-4ab3-9e71-b1bd3dc1365a">
      <Text>RivER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="ac9074bd-4974-441d-b4dc-997926c602df">
      <Text>I love Clay to the moon. But no can do... Never after his accident...</Text>
    </Paragraph>
    <Paragraph Type="Character" id="71054f75-e22c-4a5c-b61e-4032654c0002">
      <Text>CLAY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="6bcea01f-3111-49cf-90d5-c541ac47bf29">
      <Text>To the moon but not back... Well, then let’s proceed and greenlight this backbreaking process...</Text>
    </Paragraph>
    <Paragraph Type="Action" id="9616172e-bb0a-4f6d-92cd-c8abed08ce3a">
      <Text>River dials and video calls Aurora. Aurora picks up.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="06df5b12-3f67-4c04-ba1d-065d8ab69043">
      <Text>RivER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="495d500a-a776-434a-80d5-3371a87b0451">
      <Text>Hey Ms. Aurora.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="c802fea9-2461-4f98-b0ed-aac7f000b4ee">
      <Text>AuRORA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="a7950c88-bec2-445c-8843-98e15ad0c2a1">
      <Text>River, how’s the stars treating</Text>
      <Text Size="10"> </Text>
      <Text>you?</Text>
    </Paragraph>
    <Paragraph Type="Character" id="7a9833cf-58f5-44df-ac01-3282e7d64b1c">
      <Text>RiVER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="2c8d83da-8c86-4528-8f15-ce95a80b5cbf">
      <Text>Well, the stars is sending rays of sunshine... and it keeps coming and coming... probably ‘til it fries me-</Text>
    </Paragraph>
    <Paragraph Type="Character" id="feb1287f-3183-4b73-a7a8-b42229424f7e">
      <Text>AuRORA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="cc6a2b9a-5d75-4bea-b1d4-785669b33b6a">
      <Text>I saw that video. Clay with Ray. I can say: I’m friends with a friend with a famous person! </Text>
      <Text AdornmentStyle="-1">Eeeeekkkkk</Text>
      <Text>!</Text>
    </Paragraph>
    <Paragraph Type="Character" id="7574c829-0a55-42ec-9b8b-db1785ebe468">
      <Text>RiVER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="0e30548c-fa80-4610-a5f0-ad4d18306b13">
      <Text>You know Ray?</Text>
    </Paragraph>
    <Paragraph Type="Character" id="02c9d16d-c773-4dd8-a87e-a67519ebaa5f">
      <Text>AurORA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="ca483658-8d35-40f6-a0e6-bcd195983409">
      <Text>We’re besties from theatre camp!</Text>
    </Paragraph>
    <Paragraph Type="Character" id="37af0fe6-b95e-4f6a-b65f-a7d8a7268cd7">
      <Text>RiVER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="088e6b3c-7c6a-4f3f-b3bd-8a5e6dd7dffc">
      <Text>So, it wouldn’t hurt to join her in a pool of, give-or-take, a couple thousand auditions?</Text>
    </Paragraph>
    <Paragraph Type="Character" id="a1a69518-660b-4958-b59d-53ab9ff49412">
      <Text>AuroRA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="e00e3575-753c-4f92-9f83-352999e7de1d">
      <Text>That’s a couple thousand potential friends. And I love a challenge!</Text>
    </Paragraph>
    <Paragraph Type="Action" id="219d7345-54d3-4f44-b3cb-e0435e6e601a">
      <Text>River covers the bottom of her cell phone with her hand.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="c628b7fd-f433-4330-83f8-485987b8a9d8">
      <Text>RivER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="a2d910c9-34bb-435d-88c1-3da0c22b5c69">
      <Text>I love this nerd. She doesn’t need to audition to be my wife, no siree-</Text>
    </Paragraph>
    <Paragraph Type="Character" id="feb013bb-2510-4c94-9288-0d16c2bc04b2">
      <Text>SkYE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="8454d8f9-2f01-4bb0-b424-a8f7078d8532">
      <Text>You know that’s not a landline and she can still hear you.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="9a377a5f-65ed-4058-991d-412d890ae33b">
      <Text>River looks at the phone to see Aurora, somewhat blushing, somewhat weirded out.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="f3bec925-83c4-4fde-914e-bb27371aabff">
      <Text>RiVER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="22d850e8-fb0d-4f8c-aad2-609762f7b5c6">
      <Text>See you across the finish line! Of course, after a fair and ridiculously thorough process.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="e23ac873-e9bb-4454-9f61-136f499ed2ec">
      <Text>River hangs up the phone. She nearly collapses in a chair.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="f896525b-b943-484e-959f-5940b7d65a85">
      <Text>SkyE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="54f39c19-aa95-424d-93f5-5aaf1a75cd9e">
      <Text>River... This will all wash over.</Text>
    </Paragraph>
    <Paragraph Type="Scene Heading" id="696f694f-6582-439d-9cbc-d45b43622a56">
      <SceneProperties Length="5/8" Page="13" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="CLAY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="KWAN">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="RAY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text Style="Bold+AllCaps">Int. Clay’s Apartment - Day</Text>
    </Paragraph>
    <Paragraph Type="Action" id="16e4132f-56ff-4b57-973b-1cf04d7aee84">
      <Text>Ray sits on the sofa, constantly refreshing RBS’s website.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="8a00d4a8-9c1e-4050-b454-b8a03d493e7c">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="620fe967-2754-4402-9ecd-df1d79f41ba0">
      <Text>Come on, </Text>
      <Text AdornmentStyle="-1">RBS</Text>
      <Text>... don’t do this. Just give me something.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="867e5a71-a77a-47ee-808b-a74c6dda7d18">
      <Text>Kwan is sitting on a stack of old magazines.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="485b1a2e-9f2f-47c8-929c-0a9c39de8e76">
      <Text>Kwan</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="d3977974-0e89-478b-ac16-2a39216a4efa">
      <Text>You’re gonna break the screen before a sweat, bruh.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="21b1169c-8243-4cb4-9a44-20fd4f425944">
      <Text>Clay is staring intently at a spot on the wall.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="3468c455-c1f1-4235-a297-33f202a86ff7">
      <Text>ClAY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="d3977974-0e89-478b-ac16-2a39216a4efa">
      <Text>Seriously. Take a breath. You’re already the first one they’re gonna see.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="0a259a4c-b801-46ab-b900-71c17603606b">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="a693f093-493a-4bc6-aa71-795501000dc7">
      <Text>Yeah, but I’m not on their official—</Text>
    </Paragraph>
    <Paragraph Type="Action" id="ed74d04e-2daf-445b-9def-0de025db7ab6">
      <Text>Ray hits refresh. The Rainbow Broadcasting Service homepage flickers. The corporate logo is replaced by a bright banner: </Text>
      <Text AdornmentStyle="-1" Style="AllCaps">StarPower</Text>
      <Text Style="AllCaps"> needs a friend Audition.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="954e860a-047c-442f-a9c8-d920b38451ad">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="fd67302b-9fde-4a48-9126-4725996ea616">
      <Text>-website! Finally.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" RightIndent="7.50" SpaceBefore="24" Spacing="1" StartsNewPage="No" Type="Scene Heading" id="31c77a01-d5d7-4ab5-ab9c-b7e0b7e4db3c">
      <SceneProperties Length="4/8" Page="14" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="RIVER">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="SKYE">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>Int. </Text>
      <Text AdornmentStyle="-1">RBS</Text>
      <Text> Offices - Computer Room - Day</Text>
    </Paragraph>
    <Paragraph Type="Action" id="7b25edd7-0fcf-4724-9417-4ff118fad5cd">
      <Text>River and Skye are bathed in the light of a dozen monitors.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="df435b21-7e71-4f9b-9126-e7738d957935">
      <Text>Skye</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="cbafea80-7558-42c7-8329-a7db6622e71c">
      <Text>The server is sorta </Text>
      <Text AdornmentStyle="-1">laggy</Text>
      <Text>. We’re getting twenty uploads a minute.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="3a2bc924-9726-4ce2-835b-01bcb35c4968">
      <Text>River rubs her temples.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="7163a504-b0f3-4555-99cd-936092416f8d">
      <Text>River</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="a1027ea3-dee8-4f23-9401-0a0970b1daf8">
      <Text>Clay backed us into a corner. If we don’t make this look like a real search, the fans are going to turn us into space dust.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="2f194459-b716-4348-87db-81354a8e075d">
      <Text>Skye</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="75cf549a-bc46-4004-b6c5-7d05fba59fbd">
      <Text>So we’re really going to sit through forty-two hundred tapes?</Text>
    </Paragraph>
    <Paragraph Type="Character" id="19c4aa88-aad0-4e29-a45a-1e54b98b2a87">
      <Text>River</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="f3ac5e8b-1783-4b7c-bb79-3a5585f7940a">
      <Text>We’ll watch everyone’s auditions. I want a fair process... that ends with the person I wanted to choose.</Text>
    </Paragraph>
    <Paragraph Type="End of Act" id="7d3b6731-5a4c-47e2-9afe-5fcdc6bb06d3">
      <Text>End of Act Two</Text>
    </Paragraph>
    <Paragraph Type="New Act" id="1b7e5dc9-80e1-45fb-9e46-269c17b41982">
      <Text>ACT Three</Text>
    </Paragraph>
  </Content>


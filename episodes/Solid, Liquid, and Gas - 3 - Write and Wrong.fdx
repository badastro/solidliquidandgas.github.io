<?xml version="1.0" encoding="UTF-8" standalone="no" ?>
<FinalDraft DocumentType="Script" Template="No" Version="6">

  <DocumentRef DateTime="20250719T225100" id="311bf653-30ed-4d65-a49b-1d9bc7012bab">
    <XRef DateTime="20250719T224917" id="326d3bbb-277d-4966-b8b4-fc0c38660087"/>
  </DocumentRef>

  <Content>
    <Paragraph Type="New Act" id="6b67055e-8e0a-4c01-b26e-48bdef828a9a">
      <Text>Cold Open</Text>
    </Paragraph>
    <Paragraph Type="Scene Heading" id="6353e508-3b10-494d-afbb-ca218dde3018">
      <SceneProperties Length="1 1/8" Page="1" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="AURORA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="DIRECTOR">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="RAY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text Style="Bold+AllCaps">Ext. Theater Camp Amphitheater - Day (Summer 2014)</Text>
    </Paragraph>
    <Paragraph Type="Action" id="45e35927-67a8-44f1-89aa-0b99dad99afc">
      <Text>The stage is a place of the highest drama and lowest budgets. </Text>
    </Paragraph>
    <Paragraph Type="Action" id="45e35927-67a8-44f1-89aa-0b99dad99afc">
      <Text>The </Text>
      <Text Style="AllCaps">campers</Text>
      <Text> sit in the audience seats. Aurora (17), poised and polished, sits front row. Ray (17) slides into the row behind her, breathless and shaking with nervous energy. </Text>
    </Paragraph>
    <Paragraph Type="Character" id="6e5bcbcf-47af-46be-a722-bde9c66c92da">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="5a086580-8945-4108-ab0b-d4420fc1d8d7">
      <Text>(to camera)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="2738ef4f-ee53-4b36-b099-168ae5f61d4c">
      <Text>Last year at theater camp. Time to go out with a </Text>
      <Text Style="AllCaps">pan</Text>
      <Text>! I’m a shoo-in for Peter Pan. Senior privileges, let’s </Text>
      <Text AdornmentStyle="-1">goooooooo</Text>
      <Text>!</Text>
    </Paragraph>
    <Paragraph Type="Action" id="950c959c-aea5-43e7-9443-6229b45ae64e">
      <Text>The </Text>
      <Text Style="AllCaps">director</Text>
      <Text> (60s, miserable) trudges in with a clipboard.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="aa28a90e-bf99-4d52-b018-04084efdf17a">
      <Text>DirECTOR</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="415f7adc-a591-4a57-aff8-71b9f0e76e2e">
      <Text>This here is the 2014 cast of </Text>
      <Text Style="Italic">Peter Pan</Text>
      <Text>. Let’s start naming ensemble...</Text>
    </Paragraph>
    <Paragraph Type="Action" id="5a59f5a1-ef14-4e45-bb26-e09372ed876a">
      <Text Style="AllCaps">Montage</Text>
      <Text> of name-reading. Most campers stand and cheer. Ray’s smile grows tighter with each role. Aurora turns to Ray.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="a0a873b4-fd1b-4c40-8ecf-d0813f9671e6">
      <Text>Aurora</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="752c5e17-1b3f-4e3f-9eef-99c9a087cb97">
      <Text>You’re getting that Peter Pan role.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="917d6ab5-0f55-4c50-b192-591c7a7413b3">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="ce9a4bd5-6221-478c-8e33-99c2062dcf5f">
      <Text>Funny, can’t say the sam- </Text>
      <Text Style="Italic">I mean ya would’ve made a fine pirate, </Text>
      <Text AdornmentStyle="-1" Style="Italic">matey</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="eb914b65-a0af-42d8-bbe2-188840c52dca">
      <Text>Aurora smirks at the camera and makes a hook with her hand.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="b1961e99-5d48-4b85-b7ed-74820a7061d9">
      <Text>Director</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="8931267b-bc2b-4bb1-ad34-b14a6836d2bc">
      <Text>And finally... soaring in as our lead, Peter Pan... </Text>
      <Text Style="Italic">try-nye </Text>
      <Text AdornmentStyle="-1" Style="Italic">ree</Text>
      <Text Style="Italic">-yes</Text>
      <Text>?</Text>
    </Paragraph>
    <Paragraph Type="Action" id="eba98bc7-3fcb-4ff4-8340-2410a247721a">
      <Text>Ray awkwardly grins at the camera then celebrates anyways.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="fd6bf935-db66-4765-96f3-b48e4600322c">
      <Text>AurorA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="19f617ac-075b-4356-be7c-f1f15e7f4ae6">
      <Text>It’s pronounced </Text>
      <Text Style="Italic">Trini Reyes</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="067d4b33-de88-4bbd-b080-0ed9f48cccf6">
      <Text>DirectOR</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="b995e906-82ee-487b-b053-5fee9208ccf6">
      <Text>Whatever. </Text>
      <Text AdornmentStyle="-1">Anywho</Text>
      <Text>, your “I’m Flying” audition landed you this role.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="df9bc129-cbea-4a87-b9eb-072726c9ddf7">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="122f9697-c62f-4679-bcda-29db3118d149">
      <Text AdornmentStyle="-1">Wuh</Text>
      <Text>- But I sang “I’ve </Text>
      <Text AdornmentStyle="-1">Gotta</Text>
      <Text> Crow”?</Text>
    </Paragraph>
    <Paragraph Type="Character" id="8e59cb6c-0407-41b8-b074-cf51820c4695">
      <Text>Director</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="594f9efc-4fb4-4435-ab23-ba3e2cc91d3b">
      <Text>No </Text>
      <Text AdornmentStyle="-1">needa</Text>
      <Text> be a sour croc, Aurora.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="12ed5a01-a032-49b8-be8f-2223398d676b">
      <Text>AuRORA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="43eb3990-ad32-496b-ad5c-6db0355ba610">
      <Text>I’m Aurora. She’s Ray.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="8cb23440-07e7-4599-b064-61dcf9aab760">
      <Text>Director</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="1d835912-f93c-4c5f-b816-2f3c8b55ec70">
      <Text>Oh neverlands- I musta gotten you two mixed up. Aurora, you’re Peter.</Text>
    </Paragraph>
    <Paragraph Type="Scene Heading" id="b8b02112-1ffe-4448-98ba-d6a66cc5fadf">
      <SceneProperties Length="4/8" Page="2" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="AURORA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="RAY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text Style="Bold+AllCaps">Ext. Theater Camp Amphitheater - MomENTS LATER</Text>
    </Paragraph>
    <Paragraph Type="Action" id="3397588d-ddd7-43a7-aadb-e367be078846">
      <Text>Behind Ray, the Director gives Aurora some notes.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="0e5e0b0f-7aa8-47a1-b6e1-74565b2d87fe">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="0f940b5e-e800-429c-a564-0ac0d25a430f">
      <Text>(to camera)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="c0714ef4-609e-4b73-bc52-28416e16fc06">
      <Text>I’ve been here for years and this codfish couldn’t remember my name? </Text>
      <Text Style="Italic">Aurora outshines me again</Text>
      <Text>. Well, guess I’ll be spending my last year selling concessions...</Text>
    </Paragraph>
    <Paragraph Type="Action" id="c3baaaf0-506a-4e50-8151-299076702d8d">
      <Text>Ray’s gloominess catches Aurora’s attention.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="c285a70e-3c8c-47b7-816d-24bb30df4340">
      <Text>Aurora</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="80405208-0be3-4544-9431-7e284ecff1a1">
      <Text>(to camera)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="462e2c62-e817-4ce4-89b2-a0b400e29cd3">
      <Text>Poor Ray. Whenever she is on stage, she is sunshine personified. </Text>
      <Text Style="Italic">Ooh</Text>
      <Text>, I’ve got an idea tinkering in me.</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="2a0714bb-8c2e-47e5-a8d3-e1cc22a1c056">
      <Text>(to Director)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="462e2c62-e817-4ce4-89b2-a0b400e29cd3">
      <Text>Director! As the leader of the Lost Boys, I got a concession of my own.</Text>
    </Paragraph>
    <Paragraph Type="Scene Heading" id="864571ec-4649-438f-8cb8-30e4ba8b6aa9">
      <SceneProperties Length="4/8" Page="2" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="AURORA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="RAY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text Style="Bold+AllCaps">Ext. Theater Camp - Evening</Text>
    </Paragraph>
    <Paragraph Type="Action" id="93e91741-c761-47f4-a726-1c7db362bda2">
      <Text>The sun sets behind the pines. Ray looks ready to throw a punch while Aurora looks ready to give a hug.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="78e78d1c-c97b-4511-8b3e-4c2eee1fd331">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="af1eca42-a6b3-43f9-b1d2-c96022d30ebb">
      <Text>...I’m your sidekick...?</Text>
    </Paragraph>
    <Paragraph Type="Character" id="915f7aed-aa79-45e4-99fb-f47988fb13fb">
      <Text>AuroRA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="cb32675a-86cf-4d15-963f-9ae94ea4bd97">
      <Text>The way I see it, I’m </Text>
      <Text Style="AllCaps">your</Text>
      <Text Size="10"> </Text>
      <Text>sidekick! You’re freaking Tinker Bell! A star-</Text>
    </Paragraph>
    <Paragraph Type="Character" id="bfb42c4a-99b0-415e-b69f-430482a78995">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="a7b4d619-fa1d-47b5-8769-c51b00238978">
      <Text>Where’s the crew member assigned to the laser pointers? And the Director is often set in their ways. How’d you pull this off?</Text>
    </Paragraph>
    <Paragraph Type="Character" id="51d90590-9456-4c26-8ae5-531f51a99a78">
      <Text>Aurora</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="ad42c210-e055-4224-8f9e-8d92141fb47d">
      <Text>Here’s a pointer: it helps to have a family who funds this camp. The Starlings always got Reyes’s back.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="7524b90b-354a-4381-a35f-196bc6216a83">
      <Text>Aurora hugs Ray while Ray looks menacingly at the camera.</Text>
    </Paragraph>
    <Paragraph Type="Scene Heading" id="4b71002c-43e1-4443-b8d8-73d0a3ca247c">
      <SceneProperties Length="1 6/8" Page="3" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="AURORA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="DIRECTOR">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="RAY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="TOOTLES THESPIAN">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="WENDY THESPIAN">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text Style="Bold+AllCaps">Int. Theater Camp Amphitheater - Night </Text>
    </Paragraph>
    <Paragraph Type="Action" id="5e738f18-e241-49b7-a95d-1789ba17b399">
      <Text>Most seats are empty as no one cares about theatre anymore. Kwan (12) sits front row, filming on a camcorder.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="91ba2a59-8d82-4552-83f2-0e03c1ca0e8b">
      <Text>On stage, the play is a train wreck. Most forgot their lines.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="91ba2a59-8d82-4552-83f2-0e03c1ca0e8b">
      <Text>Draped in black, Ray wanders about, holding a glowing orb. Aurora, as Peter Pan, is making pipes with a dull knife by a fake campfire. She’s distractingly theatrical.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="56cce6ee-be3e-47bb-9e40-e28a012c47a4">
      <Text>Tootles Thespian</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="d1202999-eb74-40a9-a48d-5bf1c5c65b1e">
      <Text>Am I in... uh.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="9cc4fe51-a770-4fcf-ac9b-fad42ab3128c">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="6435e480-4d93-4af7-89cd-483b81b1caa3">
      <Text Style="Italic">Story</Text>
      <Text>. Your line is “</Text>
      <Text Style="Italic">story</Text>
      <Text>.”</Text>
    </Paragraph>
    <Paragraph Type="Character" id="c95c01f6-9fa1-4e1e-a49c-885cf92f6031">
      <Text>TooTLES THESPIAN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="ebeca58d-9544-40bd-b8b4-2a3b7842de1c">
      <Text>Ah! Nibs, I am in a story.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="d945a558-3b52-44b0-bd38-abf65472884b">
      <Text>Aurora</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="d4e26a83-0be7-4a97-82e2-fcd8b8b10422">
      <Text>A little less-</Text>
    </Paragraph>
    <Paragraph Type="Character" id="ad6d787a-280a-4350-941a-9cc6bb87aedf">
      <Text>Wendy Thespian</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="99e5bd34-9e75-4071-b990-e4004b73ff80">
      <Text>Now I want you to consider the um-</Text>
    </Paragraph>
    <Paragraph Type="Action" id="56ad9caf-b011-42a5-8a3f-63cd326360ba">
      <Text>Ray lunges at Wendy, thrusting the glowing orb in her face.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="e992a0e5-5f89-4ec7-9dca-3d4868dfc841">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="85435596-e26b-4d1a-afb7-432d2c28547c">
      <Text>F-E-E-L-I-N-G. </Text>
      <Text Style="Italic">Feeling-</Text>
    </Paragraph>
    <Paragraph Type="Character" id="603f7a12-761e-4b5c-a094-c8a0580d5fea">
      <Text>WenDY THESPIAN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="3f85d755-551b-42ad-b673-f6fedf0b89f6">
      <Text>...</Text>
      <Text Style="Italic">feeling</Text>
      <Text> of the unhappy-</Text>
    </Paragraph>
    <Paragraph Type="Character" id="e8210bd8-ed76-4c51-907e-770a7cf8e6b7">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="98b1ab60-a8d9-4eff-9cb8-ee74ae73f9d6">
      <Text>(to camera)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="dd5bd1f4-b58d-446c-b5ca-4fbe8d81f124">
      <Text>You see anyone here put feelings in their performance? Be honest... Ya right! Everyone’s dead inside.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="01a47087-06b9-494e-81eb-98636cc4c8f2">
      <Text>The Director goes to the edge of the stage.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="9cb7ee6a-8bd8-4a73-960b-18e3b61415a9">
      <Text>Director</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="b411dc0a-dd6e-4f7c-aa21-dbc90087ebdf">
      <Text>No need to get all children’s program-y. It’s creepy. I suggest a little less improvisation here.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="478abf95-9030-41df-80f3-6a7affefe3b7">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="2819ef59-0895-4194-b85d-d9581c38c4dc">
      <Text>The line was “A little less noise there.” But Aurora missed her lines because Wendy here bulldozed it.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="4c34d6c5-282f-45dd-b5b7-49b64183ca6c">
      <Text>AurorA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="3c17fc44-9ff3-48d5-a0a2-99e59dc24c02">
      <Text>The only lost boy here is you.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="21e5b44d-f8ec-446a-b5dd-417290f83772">
      <Text>Director</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="7e260162-027d-419c-a87e-5945a81eecc2">
      <Text>Hey </Text>
      <Text AdornmentStyle="-1">hey</Text>
      <Text> Sweeney Todd and Mrs. Lovett, let’s settle this.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="4fab2f32-646d-4b66-9f53-5c2f264cd20d">
      <Text>Wendy pulls out their play booklet.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="9011ca7e-9954-46e4-9b6c-6f7758c0b2a3">
      <Text>WenDY THESPIAN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="be066fcf-7e3b-4b66-a2c7-62c42c4c5a94">
      <Text>I don’t remember those characters being in this play...</Text>
    </Paragraph>
    <Paragraph Type="Character" id="168adcf4-8b87-43b4-8e0a-d566de5c0d75">
      <Text>Director</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="970b6866-f3cc-46c9-a7b2-7955d991e442">
      <Text>Guys, dolls, just, um, uh-</Text>
    </Paragraph>
    <Paragraph Type="Character" id="4587219f-38c3-4763-b945-e37095917599">
      <Text>AurorA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="2efc2257-5fcb-41b0-b5b2-f8230b912a52">
      <Text>Don’t tinker with your role in this world, Ray.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="07b26b8c-57bc-4d1a-a670-6efbf8885f4d">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="dcf6e76b-fb6d-4e6a-996b-ac6be71ac6bf">
      <Text>I’m nobody’s sidekick. I’ll never ever be one to you, Aurora. This </Text>
      <Text Style="Italic">Peter Pan</Text>
      <Text> production is panned!</Text>
    </Paragraph>
    <Paragraph Type="Action" id="a5f5739c-0039-4200-8a0a-78dcd004b2d1">
      <Text>Ray violently tosses her orb prop into the fake fire set. It catches on real fire.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="a5f5739c-0039-4200-8a0a-78dcd004b2d1">
      <Text>Everyone panics while the Director sighs and sits back down.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="b300979d-1af9-403a-95e1-408a390e21f7">
      <Text>DireCTOR</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="62e26293-dfcf-4f73-9fe4-3b67e4da6c9b">
      <Text>Who cares? Don’t get paid enough.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="b3d74276-ce78-4c2d-a32a-cd93f4c0ae40">
      <Text>Aurora</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="fbf32321-052a-4842-97ab-06a536ff8d1d">
      <Text>(to camera)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="7dcd6610-11c4-47b9-9b1c-0eedf8b7d62d">
      <Text>Only you can prevent wild dramas!</Text>
    </Paragraph>
    <Paragraph Type="Action" id="18daa3d8-6d32-465b-9a18-ed8e27abbd91">
      <Text>Kwan looks through the camcorder, grinning. </Text>
    </Paragraph>
    <Paragraph Type="Action" id="18daa3d8-6d32-465b-9a18-ed8e27abbd91">
      <Text Style="Bold+AllCaps">On the camcorder monitor</Text>
      <Text>: Ray tries to stomp out the fire. She then blocks the camera.</Text>
    </Paragraph>
    <Paragraph Type="Transition" id="d0448a90-1f9f-44c4-8fcb-e98eee78b5f9">
      <Text>Cut to BLACK.</Text>
    </Paragraph>
    <Paragraph Alignment="Center" FirstIndent="0.00" Leading="Regular" LeftIndent="1.00" RightIndent="7.50" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="End of Act" id="8320508a-6b7a-43cd-9457-386c90d1a8a4">
      <Text>End of Cold Open</Text>
    </Paragraph>
    <Paragraph Type="Action" id="da01c2de-c79d-48e1-83a9-43aad66ad49e">
      <Text Style="Bold+AllCaps">Main Titles</Text>
    </Paragraph>
    <Paragraph Type="New Act" id="1b7e5dc9-80e1-45fb-9e46-269c17b41982">
      <Text>ACT One</Text>
    </Paragraph>
  </Content>


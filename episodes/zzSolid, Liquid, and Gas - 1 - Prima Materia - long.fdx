<?xml version="1.0" encoding="UTF-8" standalone="no" ?>
<FinalDraft DocumentType="Script" Template="No" Version="6">

  <DocumentRef DateTime="20250719T225100" id="311bf653-30ed-4d65-a49b-1d9bc7012bab">
    <XRef DateTime="20250719T224917" id="326d3bbb-277d-4966-b8b4-fc0c38660087"/>
  </DocumentRef>

  <Content>
    <Paragraph Type="New Act" id="6b67055e-8e0a-4c01-b26e-48bdef828a9a">
      <Text>Cold Open</Text>
    </Paragraph>
    <Paragraph Type="Scene Heading" id="f8e26f32-71ab-4cd7-b50d-e493d06a3ec6">
      <SceneProperties Length="1 6/8" Page="1" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="CLAY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="KIDS">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="RAY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="ROCKET">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="STARDUST">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text Style="Bold+AllCaps">Ext. </Text>
      <Text AdornmentStyle="-1" Style="Bold+AllCaps">Miniverse</Text>
    </Paragraph>
    <Paragraph Type="Action" id="49223ad7-68ea-4b39-873b-a0dae5ec67b7">
      <Text>The world is framed in a 4:3 aspect ratio. A decorative </Text>
      <Text Style="AllCaps">pop-up book</Text>
      <Text> titled </Text>
      <Text Style="AllCaps">Stardust Stuff</Text>
      <Text> cracks open. A ROCKET SHIP with a friendly, animated face pops out from the pages.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="c45f4abb-a0be-4f04-86aa-c562447efe90">
      <Text Style="AllCaps">Clay</Text>
      <Text> (24), radiating energy in a colorful cosmic vest, appears in the rocket’s window and waves enthusiastically.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="570a04a0-92a2-4143-ac11-5dff94016394">
      <Text>ClAY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="459eb441-6eeb-4e12-b6bb-29086e10f115">
      <Text>Planets, comets, and galaxies everywhere! It’s me, Clay! Have you seen our best friend, Stardust?</Text>
    </Paragraph>
    <Paragraph Type="Action" id="eeb237ab-df23-478f-b40a-69b2f90d3f09">
      <Text Style="AllCaps">Stardust</Text>
      <Text>, a whimsical, wide-eyed fairy, soars out from behind a cardboard star and loops around the ship.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="c68e5431-9051-4285-8437-7e5009cbbe94">
      <Text>Stardust</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="270a7ad3-49a1-4246-8068-21ae246ebaec">
      <Text>(Through yelps and whines)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="af782bb0-7bd6-4705-b26b-fb6a7ea6d1f5">
      <Text>Twinkle, twinkle, twinkle.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="fbf10ab5-16ce-4999-9bf6-bbeb3956e437">
      <Text>Unseen </Text>
      <Text Style="AllCaps">kids</Text>
      <Text> answer in unison along with </Text>
      <Text Style="AllCaps">Trini</Text>
      <Text Size="10"> </Text>
      <Text Style="AllCaps">“Ray”</Text>
      <Text Size="10"> </Text>
      <Text Style="AllCaps">Reyes</Text>
      <Text Size="10"> </Text>
      <Text>(4).</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" RightIndent="7.50" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="General" id="f2ec3210-f2bb-431c-b685-027d79f3fee4">
      <DualDialogue>
        <SpellCheckIgnoreLists>
          <IgnoredRanges/>
          <IgnoredWords/>
        </SpellCheckIgnoreLists>
        <Paragraph Type="Character" id="8046f8c3-c582-4d98-94ba-2b6f0788680c">
          <Text>Kids (V.O.)</Text>
        </Paragraph>
        <Paragraph Type="Dialogue" id="bd419307-8c3a-495d-8d23-47fe1d94104e">
          <Text>There she is!</Text>
        </Paragraph>
        <Paragraph Type="Character" id="5c292767-b3d1-4895-ad7b-08beb9253101">
          <Text>Ray (V.O.)</Text>
        </Paragraph>
        <Paragraph Type="Dialogue" id="a6eb9f70-ebda-4bee-bfd8-d3c965e23a5d">
          <Text>She’s right behind you!</Text>
        </Paragraph>
      </DualDialogue>
    </Paragraph>
    <Paragraph Type="Action" id="306c14ec-fd57-4917-b334-0b00fa3f9853">
      <Text>Clay ducks back inside.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="c7e30fa4-19fb-4176-b23c-1f541976e9cb">
      <Text>Rocket</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="7f69c111-1f12-43bb-9a7b-01821c8dced8">
      <Text>Come on in, </Text>
      <Text AdornmentStyle="-1">stardusters</Text>
      <Text>!</Text>
    </Paragraph>
    <Paragraph Type="Action" id="0a48a32b-7286-4758-b434-a9918d9bbf6c">
      <Text>The camera follows Stardust as she dives through the window. Inside, the ship is filled with charming cardboard controls. Clay searches the cabin.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="c24b2bc2-647e-4a6c-8b50-feb30797a913">
      <Text>ClAY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="b4025e30-8c2f-4767-b3fb-b2b1d867636e">
      <Text>Hi! We're so glad you're here! We’re almost ready to land. Stardust? Stardust?</Text>
    </Paragraph>
    <Paragraph Type="Action" id="edc1f33b-684c-4d29-ba4a-a3312d19cc73">
      <Text>Stardust giggles and ducks underneath a nearby table. Clay turns to the camera.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="3eaac186-a7fc-4177-95ab-4fa6607b04ec">
      <Text>Clay</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="37b17ab6-23ca-47b9-8a00-c2d1e753932d">
      <Text>Did you see Stardust?</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" RightIndent="7.50" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="General" id="e2d5f57a-9cf3-48e7-aa83-409f815cd6f9">
      <DualDialogue>
        <SpellCheckIgnoreLists>
          <IgnoredRanges/>
          <IgnoredWords/>
        </SpellCheckIgnoreLists>
        <Paragraph Type="Character" id="14f64058-99fd-44e1-bafc-088d0c6cf261">
          <Text>Kids (V.O.)</Text>
        </Paragraph>
        <Paragraph Type="Dialogue" id="f2486fa3-773e-47da-bc51-f16e6c756269">
          <Text>Right there! Under the table!</Text>
        </Paragraph>
        <Paragraph Type="Character" id="4cb41fbc-f344-4440-8e5c-09fd9555ad94">
          <Text>Ray (V.O.)</Text>
        </Paragraph>
        <Paragraph Type="Dialogue" id="68dcc84c-7368-418f-96aa-4ec96b20f8c9">
          <Text>Are you blind?!</Text>
        </Paragraph>
      </DualDialogue>
    </Paragraph>
    <Paragraph Type="Action" id="b9472d95-0254-4c2e-b755-8c63894c341b">
      <Text>Clay mimics hand-goggles, spotting her with a laugh.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="a1cfd922-cad6-4db0-9edb-4cc136656c0f">
      <Text>ClAY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="6c5f6b00-30c8-4b7a-b737-707b6d0b603d">
      <Text>Stardust! What world should we visit today?</Text>
    </Paragraph>
    <Paragraph Type="Action" id="c10cbf10-7f87-4a92-b611-b3bdfc215af6">
      <Text>Clay gestures to the window, where cutouts of a blue, white, and green planet hang against a dark backdrop.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="a02014ad-0594-4204-97d1-c2eaea491eed">
      <Text>Clay</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="17330476-6de2-445b-bba8-1e6967cecf23">
      <Text>A </Text>
      <Text Style="Italic+AllCaps">blue</Text>
      <Text> planet? A </Text>
      <Text Style="Italic+AllCaps">clue</Text>
      <Text> we need bathing suits. Do you have one?</Text>
    </Paragraph>
    <Paragraph Type="Action" id="202ccddf-9c8b-4f86-899a-e93fed6a87b1">
      <Text>Stardust shakes her head no.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="d712f87d-94a0-4049-9db2-56fa0ca06dfe">
      <Text>ClAY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="7fcef733-e346-40ba-9c14-859dbd9a5c0a">
      <Text>Should we land on the white planet? </Text>
      <Text AdornmentStyle="-1">Brrr</Text>
      <Text>! Do you have your winter coat?</Text>
    </Paragraph>
    <Paragraph Type="Action" id="8717af61-a8bf-4aac-a3b6-6b50d2f058c9">
      <Text>Stardust shakes her head no. Clay points to the final world.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="334014ba-b16b-43be-b55b-d657d4f1dcc2">
      <Text>Clay</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="1e6b95de-ee4a-4b0c-8d24-ce88a79213e3">
      <Text>Then what color is this one?</Text>
    </Paragraph>
    <Paragraph Type="Character" id="db339cf5-59cd-4e29-99a4-4750b717b48d">
      <Text>KiDS (V.O.)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="bbe65638-8786-4b30-a553-e6583df866a6">
      <Text>Green!</Text>
    </Paragraph>
    <Paragraph Type="Character" id="205e3e77-c37b-4243-9347-0a76d9160c3e">
      <Text>ClAY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="0bc952a4-17e5-43ad-9025-dd8742ce75e5">
      <Text>Yellow?</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" RightIndent="7.50" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="General" id="3c4666c3-5b6f-4f95-a7fa-b2cf065ff328">
      <DualDialogue>
        <SpellCheckIgnoreLists>
          <IgnoredRanges/>
          <IgnoredWords/>
        </SpellCheckIgnoreLists>
        <Paragraph Type="Character" id="2aa98dfb-5a67-4e02-86ce-ba39014638e6">
          <Text>Ray (V.O.)</Text>
        </Paragraph>
        <Paragraph Type="Dialogue" id="729eaf10-e9e0-4478-93ef-6b27de66fb84">
          <Text Style="AllCaps">Green for crying out loud!</Text>
        </Paragraph>
        <Paragraph Type="Character" id="1ed3ffb0-1649-4fa1-a9c2-f2c015a7a7ec">
          <Text>KiDS (V.O.)</Text>
        </Paragraph>
        <Paragraph Type="Dialogue" id="01b66072-730f-46b9-9c20-f68a75b69fae">
          <Text Style="AllCaps">Green! Green! Green!</Text>
        </Paragraph>
      </DualDialogue>
    </Paragraph>
    <Paragraph Type="Character" id="3aa1f8cc-f486-4b71-aed2-745cb8a413be">
      <Text>ClaY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="1e6b95de-ee4a-4b0c-8d24-ce88a79213e3">
      <Text>Ah! The </Text>
      <Text Style="AllCaps">green</Text>
      <Text> planet! Do you have your sunglasses?</Text>
    </Paragraph>
    <Paragraph Type="Action" id="afe3a7a8-311e-45ff-b057-0e54c1ebd3aa">
      <Text>Stardust puts on a pair of shades.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="b651c3a1-ce61-4db3-a473-41b010a4a756">
      <Text>Clay breaks into a catchy jingle.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="8348cd99-c1d8-4d14-b32b-8de53f05bcf9">
      <Text>ClaY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="136d6097-bf7b-4795-96a8-3676dbb1bfb8">
      <Text>Rocket, take us to the </Text>
      <Text Style="AllCaps">green</Text>
      <Text>!</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="ed93f298-3f0f-4f72-9c61-4111ad756278">
      <Text Style="AllCaps">Let’s land on this planet</Text>
    </Paragraph>
    <Paragraph Type="Scene Heading" id="864571ec-4649-438f-8cb8-30e4ba8b6aa9">
      <SceneProperties Length="2 1/8" Page="2" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="CLAY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="CLAY &amp; RAY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="CLAY &amp; RAY &amp; KWAN">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="KWAN &amp; KIDS">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="RAY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="STARDUST">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text Style="Bold+AllCaps">Int. Reyes Living Room - Day (2001)</Text>
    </Paragraph>
    <Paragraph Type="Action" id="d3f18c5c-59a0-4800-a10e-8cb82beea391">
      <Text>A square TV plays the show. Ray</Text>
      <Text Size="10"> </Text>
      <Text>(4,</Text>
      <Text Size="10"> </Text>
      <Text>Filipina</Text>
      <Text Size="10"> </Text>
      <Text>American) dances along, in her homemade </Text>
      <Text Style="AllCaps">cardboard rocket ship</Text>
      <Text> </Text>
      <Text Style="AllCaps">costume</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="c7c940f6-d617-4188-9383-808824d35e4f">
      <Text>Clay &amp; Ray</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="1cabf305-76c1-4ed4-9459-701592f22848">
      <Text Style="AllCaps">Let’s land on this planet
I wonder if we’ll call it home?</Text>
    </Paragraph>
    <Paragraph Type="Action" id="d62c3c1b-1e34-4635-9255-1a4d23631325">
      <Text>Much like Clay, Ray turns to face her own “camera.”</Text>
    </Paragraph>
    <Paragraph Type="Action" id="901cbd61-f802-4f35-95e9-6c5e3cff618f">
      <Text Style="Bold+Underline+AllCaps">Ray talking head</Text>
    </Paragraph>
    <Paragraph Type="Character" id="e96a517a-6c7f-4030-b4f0-78eabd8e86d2">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="4468467e-fcf8-405d-bf11-3f46b1746db3">
      <Text>You my audience! </Text>
      <Text AdornmentStyle="-1" Style="Italic">Pwease</Text>
      <Text Style="Italic"> </Text>
      <Text AdornmentStyle="-1" Style="Italic">pwetend</Text>
      <Text>. I Trini </Text>
      <Text Style="Italic">Reyes</Text>
      <Text>, I wanna be Clay. Good news today, we on solid </Text>
      <Text AdornmentStyle="-1">gwound</Text>
      <Text>! So the floor ain’t...?</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="aa0a973a-6ca1-416e-8f2b-656b6fb7999c">
      <Text>(Pause)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="9f7b3368-31ea-4538-951f-215ba3fb9f46">
      <Text>Lava! Lava! Lava!</Text>
    </Paragraph>
    <Paragraph Type="Action" id="c7e7f514-878c-4a6e-af2c-2bdc4fe9c6a0">
      <Text>On the table, a </Text>
      <Text Style="Italic">Stardust Stuff</Text>
      <Text> coloring book lies open. Inside, a child’s messy coloring fills a page featuring Clay and the show’s founders: 
- </Text>
      <Text Style="AllCaps">River Matthews</Text>
      <Text> (25, Ms. Frizzle-like) with Stardust puppet.
- </Text>
      <Text Style="AllCaps">Schuyler “Skye” Park</Text>
      <Text> (26, Korean, in over their head).</Text>
    </Paragraph>
    <Paragraph Type="Character" id="d195e840-eb6d-425f-a91a-5a8eec70b1a0">
      <Text>Ray (O.S.)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="4468467e-fcf8-405d-bf11-3f46b1746db3">
      <Text>It so fun talkin’ to thin air!</Text>
    </Paragraph>
    <Paragraph Type="Action" id="473dc14c-b5f2-42d1-a0e7-4ac47ea661c5">
      <Text Style="Bold+AllCaps">Montage - Five Years Later</Text>
    </Paragraph>
    <Paragraph Type="Action" id="e1d326e7-0cb3-4a21-8059-8af66c620b31">
      <Text Style="Bold">2002</Text>
    </Paragraph>
    <Paragraph Type="Action" id="969f8d5c-219f-40f9-830c-e2af0c7a9861">
      <Text>Rain hits the window. Ray (5) sits in the dark, out of her costume. She glances at the camera.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="48eaf312-bbf0-4a23-8101-4970eb226c48">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="6f3e4bcf-5500-4f67-8b1f-1d4627626d10">
      <Text>It can also be lonely...</Text>
    </Paragraph>
    <Paragraph Type="Action" id="969f8d5c-219f-40f9-830c-e2af0c7a9861">
      <Text>On the TV, Clay and Stardust drift in a black hole.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="46af8ae9-1b03-4fb1-8e5b-ea06088046d1">
      <Text>Stardust</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="bd2e39da-4499-44bf-ae34-411d5a0db280">
      <Text>Twinkle, twinkle, twinkle!</Text>
    </Paragraph>
    <Paragraph Type="Character" id="e7942eea-d7fb-4829-b249-355e53a56913">
      <Text>Clay</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="ede10c2c-76d6-40c4-a8f6-3bfddd873595">
      <Text>Don't be scared! The darker it is, the more glitter we can see!</Text>
    </Paragraph>
    <Paragraph Type="Action" id="7154dbc1-a968-4bed-a576-6f1be0f4d5dd">
      <Text>Reassured, Ray pulls her glittery rocket costume back on.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="621c49a0-f242-44ab-8b5c-cc9350182e30">
      <Text>Clay</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="a7198d91-4695-4207-afc9-1ca5a549ec0f">
      <Text>You are not alone!</Text>
    </Paragraph>
    <Paragraph Type="Action" id="11c4f04b-164d-4ac5-9fe9-3af43f2ecd97">
      <Text Style="Bold">2003</Text>
    </Paragraph>
    <Paragraph Type="Action" id="693045a6-1dee-4aac-987c-df18374906e5">
      <Text>Ray’s baby brother, </Text>
      <Text Style="AllCaps">Kwan</Text>
      <Text>, crawls towards the TV screen. Ray (6) sits him down and crowns him an astronaut helmet.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="7e40c4d9-273d-43de-8aed-947da7315a9a">
      <Text>On the TV, Clay shows Stardust how to moonwalk. In the room, Ray helps Kwan take his first steps. He falls face first.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="f250beb9-7fdd-4eb5-ae7a-99d45da85804">
      <Text>ClAY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="35dcdb54-86b3-4f1a-977a-020c0cf42510">
      <Text>Gravity is when the world gives us a hug!</Text>
    </Paragraph>
    <Paragraph Type="Action" id="bca6afec-b262-47ba-ba63-28a822cd768f">
      <Text Style="Bold">2004</Text>
    </Paragraph>
    <Paragraph Type="Action" id="c69df17c-25d1-4dfd-96fd-2c6061d1eceb">
      <Text>On the TV, Clay and Stardust sled across an icy comet. They pull out smoothies.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="ec74fc00-1741-4910-9646-127d7834a4fa">
      <Text>Clay</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="af464c30-ff8e-4c5f-9834-3e0b814dadaf">
      <Text>It’s not just a rock, </Text>
      <Text AdornmentStyle="-1">stardusters</Text>
      <Text>. We’re sledding on a smoothie comet! Made of water, ice, </Text>
      <Text Style="Italic">dust</Text>
      <Text>, and sugar-</Text>
    </Paragraph>
    <Paragraph Type="Action" id="a534d806-ace4-41da-b6b7-0d7aaceda9ee">
      <Text>Ray (7) and Kwan (2) share a smoothie before wincing hard.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" RightIndent="7.50" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="General" id="88a172b8-f536-4e0a-8685-2044d04e3824">
      <DualDialogue>
        <SpellCheckIgnoreLists>
          <IgnoredRanges/>
          <IgnoredWords/>
        </SpellCheckIgnoreLists>
        <Paragraph Type="Character" id="1377fe92-b8a2-40e2-9fba-462e3177195a">
          <Text>Clay &amp; Ray &amp; Kwan</Text>
        </Paragraph>
        <Paragraph Type="Dialogue" id="052a6507-bb2b-42d7-bffc-6ad1097e3f46">
          <Text>Brain freeze!</Text>
        </Paragraph>
        <Paragraph Type="Character" id="491d5351-e082-4a7f-92fc-ecd3520e4aa1">
          <Text>Stardust</Text>
        </Paragraph>
        <Paragraph Type="Dialogue" id="ca90dfb4-5ca5-42cc-b94b-d6f929e537a0">
          <Text>Twinkle, twinkle, twinkle!</Text>
        </Paragraph>
      </DualDialogue>
    </Paragraph>
    <Paragraph Type="Action" id="105744d0-1caf-4649-891e-6445cc5e6419">
      <Text Style="Bold">2005</Text>
    </Paragraph>
    <Paragraph Type="Action" id="99626ded-4fed-47b8-9767-9213a3c8606a">
      <Text>Ray (8) performs a sock puppet show for Kwan (3) using puppets she made to look like Clay and Stardust. In the background, the real show plays on the TV.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="ace7d802-c516-4728-8bf2-283673d81746">
      <Text>ClAY (o.S.)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="a2c5e6f5-80e7-44f0-bd2b-99eed0f554fc">
      <Text>What keeps our feet warm?</Text>
    </Paragraph>
    <Paragraph Type="Character" id="a3671417-0ea8-4585-b997-05f80d7cac52">
      <Text>Kwan &amp; Kids (O.S.)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="edc760da-a434-42ce-b985-e98168e9550c">
      <Text>Socks!</Text>
    </Paragraph>
    <Paragraph Type="Character" id="eafe5333-24af-47b9-b34b-762c1a9b6005">
      <Text>Clay (O.S.)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="3b5a1396-c024-463d-9220-9ad25cef1038">
      <Text>Gloves?</Text>
    </Paragraph>
    <Paragraph Type="Character" id="acddfaad-a829-4055-8b8a-b9bca8d45b6f">
      <Text>Kwan &amp; Kids (O.S.)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="16e9f1ee-47e4-401a-b80b-f975208bfe5a">
      <Text>Socks! Socks! Socks!</Text>
    </Paragraph>
    <Paragraph Type="Character" id="cd8b822d-f601-4e15-a073-decaf7ea56ef">
      <Text>ClAY (O.S.)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="efca0572-259c-46f6-93dd-fe32ba4f6b34">
      <Text>We’ve been on rocky planets, but have we ever visited a </Text>
      <Text AdornmentStyle="-1">socky</Text>
      <Text> one?</Text>
    </Paragraph>
    <Paragraph Type="Character" id="88757235-aaee-4575-b201-71f20f9779fe">
      <Text>StarDUST (O.S.)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="54270937-3580-4631-be6c-49da85570a20">
      <Text>Twinkle, twinkle, twinkle!</Text>
    </Paragraph>
    <Paragraph Type="Action" id="ba39c6a6-c3da-4535-8be2-67a9dd0ced96">
      <Text>Ray takes a bow for her brother. Ray clocks the camera.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="bcaa8ec8-db86-4fe9-b6c0-ed0fb336c967">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="a3b554f8-cfd3-4c36-bc5f-18cbed70ddeb">
      <Text>Thanks for being my captive audience. You did me a solid, bruh.</Text>
    </Paragraph>
    <Paragraph Type="Scene Heading" id="f8e26f32-71ab-4cd7-b50d-e493d06a3ec6">
      <SceneProperties Length="1 4/8" Page="4" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="CLAY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="KIDS">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="KIDS &amp; KWAN">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="KWAN">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="RAY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="STARDUST">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text Style="Bold+AllCaps">Int. Reyes Living Room - Day (2006)</Text>
    </Paragraph>
    <Paragraph Type="Action" id="029619e5-77c7-4c12-933a-246589e1b67c">
      <Text>Ray (9) has passed her cardboard rocket down to Kwan (4). She sits on the sofa behind him, focused on her rehearsal booklet for </Text>
      <Text Style="Italic">A Christmas Carol</Text>
      <Text>, scribbling notes.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="08dd4788-a66d-441d-b997-9c90e6e2a594">
      <Text>On the TV, Clay (29) and Stardust sit on a tinfoil moon. Clay offers a bittersweet smile to the camera.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="9b6ecd6e-8695-4f00-82bf-6963ff445781">
      <Text>Clay</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="4452a36f-5db0-4f1c-9332-174f7f9c434e">
      <Text>When liquid becomes a gas, it doesn't go away. It just spreads out. It goes everywhere, like I am.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="c68e5431-9051-4285-8437-7e5009cbbe94">
      <Text>Stardust</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="eede606f-eb13-42d8-977d-349411e81858">
      <Text>Twinkle, twinkle, twinkle...</Text>
    </Paragraph>
    <Paragraph Type="Character" id="f7106e8c-d401-4c33-9476-ec6980dd7b21">
      <Text>ClAY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="70713475-f2c1-4cb1-9502-46180b26eef8">
      <Text>‘specially behind the stars...</Text>
    </Paragraph>
    <Paragraph Type="Character" id="46ae151a-252d-46c8-abca-f9ece2c87e38">
      <Text>Kids (V.O.)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="3a46ccb1-e22c-477f-8209-d2f85583156b">
      <Text>Aww...</Text>
    </Paragraph>
    <Paragraph Type="Action" id="425df47e-56eb-4ae7-bcab-835a9086cc10">
      <Text>Ray looks up, annoyed that Kwan is blocking her view.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="90df1eb4-15f5-4926-9bbb-dbf13e2229cd">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="abc99818-0e7a-4cdd-bad6-2a825b061240">
      <Text>Bruh. You wanna go blind?</Text>
    </Paragraph>
    <Paragraph Type="Character" id="7a3c00a5-1303-4d2d-95a6-d38e96f683ba">
      <Text>Kwan</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="2a7ee6c2-47b6-43d9-89ec-bba1fd509465">
      <Text>Like you’ll be, Tiny Trini?</Text>
    </Paragraph>
    <Paragraph Type="Character" id="db27cda8-18ec-46b6-830f-455720672db4">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="6bb0cd99-2e48-426b-940e-6a903a61d20c">
      <Text Style="Italic">Tiny Tim</Text>
      <Text> isn’t blind... Kwan, sit further away from the TV.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="01212214-c653-422d-86de-ada48b2b8e2b">
      <Text>ClAY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="f330da80-a1c8-484c-ac8f-d7680913432e">
      <Text>It’s time to say goodbye...</Text>
    </Paragraph>
    <Paragraph Type="Character" id="71f3ee54-f6ef-415d-8335-b2deecf8f532">
      <Text>KWAN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="0506f4f5-4c9f-4da8-a2ca-5191817b6f00">
      <Text>Clay is saying goodbye...</Text>
    </Paragraph>
    <Paragraph Type="Character" id="f09071d5-19dc-45ce-ba3e-37ab262a477a">
      <Text>RAY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="3ba354e2-3b20-447f-a797-f4f08e6238e8">
      <Text>Then say it back, Kwan.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="d607c104-be1f-47d4-a5b5-f06832f64bc7">
      <Text>Kids &amp; Kwan</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="bfd5b90e-7288-4335-beef-5d6296cfe274">
      <Text>Goodbye...</Text>
    </Paragraph>
    <Paragraph Type="Action" id="06742e5a-b2f7-4513-9d75-b6e8eb034910">
      <Text>The whimsical music fades into a single, lonely note.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="0cc02f09-57e1-4c9f-badf-ff99a55192ef">
      <Text>CLAY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="d4b58cf0-7936-46db-a41a-098c66f2cc31">
      <Text>I must go home now. But you? You’re already home. Keep looking up because stars are us...</Text>
    </Paragraph>
    <Paragraph Type="Action" id="be2969ca-3261-401a-afb9-63d719d2787e">
      <Text>Clay boards Rocket. The ship blasts off into the cosmos. Stardust pulses with a final spark and vanishes.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="8d23f68b-c7d7-4dcf-9bb8-61142c2059a5">
      <Text>The screen fades to black. The text appears: “Clay Goes Home.” A final production still of the team and studio follows: “Thank you for 7 years of </Text>
      <Text Style="Italic">Stardust Stuff</Text>
      <Text>.”</Text>
    </Paragraph>
    <Paragraph Type="Action" id="9c92b40e-fdde-4527-98ab-2f80d5ff57bd">
      <Text>Ray drops her pen, finally giving the TV</Text>
      <Text Size="10"> </Text>
      <Text>her</Text>
      <Text Size="10"> </Text>
      <Text>full</Text>
      <Text Size="10"> </Text>
      <Text>attention.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="c7a5d551-16e2-49aa-95d9-5178a53e654e">
      <Text>RAY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="84c32215-8252-4b01-aad1-1b7e505884f9">
      <Text AdornmentStyle="-1">Wuh</Text>
      <Text>-No “See ya later, </Text>
      <Text AdornmentStyle="-1">stardusters</Text>
      <Text>?”</Text>
    </Paragraph>
    <Paragraph Type="Action" id="ab0e784a-e211-4428-866f-aeb5417346ac">
      <Text>Ray joins Kwan at the TV. A reflection of two small kids stare back in the glass. She looks down at her pen.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" RightIndent="7.50" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="General" id="8040202a-a476-4a83-a2be-88ac2b841c85">
      <DualDialogue>
        <SpellCheckIgnoreLists>
          <IgnoredRanges/>
          <IgnoredWords/>
        </SpellCheckIgnoreLists>
        <Paragraph Type="Character" id="b325a6d1-31cf-4249-ad07-741ebbf3a253">
          <Text>Kwan</Text>
        </Paragraph>
        <Paragraph Type="Dialogue" id="7f75a458-cf9d-4aec-ba25-500ecf225665">
          <Text>Goodbye Clay...</Text>
        </Paragraph>
        <Paragraph Type="Character" id="55a9980a-5f0b-4170-829f-e7ff88d1830f">
          <Text>RAY</Text>
        </Paragraph>
        <Paragraph Type="Dialogue" id="4e4f110f-4dde-41fb-b5e6-798a9e036528">
          <Text>Hello Ray...</Text>
        </Paragraph>
      </DualDialogue>
    </Paragraph>
    <Paragraph Type="Action" id="39a9027c-28de-4bd6-8a62-7480d117dd9d">
      <Text>With sudden purpose, she opens the checkout card inside her booklet and crosses out “Trini Reyes.” In its place, she writes </Text>
      <Text Style="AllCaps">Ray</Text>
      <Text> in bold letters. She holds it up to the camera.</Text>
    </Paragraph>
    <Paragraph Type="Transition" id="952f419d-0561-4a75-b97b-b0e347eda6f8">
      <Text>Match cut to:</Text>
    </Paragraph>
    <Paragraph Type="Scene Heading" id="4f702085-15ca-4569-92c3-050b42f17b3e">
      <SceneProperties Length="4/8" Page="6" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="RAY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="STAGE MANAGER">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text Style="Bold+AllCaps">Int. Theatre Backstage - Night (2025)</Text>
    </Paragraph>
    <Paragraph Type="Action" id="7d5f8cc6-9fc7-4b38-b205-97a239d48a4b">
      <Text>A </Text>
      <Text Style="AllCaps">clipboard</Text>
      <Text> displays the cast list for </Text>
      <Text Style="Italic">Cat Scouts Live 2025</Text>
      <Text>. A pen slides down to Trini “Ray” Reyes and checks</Text>
      <Text Size="10"> </Text>
      <Text>a</Text>
      <Text Size="10"> </Text>
      <Text>box:</Text>
      <Text Size="10"> </Text>
      <Text Style="AllCaps">late</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="87c04828-07db-4314-a802-a0638c8ce150">
      <Text>Ray (29) bursts in, breathless and disheveled.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="ab6af4ed-8bab-433c-b3d1-75ef4166c40b">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="cd8bb3fb-393a-446f-bde9-78baa2ad390d">
      <Text>Sorry, sorry, sorry!</Text>
    </Paragraph>
    <Paragraph Type="Character" id="40ef861f-a352-49e8-a52b-e1723ec274f7">
      <Text>Stage Manager</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="6cc3c510-22d2-4e02-a336-0eab6df1f039">
      <Text>Sorry won’t cut it, even if we’re touring Canada. Try not to lose your head, okay?</Text>
    </Paragraph>
    <Paragraph Type="Action" id="901cbd61-f802-4f35-95e9-6c5e3cff618f">
      <Text Style="Bold+Underline+AllCaps">Ray talking head</Text>
    </Paragraph>
    <Paragraph Type="Character" id="b17efa04-eee4-42c7-8c3a-67d143150999">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="cbbe52b0-e64b-4ff8-9f89-7ddec186ae27">
      <Text>I’ve lost my mind the moment I took my first steps on a theatre stage. What I had to gain was my heart... </Text>
    </Paragraph>
    <Paragraph Type="Scene Heading" id="530f2e93-1552-4378-9fc1-77c9c72b382d">
      <SceneProperties Length="4/8" Page="6" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="PUPPETEER">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="RAY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text Style="Bold+AllCaps">Int. Puppet Room - MoMENTS LATER</Text>
    </Paragraph>
    <Paragraph Type="Action" id="3fca83ce-7a0d-457f-a9bf-04bccb222330">
      <Text>A </Text>
      <Text Style="AllCaps">cat scout puppet</Text>
      <Text> sits on a workbench with its head severed from its uniformed body. Ray stares at it, devastated.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="dc7ae7b2-de63-46ee-8eaf-efbcca07cf85">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="a6d5d42e-dcac-4ce9-bb97-6ffbce84f6c5">
      <Text>...and a rough life...</Text>
    </Paragraph>
    <Paragraph Type="Action" id="1a1e7a26-a322-4e0f-a769-741375d98aa6">
      <Text>A </Text>
      <Text Style="AllCaps">puppeteer</Text>
      <Text> in a “Cat Scouts” hoodie inspects the damaged foam, turning it over before shrugging.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="10fed7cf-5a4b-43b7-ad79-119fc2e0a112">
      <Text>Puppeteer</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="427a6dbe-41fe-4e37-99eb-6714dac1a66e">
      <Text>Ruff? More like </Text>
      <Text Style="Italic">meow</Text>
      <Text>. Don’t ya worry. Ya got eight lives to spare.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="23f7285b-6a97-4828-82a9-832b3a9b9934">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="d6df7e33-c086-468e-ab78-d36c868fec25">
      <Text>We got replacements?</Text>
    </Paragraph>
    <Paragraph Type="Character" id="a900cc24-1744-4614-b304-87b0bca4811a">
      <Text>PuPPETEER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="5f9d5fac-53c2-43e0-bd64-99ea1d4aa725">
      <Text>This is a touring production. There ain’t a budget for replacements.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="c51ac47d-11f5-4736-8b97-66bf2518aa3f">
      <Text>The puppeteer grabs a bottle of glue that reads: </Text>
      <Text Style="AllCaps">flammable</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Scene Heading" id="86da0d4c-8d37-418e-a621-cfff83080134">
      <SceneProperties Length="1 4/8" Page="7" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="PERFORMER">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="PRODUCER">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="RAY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="STAGE MANAGER">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text Style="Bold+AllCaps">Int. Theatre Stage - Later</Text>
    </Paragraph>
    <Paragraph Type="Action" id="7bfb842a-1fb5-4597-a0bb-5a2809a385e1">
      <Text>Tech rehearsal is a mess. The harsh lights expose the plywood of a half-finished forest set.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="5e8f6238-cd9d-4781-b759-1e72525ce14b">
      <Text>Ray stands with the other </Text>
      <Text Style="AllCaps">puppeteers</Text>
      <Text>, dressed in a black stage suit. She holds her cat scout; the head is glued back on, but it looks more like a trauma patient than a scout.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="b146a400-2afc-4672-bed3-2fc9d990e2af">
      <Text>Stage Manager</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="31318360-09cf-406e-a909-ba4f304398e2">
      <Text>Final tech run before doors. From the top of the “Meow-</Text>
      <Text AdornmentStyle="-1">tain</Text>
      <Text>” song. Ray, keep that head steady.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="b7015c32-1607-41cb-819a-7eddd4f21aba">
      <Text>Upbeat music track blares. Ray clumsily dances. As she twirls, centrifugal force pulls at the fresh glue.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="2a97ef95-c7d9-40a8-8379-c1beaba9f0bb">
      <Text Style="AllCaps">Creak</Text>
      <Text>. The glue snaps. Ray lunges for the head, but it's too late as it launches across the stage, landing on a spotlight.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="5ab51c09-b4ea-4db3-9b3e-69768a91120a">
      <Text Style="AllCaps">Hiss</Text>
      <Text>. </Text>
      <Text Style="AllCaps">Sparks</Text>
      <Text>. The head transforms into a fireball. It rolls into the Colonel Calico puppet, which also goes up in flames.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="9fd7bef9-fffd-4060-860c-0307e2bb2d68">
      <Text>Performer</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="7857d215-5978-45ad-8eb5-2a5a08f69590">
      <Text>Fire! Colonel Calico is a fireball!</Text>
    </Paragraph>
    <Paragraph Type="Action" id="e5290208-ec93-4eaa-9888-5c76fb56325e">
      <Text>Ray grabs a fire extinguisher, shaking it with theatrics.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="cc4ca3f8-d881-41c5-9923-76b9ebeda78e">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="5c478f38-d748-468e-a9b3-ca222d3ab138">
      <Text>This is when the Cat Scouts become the Cat Firefighters!</Text>
    </Paragraph>
    <Paragraph Type="Action" id="53a82609-9ccd-4e88-9534-bea0fbfbe97a">
      <Text>She blasts the calico puppet, but the pressure sends its flaming head flying into a puppet rack, engulfing everything.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="defcdc42-a9a4-4dda-ad31-36d274e83ef6">
      <Text>Performer</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="bedc986c-4fab-4d81-9ba7-92ae8ba7e773">
      <Text>Please, not Sergeant Siamese!</Text>
    </Paragraph>
    <Paragraph Type="Character" id="2ed0b007-171c-499a-bcaf-d1870500da58">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="16fff356-69ef-4e25-bbc9-c3fe75fb6d20">
      <Text>The Siamese cats always rubbed me the wrong way...</Text>
    </Paragraph>
    <Paragraph Type="Action" id="2855296c-24c9-4a1a-b846-da780896e135">
      <Text>The fire reaches the curtains, tripping a sensor. Sprinklers roar to life, slamming the stage with water. In seconds, the fire is out, but the puppets are floating charred lumps.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="93bea314-f11b-472e-b33c-b202453e9ab3">
      <Text>Drenched and holding her decapitated puppet, Ray looks up at the stage manager, who now holds an umbrella.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="8f13173c-4d22-4872-a8f4-8f318467f437">
      <Text>RAY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="a8e51c7c-bc74-45a7-9c4a-779f0b2f679c">
      <Text>Look on the bright side: fire’s out-</Text>
    </Paragraph>
    <Paragraph Type="Action" id="072b38ed-bf71-4d9c-a79a-6ab177d970e1">
      <Text>The music cuts out as the </Text>
      <Text Style="AllCaps">producer</Text>
      <Text> joins the stage manager.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="89e588a0-a204-419d-b94b-d32fb1ab635c">
      <Text>STAGE MANAGER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="fc9d0bc4-30dc-47d5-92ad-fef65993362f">
      <Text>Only you. Only you could kill nine lives in </Text>
      <Text Style="Italic">one fell swoop</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="b96794d0-e840-4aa1-9774-e23887baf6eb">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="e06a2c9a-ed56-429b-9a26-ec39ac0a569f">
      <Text>I see you quoting </Text>
      <Text Style="Italic">Macbeth</Text>
      <Text>...</Text>
    </Paragraph>
    <Paragraph Type="Character" id="0a2bd3eb-6889-419b-a9d6-2d262af43775">
      <Text>ProdUCER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="1b9b7909-d19c-44cc-a8b9-3476547d6ba6">
      <Text>We may not budget for replacement puppets. But you are the exception.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="5308addc-e643-4821-a1de-f6de3c6cb571">
      <Text>StagE MANAGER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="27d07d32-5b56-473a-9815-e835d187ac24">
      <Text>We should’ve hired Aurora, not Ray-</Text>
    </Paragraph>
    <Paragraph Type="Character" id="7d79b908-4678-4162-a6fb-0bcf4f4d7f9d">
      <Text>ProDUCER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="1b9b7909-d19c-44cc-a8b9-3476547d6ba6">
      <Text>Trini Reyes, for such a fire, you are-</Text>
    </Paragraph>
    <Paragraph Type="Character" id="5de28f1d-4ee9-48f7-b031-600a33244305">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="6e0f1441-aab4-462f-b67e-64aad5bc2816">
      <Text>Recycled?</Text>
    </Paragraph>
    <Paragraph Type="Action" id="0cf1188e-befe-4242-9743-51523eda437d">
      <Text>Ray gives a worried look to the camera.</Text>
    </Paragraph>
    <Paragraph Alignment="Center" FirstIndent="0.00" Leading="Regular" LeftIndent="1.00" RightIndent="7.50" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="End of Act" id="8320508a-6b7a-43cd-9457-386c90d1a8a4">
      <Text>End of Cold Open</Text>
    </Paragraph>
    <Paragraph Type="Action" id="e7d4a034-ce3c-4897-b63b-991f7dd19c3b">
      <Text Style="AllCaps">Begin Main Titles</Text>
    </Paragraph>
    <Paragraph Type="Action" id="1a28fe51-38f0-4a48-b283-3a03a5ed2811">
      <Text>“Just a Phase” sung by River Matthews plays.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="1a28fe51-38f0-4a48-b283-3a03a5ed2811">
      <Text>Montage:</Text>
    </Paragraph>
    <Paragraph Type="Action" id="8c2fa7ef-19b1-48ca-bbea-4f48bbedd059">
      <Text>- Ray (29) and Kwan (24) board a cardboard rocket ship and blast off into a cardboard cosmos.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="4a691660-4582-43c0-a202-1611a3cefd9e">
      <Text>- </Text>
      <Text Style="AllCaps">Ms. Aurora Starling</Text>
      <Text> (29, Biracial, perfect) glides past them, looking flawless in a pristine cardboard spacesuit.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="603f2c17-7b69-40cd-bddc-a097db4cd1f5">
      <Text>- Ray and Kwan’s rocket crash lands on a strange world.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="006659d1-bbed-480c-a51e-319403d1528a">
      <Text>- On this new world, Clay (46) appears, dancing with the Stardust puppet. River Matthews (50) is revealed as the puppeteer, while Skye Park (51) joins them, surrounded by many cosmic characters. They wave directly to the audience.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="62db2a78-ea2f-4c09-a492-4854f26afbcf">
      <Text>- The camera zooms out to reveal the previous scene is playing on a square TV. Ray and Kwan are perched on top of this TV, posing with their own Stardust-inspired puppets.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="4e78583b-4417-485e-a677-f3ffb92564ac">
      <Text Style="AllCaps">End Main Titles</Text>
    </Paragraph>
    <Paragraph Type="New Act" id="c74f8479-2577-41ab-979b-f9185f8cb475">
      <Text>Act One</Text>
    </Paragraph>
    <Paragraph Type="Scene Heading" id="25b7d086-7ecc-4961-ae66-0a0dfad04895">
      <SceneProperties Length="1 1/8" Page="9" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="PUPPETEER">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="RAY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text Style="Bold+AllCaps">Int. Cafe - Day</Text>
    </Paragraph>
    <Paragraph Type="Action" id="a6487a92-41c3-4a00-8db8-49a2bbe3b1ca">
      <Text>Ray leans in desperately across a table. Opposite her, a shaky </Text>
      <Text Style="AllCaps">artist</Text>
      <Text> in a Toronto Fringe hat nurses an espresso.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="5b6b4c0e-0554-4401-bfeb-b54f4be36ca3">
      <Text>RAY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="afe2f07a-fcab-4c26-a31c-72c961321e3d">
      <Text>Buddy, come on. Just the weekend shows. I don’t even need a credit, I’ll work under a stage name. Call me Alan </Text>
      <Text AdornmentStyle="-1">Smithee</Text>
      <Text>. I don't care.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="b05a083b-7871-49d4-9ec7-f674bd5126d7">
      <Text>PupPETEER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="c1d2b44f-bf56-426f-b84d-380807a51536">
      <Text>Ray, I tried. Really did. I brought your name up at Solar Stage.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="ff3ce01d-ec10-4b92-80dd-9964120f0bfc">
      <Text>RAY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="c0d6793f-8e3d-44e9-8d4b-2ffb03cf99ba">
      <Text>And...?</Text>
    </Paragraph>
    <Paragraph Type="Action" id="3266a824-e484-4246-9f2e-8dbb6b5b2b55">
      <Text>The artist gets out their phone and opens </Text>
      <Text Style="AllCaps">Toronto Stage</Text>
      <Text> group chat. They scroll through a wall of text. One message reads: “In Cat Scouts Live, she set everyone’s heads on fire. Do </Text>
      <Text Style="AllCaps">not</Text>
      <Text> hire Reyes.” Another reads: “Check this out.” Below is a video titled “Neutron Nigel.” They click </Text>
      <Text Style="AllCaps">play</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="add284c3-896b-4ac3-87b6-225685d5cc11">
      <Text Style="Bold+AllCaps">On the phone:</Text>
      <Text> Ray sits in a rehearsal room. On her left hand is a </Text>
      <Text Style="AllCaps">mangy sock puppet</Text>
      <Text> with googly eyes named </Text>
      <Text Style="AllCaps">Neutron Nigel</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="581d7d11-213f-4a4c-925b-8b6d13f4f236">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="21a9ee9f-0fc7-42e8-942f-5db75439514e">
      <Text>Hi viewers! I’m Ray. </Text>
      <Text Style="Italic">And this is Nigel </Text>
      <Text AdornmentStyle="-1" Style="Italic">Neutronberry</Text>
      <Text>. Today, we bond-</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="d7f719df-e432-4050-a07b-ebc865f13ecc">
      <Text>(as Nigel)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="4c26a4c0-dace-4ea6-be32-15246b585d66">
      <Text>Before we talk about atomic bonds, let’s talk about my contract.</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="cabc6cff-9135-45fb-8656-09c3316e7667">
      <Text>(as herself)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="06c33aa9-bb76-4dbe-ac0d-2e9d5da24509">
      <Text>Nigel, not now. I’m mid-take-</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="dfb31966-dafe-4097-a2ac-7ca12d28adeb">
      <Text>(as Nigel)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="37fae974-b316-4c0c-9b09-ca51162e4813">
      <Text Style="Italic">Hostile work environment</Text>
      <Text>. According to the bylaws of the Imaginary Friends Union, I am entitled to three breaks and hands that don’t smell like gas station hot dogs.</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="796e8f99-0907-407b-bece-a4e36662918a">
      <Text>(as herself)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="e2e50c39-6dd5-46cd-b96f-154f2107dba5">
      <Text>Ignore him, kids! Neutrons love to operate under high pressure!</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="fdb60da0-38fa-4042-afa5-4e6bbdabe2e1">
      <Text>(as Nigel)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="1c8f129d-8ba4-446a-9e4a-c99a5a022c73">
      <Text>I’m experiencing a mid-life crisis.</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="04e0af95-2c05-4b8b-8663-aa4d359f72cd">
      <Text>(as herself)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="82def958-839b-4933-9de0-40ea680bb30f">
      <Text>You’re a billion years old. You got billions more to go. Well, you’re a sock. You really got only a few </Text>
      <Text AdornmentStyle="-1">mon</Text>
      <Text>-</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="aa087acc-f577-48b3-9a5e-ce25acdb25c4">
      <Text>(as Nigel)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="c58fe5d9-d28e-4c7c-99d1-83b87350c27b">
      <Text>Sock it! Supernova!</Text>
    </Paragraph>
    <Paragraph Type="Action" id="1645ff3c-91a5-485c-b36d-d2286373ab73">
      <Text>Ray’s puppet hand punches herself in the face. Ray punches her puppet hand with her free hand. They get in a tussle.</Text>
    </Paragraph>
    <Paragraph Type="Scene Heading" id="25b7d086-7ecc-4961-ae66-0a0dfad04895">
      <SceneProperties Length="3/8" Page="10" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="PUPPETEER">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="RAY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text Style="Bold+AllCaps">Int. Cafe - ConTINUOUS</Text>
    </Paragraph>
    <Paragraph Type="Character" id="8478f4c5-9194-4833-b9b9-95a1394dabc4">
      <Text>RaY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="59e9369f-c8b0-4454-b5ce-f598ad08267e">
      <Text>That tape was my proof-of-concept for a science show on Adult Swim...</Text>
    </Paragraph>
    <Paragraph Type="Character" id="2dcda75f-5cbc-4389-bb91-77e241640eca">
      <Text>PupPETEER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="b35d7c4e-2f3f-4828-9d90-9a657a9bcc4e">
      <Text>Ya ain’t fit for children’s theatre-</Text>
    </Paragraph>
    <Paragraph Type="Character" id="2597883a-3999-43f0-b437-3fe30537232a">
      <Text>RAY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="32b0ef47-89c7-461d-89ec-628e7bf81e70">
      <Text>I’ve been in this industry for a decade! One freak accident and ugh-</Text>
    </Paragraph>
    <Paragraph Type="Character" id="5a85ae39-d14b-4b2e-acab-1877a5423879">
      <Text>PupPETEER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="e235ef27-6bdd-4bd0-9349-93cd9a518f9c">
      <Text>Burning puppets burns bridges too.</Text>
    </Paragraph>
    <Paragraph Type="Scene Heading" id="d0e659f8-8220-454a-8e8e-858b26c1ac52">
      <SceneProperties Length="4/8" Page="10" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="RAY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text Style="Bold+AllCaps">Int. Ray’s Car - MOments Later</Text>
    </Paragraph>
    <Paragraph Type="Action" id="0d37048a-3ab5-4b6f-a7c3-550ea966c777">
      <Text>Ray stares at her reflection in the rearview mirror.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="52e8252c-3602-4273-b448-a2d075d9ba87">
      <Text Style="Bold+Underline+AllCaps">Ray Talking Head</Text>
    </Paragraph>
    <Paragraph Type="Character" id="c041c0b4-4a7f-4f50-b9c2-a35f5f560453">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="6792307a-c42a-4347-bddf-26ea1a9c40e6">
      <Text>What now, world? Should I go look for another job or should I...</Text>
    </Paragraph>
    <Paragraph Type="Action" id="6eb2e6dc-12bd-4007-8f4e-a0a138e2e76e">
      <Text>Ray motions like she is slitting her own throat.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="9edb49d9-c82d-499e-bb4b-3176cf07e1ca">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="8ab72c6b-d691-4bc5-bb5e-c142671d56f8">
      <Text>...</Text>
      <Text AdornmentStyle="-1">ll</Text>
      <Text> myself.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="9d235ea9-72b4-4a23-94ef-a0dc98bce9a7">
      <Text>Awkwardly long pause.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="801810a1-ee4d-4010-ad5c-0dd545e6416a">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="102d5404-4d9e-4659-9a5c-772ddf2365e8">
      <Text AdornmentStyle="-1">Whichhhhh</Text>
      <Text> one...? Apply myself or offffffff myself?</Text>
    </Paragraph>
    <Paragraph Type="Action" id="f8ef923f-9d40-4953-a508-d764fd806138">
      <Text Style="Bold+AllCaps">As we were</Text>
    </Paragraph>
    <Paragraph Type="Action" id="0d37048a-3ab5-4b6f-a7c3-550ea966c777">
      <Text>Ray sees her photo with Kwan (4) and herself (9) in front of a giant globe on the dashboard.</Text>
    </Paragraph>
    <Paragraph Type="Scene Heading" id="4d363499-15c2-4609-832f-b7fe0e32ac7f">
      <SceneProperties Length="2/8" Page="10" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="RAY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text Style="Bold+AllCaps">Ext. Ray’s Car - Continuous</Text>
    </Paragraph>
    <Paragraph Type="Action" id="f1b9fb0e-6dbb-4515-bfc7-e5581fe4b86b">
      <Text>Ray drives away from the cafe.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="98a468ff-eb9c-4f54-aeaa-1d32f40292e4">
      <Text>Ray (V.O.)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="f6f9fadd-f734-461b-bc37-cf86bd32174b">
      <Text>Alright, world. Perhaps, I should ask: What’s next?</Text>
    </Paragraph>
    <Paragraph Type="Scene Heading" id="57d90b96-27b1-47a6-9269-6c3170445e33">
      <SceneProperties Length="1 7/8" Page="11" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="CLAY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text Style="Bold+AllCaps">Int. Ray’s Car - Day (WeekS LATER)</Text>
    </Paragraph>
    <Paragraph Type="Action" id="2780a8b9-ae76-4cef-9334-ca8d067597bb">
      <Text>The car dissolves from empty to becoming a tomb of a failed life. Cardboard boxes are crammed into the backseat, while a termination letter and an eviction notice sit shotgun.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="96a2c0cd-299e-45b8-86ad-8e7587470b32">
      <Text>Ray sits, with her hair like a bird's nest. She shifts into drive, weeping silently as she pulls away from the curb.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="dbce47fb-2e46-4d45-bd18-55d2ab3ffac0">
      <Text>Her phone, mounted on the dash, </Text>
      <Text Style="AllCaps">pings</Text>
      <Text>. A notification banner slides across: </Text>
      <Text Style="AllCaps">Ms. Aurora is Live!</Text>
      <Text> (42K Watching).</Text>
    </Paragraph>
    <Paragraph Type="Action" id="acb24d4c-72ed-4d43-80aa-23abc0cc0ad9">
      <Text>Ray </Text>
      <Text Style="AllCaps">swipes</Text>
      <Text> away the notification. Her thumb accidentally hits a different video: </Text>
      <Text Style="AllCaps">Billy Clayton Dubois</Text>
      <Text> (45), the original Clay, sits in a sunny garden wearing his iconic cosmic vest.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="80574043-de3c-47dc-9dcb-86c47117ee12">
      <Text>Clay</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="8eded6ab-e3f0-4e7a-8d4a-dd54f2cd7042">
      <Text>Hey. You got a moment?</Text>
    </Paragraph>
    <Paragraph Type="Action" id="565e605d-b13b-488b-8e0d-a778d94e7273">
      <Text>Ray reaches out to swipe him away, but her hand trembles and drops. She lets him speak. </Text>
    </Paragraph>
    <Paragraph Type="Character" id="dad41a06-cadb-4439-8742-3c86da72c5d1">
      <Text>ClAY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="8eded6ab-e3f0-4e7a-8d4a-dd54f2cd7042">
      <Text>Alright. You remember how when we were younger, we used to run around and hang out with Stardust and discover her stuff and ride Rocket and get lost on another planet and solve all the fun </Text>
      <Text Style="Italic">clues</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="eed34732-79ac-4272-9585-323456b3de8d">
      <Text>Ray sniffles, her eyes darting between the road and screen. On screen, Clay leans in with a smile as warm as a blanket.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="59aa9c23-5a82-4172-bdc7-53ec285edb20">
      <Text>CLAY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="8eded6ab-e3f0-4e7a-8d4a-dd54f2cd7042">
      <Text>And then at some point I said, “Hi </Text>
      <Text AdornmentStyle="-1">stardusters</Text>
      <Text>, guess what? Huge news: I’m returning to my home planet.” And then Rocket took me away and we were gone. And we didn’t see each other for like an eternity. Can we just talk about that?</Text>
    </Paragraph>
    <Paragraph Type="Action" id="fce42656-61b9-4ac3-b41c-e15f62305046">
      <Text>Ray reluctantly nods. She feels like a five-year-old again.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="9e479f43-8b8a-4ade-a2da-bdb7bfd25906">
      <Text>Clay</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="78f908aa-9c47-40a8-bf3f-4c6b3d710373">
      <Text>Fab. Because I realize it was sorta spontaneous. I just </Text>
      <Text AdornmentStyle="-1">kinda</Text>
      <Text> took Rocket for a spin and went for a much needed vacation. And that was super challenging by the way. But great because I got to rest my head and take things slowly and now I’m literally doing all sorts of things that I dreamt of doing.

And then look at you and look at all you have done and all you have accomplished in all that time and it’s just... it’s just awesome, am I right?</Text>
    </Paragraph>
    <Paragraph Type="Action" id="2ae023c9-5484-4658-a2bf-093746df7d90">
      <Text>Ray glances at the eviction notice. She snorts at the camera.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="31147ec0-d55a-4b26-a5c1-a06fa206100e">
      <Text>ClAY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="78f908aa-9c47-40a8-bf3f-4c6b3d710373">
      <Text>I mean, we started out with stuff and now it’s what? Rent, and jobs, and families.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="a8b13682-f36b-4bf8-a71a-fe2fa818bb40">
      <Text>Ray aggressively flips a FAMILY PHOTO face down on the passenger seat, hiding the happy faces of her and her family.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="d354ae10-2a5d-4146-ba35-a64068da7d6e">
      <Text>Clay</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="e2dfb5b9-9c8a-4a89-8266-c0ceb75b570e">
      <Text>And some of it has been </Text>
      <Text AdornmentStyle="-1">kinda</Text>
      <Text> hard, you know? I know you know. And I hoped to tell you that I really couldn’t have done all of that without your help. And in fact, all the singing you did when I was singing back when we were younger still rings music to my ears today. Right now. And that’s truly dope.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="75e3f3a4-71ff-4c90-972b-90da66f44121">
      <Text>Ray rolls her eyes with an involuntary twitch of a smile.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="058dc4e2-fdf7-4bc5-a59c-549f9f4d1f48">
      <Text>Clay</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="cec3cddb-7cfd-42ae-90eb-5094b5e61517">
      <Text>I guess I wanted to say: After an eternity, I never forgot you, ever. And I’m super glad we’re forever buddies. Thanks for listening.

You look fabulous by the way. Whatever you’re doing, it’s working.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="2a71ac33-c972-4a34-b958-cffe49f80274">
      <Text>Ray catches her reflection in the rearview mirror of a disheveled, unemployed mess.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="89e31cb5-4416-4e87-841c-42782f343c3e">
      <Text>The video ends, replaced by a </Text>
      <Text Style="AllCaps">Stardust 25th Anniversary</Text>
      <Text> graphic. Ray swipes it away, pulling up a map. The destination: </Text>
      <Text Style="AllCaps">East Lansing, Michigan</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Scene Heading" id="b6e35718-0e1e-4b9c-af91-ee9b1a813231">
      <SceneProperties Length="1/8" Page="12" Title="">
        <SceneArcBeats/>
      </SceneProperties>
      <Text Style="Bold+AllCaps">Ext. Michigan State University - Afternoon</Text>
    </Paragraph>
    <Paragraph Type="Action" id="2e20ed32-4742-4334-a176-2dbeedead880">
      <Text>Ray’s car rolls onto the sprawling campus.</Text>
    </Paragraph>
    <Paragraph Type="Scene Heading" id="f08d061a-559f-41df-9b0e-4f1bc2b369a4">
      <SceneProperties Length="3/8" Page="12" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="RAY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text Style="Bold+AllCaps">Int. Ray’s Car - ConTINUOUS</Text>
    </Paragraph>
    <Paragraph Type="Action" id="2fbdba88-6f3c-4c9f-bda5-f5eea1db8071">
      <Text>Ray hits “record live” on her phone and forces a smile.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="dd992267-07ef-43f4-8fdd-94b8ba5327e0">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="89efe9b4-0012-4ac9-8c58-80e91efd948e">
      <Text>Plasma update: After having my hands in puppetry, we’re getting our hands dirty in astronomy!</Text>
    </Paragraph>
    <Paragraph Type="Action" id="57b2c369-692a-43e7-a3a2-506b2b572b76">
      <Text>A notification pops up on the screen. A comment from @ClimateChangeIsFake: “earth is flat, plasma girl.”</Text>
    </Paragraph>
    <Paragraph Type="Action" id="89a4f172-8540-4d93-a63e-8c5853038268">
      <Text>Ray winces at the camera. Her thumb clicks the </Text>
      <Text Style="AllCaps">block</Text>
      <Text> button.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="674ccb46-fb46-4ec1-ba9b-e2a3d794c5ff">
      <Text>RaY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="89efe9b4-0012-4ac9-8c58-80e91efd948e">
      <Text>Blocking conspiracy theorists in the chat... </Text>
      <Text AdornmentStyle="-1">Anywho</Text>
      <Text>, I’m in East Lansing to see my genius brother. Let’s see if he can explain why our universe is a dumpster fire.</Text>
    </Paragraph>
    <Paragraph Type="Scene Heading" id="d6e6682e-8d3d-4547-8695-9c277971e902">
      <SceneProperties Length="5/8" Page="13" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="KWAN">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="RAY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text Style="Bold+AllCaps">Ext. Abrams Planetarium Parking Lot - CoNTINUOUS</Text>
    </Paragraph>
    <Paragraph Type="Action" id="4fc7e1d6-4004-4d67-9528-5a9c4b3e4803">
      <Text>Ray pulls into a spot and stops recording. She exhaustedly stares through the windshield at the planetarium’s dome. To her, it looks exactly like the tinfoil moon Clay sat on.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="a8988995-0b6c-40d5-9e73-3a7c61118dbe">
      <Text Style="AllCaps">Thump. Thump. Thump.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="67bba11d-1aad-4401-b86f-6641b1040db4">
      <Text>Ray jumps, gasping. Kwan (24) stands by her window. He wears an </Text>
      <Text AdornmentStyle="-1">MSU</Text>
      <Text> hoodie and noise-canceling headphones around his neck. He traces circles against the glass with his knuckles.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="c42a2c69-7100-43d1-b54c-549f252e977a">
      <Text>RAY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="b479e77f-d063-4bd4-9e38-bd9294cb2f80">
      <Text>Hey, bruh. You trying to break in?</Text>
    </Paragraph>
    <Paragraph Type="Action" id="4315d523-98fc-4659-948d-2f6de1380b2e">
      <Text>Ray steps out. Kwan immediately takes a few large steps back.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="c622df10-6865-4e7c-a5d3-8d5c3aabf394">
      <Text>KWAN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="dd1f9a0d-fcbe-4f37-80e3-ce76d2356299">
      <Text>You smell like a campfire.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="26267c3d-2bd5-4309-8180-da9d83798dda">
      <Text>RAY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="40021939-f6e6-4088-b6d9-8575d3fe86d1">
      <Text>Not coming out, huh? Long story short, involving cats, sprinklers, and a very angry stage manager.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="a8de143f-2c87-4434-a45b-949eb344f2e7">
      <Text>KWAN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="cfdee166-16dd-4656-b026-aa61058198f1">
      <Text>Well, our stage is 400 steps away. To the planetarium!</Text>
    </Paragraph>
    <Paragraph Type="Action" id="a26ab9c3-1355-4d0e-8589-958bb53c9263">
      <Text>Ray gives a smug look to the camera.</Text>
    </Paragraph>
    <Paragraph Alignment="Center" FirstIndent="0.00" Leading="Regular" LeftIndent="1.00" RightIndent="7.50" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="End of Act" id="8320508a-6b7a-43cd-9457-386c90d1a8a4">
      <Text>End of Act One</Text>
    </Paragraph>
    <Paragraph Type="New Act" id="1e86dd4f-aecd-4d93-a977-ee2f15120ede">
      <Text>Act Two</Text>
    </Paragraph>
    <Paragraph Type="Scene Heading" id="a9b55b7d-a5b0-4836-97f1-c785f3b09dc0">
      <SceneProperties Length="4/8" Page="14" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="KWAN">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="RAY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text Style="Bold+AllCaps">Int. Abrams Planetarium - Day</Text>
    </Paragraph>
    <Paragraph Type="Action" id="0011ce00-5720-4f12-8caf-7240984a8254">
      <Text>Ray and Kwan pass a meteorite exhibit as he leads her into the dimly lit dome. Kwan heads to the control console.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="f640b0a0-24f4-499e-abb7-a70600a2a05b">
      <Text>Kwan</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="9b32350b-43cc-47e3-b1bf-a28406d7663f">
      <Text>I must recalibrate the visuals for my neurodivergent theatre.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="7de89bad-4728-4a7a-bafb-edfb68fe50a1">
      <Text>RAY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="a7e7d5f9-917b-451d-b8e4-ca699052cd98">
      <Text>Recalibrate? Nerd does what?</Text>
    </Paragraph>
    <Paragraph Type="Character" id="05dd18fc-40dc-447c-8fb0-6b8683d0d339">
      <Text>KWAN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="df335041-d180-4499-b178-2a526871a858">
      <Text>Making stars move like jellyfish!</Text>
    </Paragraph>
    <Paragraph Type="Action" id="ac878600-1686-4a9b-859f-bc805911faec">
      <Text>He taps the keys. Above them, the sky ripples into stars.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="be24fa83-f9be-45ab-9c7b-37f35128d36c">
      <Text>RAY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="8728aca0-6dbf-4c7e-be78-429384a390a8">
      <Text>You were scared of the dark, bruh. Now look at you. Not afraid of any-</Text>
    </Paragraph>
    <Paragraph Type="Scene Heading" id="b365999f-9fd9-4f78-b9e4-30b8b0ec9113">
      <SceneProperties Length="1/8" Page="14" Title="">
        <SceneArcBeats/>
      </SceneProperties>
      <Text Style="Bold+AllCaps">EXT. REYES HOME - NIGHT (Flashback, 2008)</Text>
    </Paragraph>
    <Paragraph Type="Action" id="649a126c-e5d2-4a96-82cc-f3b19ecf726a">
      <Text>A humid summer night. A </Text>
      <Text Style="AllCaps">tornado siren</Text>
      <Text> wails in the distance.</Text>
    </Paragraph>
    <Paragraph Type="Scene Heading" id="5799f7fb-bdb7-4013-9b2c-605e55666998">
      <SceneProperties Length="6/8" Page="14" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="KWAN">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="RAY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text Style="Bold+AllCaps">INT. REYES LIVING ROOM - CONTINUOUS</Text>
    </Paragraph>
    <Paragraph Type="Action" id="5575a5fd-6f00-4b8a-b6f4-a458c910b783">
      <Text>The power is out. Kwan (6) hides under the kitchen table. Kwan rocks so hard he hits his head on the table leg. </Text>
      <Text Style="AllCaps">Thump</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="204b1ec8-4b14-467d-97a6-6ee956a5bac1">
      <Text>Ray (O.S.)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="8e69333d-8970-4c31-8436-0c0d000ea5de">
      <Text>Bruh! Look! Look at the light!</Text>
    </Paragraph>
    <Paragraph Type="Action" id="59fb36a1-572e-44ad-8710-4a459dd4bb5a">
      <Text>Kwan peeks through his fingers. Ray (11) holds a flashlight. She nabs an empty </Text>
      <Text Style="AllCaps">plastic bottle</Text>
      <Text> from the trash. She unscrews the cap a bit, then slaps the bottom. </Text>
      <Text Style="AllCaps">Pop</Text>
      <Text>. The cap flies off.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="d7c5514e-a709-4008-a6f2-39deb1d0a278">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="bb0bbcce-37f3-45ea-b10f-c5d9fc68290a">
      <Text>The sky may try to squish our house-</Text>
    </Paragraph>
    <Paragraph Type="Action" id="1043d507-5733-405f-98e2-9f77fef81af5">
      <Text>Ray squeezes the bottle from the opening. It does not crush.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="b132fc48-ca9c-4c80-b765-ab5936a3c4cf">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="dcce75a6-db90-4d28-b0d4-4259adbe24a5">
      <Text>But if we stay tight, keep our air inside, we’re a pod. Wind can’t get us with pressure. Science, see?!</Text>
    </Paragraph>
    <Paragraph Type="Action" id="ed10f9b0-e513-4749-9fee-1b364745fb7f">
      <Text>A flash of lightning illuminates a </Text>
      <Text Style="AllCaps">special-edition stardust</Text>
      <Text> </Text>
      <Text Style="AllCaps">walkie-talkie</Text>
      <Text> on the rug. Ray grabs it and clicks the side.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="fa520355-57d0-4d3c-9959-fe1d69e0b174">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="3da366d8-901b-440e-bc85-c5b1df9deec8">
      <Text AdornmentStyle="-1">Starduster</Text>
      <Text> Kwan! Let’s call it home-</Text>
    </Paragraph>
    <Paragraph Type="Action" id="ed6dc901-01a1-438e-9a1a-fb55cffdff5c">
      <Text>Kwan pulls out his own plastic walkie-talkie.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="bd18491f-f9c6-4270-9fea-336661bbc324">
      <Text>Kwan</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="e96f24a2-54ca-4db0-adc6-4fb50fc42c65">
      <Text>Will we lose our home?</Text>
    </Paragraph>
    <Paragraph Type="Action" id="e0fd18df-a15d-4348-b575-025b87130a4f">
      <Text>Ray pulls Kwan out from underneath the table and into a hug.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="f8dfb335-7455-4bcb-a42e-102c1d6c43ce">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="fb1ac9f9-911f-479b-aaeb-1a0440af44f3">
      <Text>No way. Home is so tough. Our force fields are at, like, a mill-  bill- bajillion- hug-</Text>
      <Text AdornmentStyle="-1">tillion</Text>
      <Text> percent.</Text>
    </Paragraph>
    <Paragraph Type="Scene Heading" id="922de64f-e3df-44f0-80fc-e5ac8a6b921d">
      <SceneProperties Length="1/8" Page="15" Title="">
        <SceneArcBeats/>
      </SceneProperties>
      <Text Style="Bold+AllCaps">EXT. REYES HOME - CONTINUOUS</Text>
    </Paragraph>
    <Paragraph Type="Action" id="428e62d3-d2e8-4a01-8aca-fd50324d2b44">
      <Text>The wind howls. A </Text>
      <Text Style="AllCaps">foreclosure</Text>
      <Text> notice is taped to the door.</Text>
    </Paragraph>
    <Paragraph Type="Scene Heading" id="a9b55b7d-a5b0-4836-97f1-c785f3b09dc0">
      <SceneProperties Length="1 3/8" Page="15" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="KWAN">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="RAY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text Style="Bold+AllCaps">Int. Abrams Planetarium - ConTINUOUS</Text>
    </Paragraph>
    <Paragraph Type="Action" id="a6fb09cd-b16b-4480-95ee-8292adcfc702">
      <Text>Ray watches swirls of light dance in the dome.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="b56d0125-b66f-41a7-b1cd-18147822150f">
      <Text>RAY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="b235f5c3-740f-4412-b483-3bb7151d788d">
      <Text>God, I wish I could live here. No producers, no puppets, just...</Text>
    </Paragraph>
    <Paragraph Type="Action" id="62c373e0-c38c-402d-a32b-c3309b43e5a0">
      <Text>The dome displays auroras.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="7c97731f-5a6a-4787-9ea6-0d608e363742">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="6972a1a6-84f7-4552-bf8e-e1a34c49a960">
      <Text>Please no auroras...</Text>
    </Paragraph>
    <Paragraph Type="Action" id="901cbd61-f802-4f35-95e9-6c5e3cff618f">
      <Text Style="Bold+Underline+AllCaps">Ray talking head</Text>
    </Paragraph>
    <Paragraph Type="Action" id="4ecd8cfe-38dc-42c9-82e5-3da5bad36da2">
      <Text>Ray holds a campy group photo. She points to the perfect Ms. Aurora Starling (20) next to Ray (20).</Text>
    </Paragraph>
    <Paragraph Type="Character" id="e0bf96ed-034a-4406-ae72-54bbcd41f3d5">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="49a54e86-a7d7-4f12-829e-b8140ccc7ba6">
      <Text>Don’t get me started on Ms. Aurora Starling. We ain’t see eye to eye since theatre camp or science camp or Girls State or college-</Text>
    </Paragraph>
    <Paragraph Type="Action" id="7d72c44f-0dc6-4453-8cb9-b240823b1826">
      <Text Style="Bold+AllCaps">As we were</Text>
    </Paragraph>
    <Paragraph Type="Character" id="59ce4f9d-2a26-40d9-8438-66a3b9098753">
      <Text>KwaN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="85f0be4b-f995-4c1f-9b39-772806eb9a5b">
      <Text>Auroras are the best, especially Ms. Aurora. Her YouTube channel makes me wanna touch grass. Your channel makes me feel kidnapped-</Text>
    </Paragraph>
    <Paragraph Type="Character" id="5ebd99f5-a4a5-4445-9b90-a5f05fcb061f">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="49da5dca-975c-4fe6-99f6-4b97b25e8d87">
      <Text>(in Tagalog; subtitled)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="36abdb85-1a66-43ba-890e-cbf3e37f0649">
      <Text>Shut up.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="8a681b79-91f6-4ffa-829a-72b1fe68c89c">
      <Text>Kwan</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="9e829236-b483-49c4-a421-482d31c56fb8">
      <Text>How about a supernova for size?</Text>
    </Paragraph>
    <Paragraph Type="Action" id="7830515c-6a8b-48ee-85a4-3a7e6c7c50ac">
      <Text>A </Text>
      <Text Style="AllCaps">supernova</Text>
      <Text> blooms across the dome.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="72b52b5d-abfd-4761-9f37-001a1cc8f037">
      <Text>KwaN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="132f5808-d2fa-4019-94e8-69226080351c">
      <Text>“Twinkle, twinkle, twinkle” as Stardust would say.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="a5a85fd2-0660-482a-9cf9-089cfc3d795a">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="3eaa38a6-ddf1-4a87-80bd-4a716470e60e">
      <Text>What a blast from the past. That was a good show. I miss </Text>
      <Text Style="Italic">Stardust</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="108a13ad-77cb-43cf-8184-44ccfa21add9">
      <Text>Kwan</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="1613115d-be9f-4760-ba86-276056371bf4">
      <Text>Stardust is here.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="82a1c634-56f9-48a3-89d6-cc1536aab1c6">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="fded4964-a66d-4c5b-83c4-ce012230bde5">
      <Text>And so is Clay in our hearts...</Text>
    </Paragraph>
    <Paragraph Type="Character" id="2bc80a6c-a7d3-4411-9485-88bdbc68e1f1">
      <Text>Kwan</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="4b7f565e-1eb0-432d-8518-c93ea457218d">
      <Text>No, Stardust is visiting tomorrow.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="cedc4a52-33e0-4db5-8211-58464d7866fe">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="042c71ff-d70c-48cc-ba21-1b9cd4410bbf">
      <Text>In what world is she-</Text>
    </Paragraph>
    <Paragraph Type="Action" id="48544668-87f1-47aa-bc52-75b377d1323a">
      <Text>Kwan pulls out an </Text>
      <Text AdornmentStyle="-1" Style="AllCaps">MSU</Text>
      <Text Style="AllCaps"> Arts Fair</Text>
      <Text> flyer. The graphic features River Matthews (50) holding her Stardust puppet and </Text>
      <Text Style="AllCaps">text</Text>
      <Text>: “Master of Ceremony: River Matthews, </Text>
      <Text Style="Italic">Stardust Stuff </Text>
      <Text>Creator.”</Text>
    </Paragraph>
    <Paragraph Type="Action" id="052d1f91-47d0-4d35-b676-e493e82ee831">
      <Text Style="Bold+Underline+AllCaps">Ray Talking Head</Text>
    </Paragraph>
    <Paragraph Type="Action" id="cac81c94-8759-4e9e-aa8f-33cd38619354">
      <Text>Ray howls in celebration while dancing in place.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="5c15f6f0-0aa8-4d88-8b97-8ee257624f1c">
      <Text>KwaN (O.S.)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="d570f910-5975-48c7-bb0d-d119ea97aed4">
      <Text AdornmentStyle="-1">Shhhhhhhhh</Text>
      <Text>!!!!</Text>
    </Paragraph>
    <Paragraph Type="Action" id="e55801bf-1871-4bd6-99cb-282513b5fd75">
      <Text>Ray collects herself and smiles towards the camera.</Text>
    </Paragraph>
    <Paragraph Type="Scene Heading" id="ef801fc1-2729-412e-91e2-b16efc470bc0">
      <SceneProperties Length="2" Page="16" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="CLAY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="KIDS">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="KWAN">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="RAY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="ROCKET">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="STARDUST">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text Style="Bold+AllCaps">Int. Kwan’s Apartment - Night</Text>
    </Paragraph>
    <Paragraph Type="Action" id="03270387-028a-490a-b435-4a3bbb751a2b">
      <Text>Physics posters fill the walls, telescopes scatter around the spaces, and unresolved assignments lie stacked on a table.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="03270387-028a-490a-b435-4a3bbb751a2b">
      <Text>Ray lies on the floor, surrounded by takeout containers. Kwan peeks out of the bathroom, brushing his teeth.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="dc037c4d-98cd-4370-9ef4-f9657bd6cb5b">
      <Text>RAY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="a4ecdb54-ab1c-46a5-bf0c-5fe48c4bdc0e">
      <Text>I’m a black hole of food, bruh.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="9905ad20-7f41-458e-a5ae-73f2c221a6a5">
      <Text>Kwan spits out the toothpaste and rinses his toothbrush.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="3efaeff9-c2de-4c08-8dec-358ffe72696e">
      <Text>KWAN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="2b6270a4-54c2-4f25-b5b0-bded1588973e">
      <Text>You’re really a supernova.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="2065cabc-21b5-4646-b82a-f227412b82a7">
      <Text>RAY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="7d677471-4b70-4b49-9ece-9c7fe4f12c2a">
      <Text>Thanks, bruh. That’s actually—</Text>
    </Paragraph>
    <Paragraph Type="Character" id="7999c914-d3a9-4d22-8733-6beb8a80db8b">
      <Text>KWAN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="dbf668ed-6b7a-47a8-9e03-9633c2970104">
      <Text>Supernova is a messy violent implosion caused by the inability to manage pressure... and food.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="a1c96c49-2d12-4ba6-8fcc-c6f3e71dfc32">
      <Text>RaY</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="04e5735b-c711-4cf1-b132-82da5c95cf20">
      <Text>(in Tagalog; subtitled)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="c4c87567-e6aa-4c32-8fca-acad82e7870c">
      <Text>Shut the hell up!</Text>
    </Paragraph>
    <Paragraph Type="Action" id="24c1e334-de72-4886-bbc7-600c9a3ea98e">
      <Text>Kwan heads off to bed.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="3d159850-7270-43bb-b049-b169f97351fe">
      <Text>RAY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="3993a229-0807-4109-a14b-d72aba15b333">
      <Text>I was trying to save my puppet show-</Text>
    </Paragraph>
    <Paragraph Type="Character" id="be023109-0950-4a7c-86c9-42dab68f0397">
      <Text>Kwan (O.S.)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="c67ff3b0-6261-42cf-b192-0d0a30faec58">
      <Text>Maybe it’s a time you stop saving and start listening.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="f2eb96ae-3dd6-4c59-ac23-aee0eedf5f61">
      <Text>Ray sits upright against the sofa. She grabs the remote and turns on the flatscreen TV. From the </Text>
      <Text Style="Italic">Stardust Stuff</Text>
      <Text> catalog on a streaming app, she selects a classic episode: “ZINC!”</Text>
    </Paragraph>
    <Paragraph Type="Action" id="b651c3a1-ce61-4db3-a473-41b010a4a756">
      <Text Style="Bold">ON THE TV:</Text>
      <Text> A rocket ship touches down on a vibrant, hand-painted planet. Rocket sings a jingle.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="1fba0e28-ce16-413d-9d5a-c5f89f1dd76c">
      <Text>Rocket</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="538e12d0-902a-4e31-87ed-5307d57e3832">
      <Text Style="AllCaps">Let’s land on this planet
I wonder if we’ll call it home?</Text>
    </Paragraph>
    <Paragraph Type="Action" id="b651c3a1-ce61-4db3-a473-41b010a4a756">
      <Text>Clay (20s) steps out of the hatch into a whimsical forest. He comes across a strange, glowing purple mushroom.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="44a5c628-a1fb-4ebd-846b-b18ccdb07779">
      <Text>CLAY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="84f19451-bd27-44ff-add3-e52223b84af2">
      <Text>What color is that?</Text>
    </Paragraph>
    <Paragraph Type="Character" id="8b9ea3d2-fac4-42d6-89b8-453091f4a2cd">
      <Text>Kids (V.O.)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="e4f35b36-9f0f-4749-93e5-e2f25c609680">
      <Text>Purple!</Text>
    </Paragraph>
    <Paragraph Type="Character" id="29d96b29-32b7-4ebb-9c2f-7082bfbd2bff">
      <Text>ClAY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="634f35bc-0972-46c1-b994-52e22912a18c">
      <Text>Green?</Text>
    </Paragraph>
    <Paragraph Type="Action" id="a60bf764-cbf8-48a2-a458-bae372f147db">
      <Text>Ray turns to the camera with an amused look.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" RightIndent="7.50" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="General" id="6bc6b778-f22d-4337-ab07-e8ee6c13b46f">
      <DualDialogue>
        <SpellCheckIgnoreLists>
          <IgnoredRanges/>
          <IgnoredWords/>
        </SpellCheckIgnoreLists>
        <Paragraph Type="Character" id="5188fa66-623e-4e23-b31e-70e256226934">
          <Text>RAY</Text>
        </Paragraph>
        <Paragraph Type="Dialogue" id="9975702f-de3e-44f3-8147-c6488fb88567">
          <Text>This guy’s so colorblind...</Text>
        </Paragraph>
        <Paragraph Type="Character" id="ad7f43ce-2890-438b-bb0b-33dbd00fd37f">
          <Text>Kids (V.O.)</Text>
        </Paragraph>
        <Paragraph Type="Dialogue" id="9efa9bd8-2938-4e12-a46a-5f7b39eca55e">
          <Text Style="AllCaps">Purple! Purple! Purple!</Text>
        </Paragraph>
      </DualDialogue>
    </Paragraph>
    <Paragraph Type="Character" id="0b1d9e64-d22e-46f3-9ff9-d022bb3e89f1">
      <Text>CLAY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="e00dd134-e89e-4157-adf1-d24242017c1a">
      <Text>A </Text>
      <Text Style="AllCaps">purple</Text>
      <Text> mushroom! Stardust, should we check it out?</Text>
    </Paragraph>
    <Paragraph Type="Action" id="33a29262-621f-4b4b-bab0-f392e3a140c7">
      <Text>Stardust zips around Clay’s head, leaving a trail of glitter before landing on the sprout with a musical </Text>
      <Text Style="AllCaps">ding</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="23e80774-b7d0-4e22-9524-3dfe3d3cae57">
      <Text>Stardust</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="99f584f0-adfe-4da3-bb17-74fe1f48540c">
      <Text>Twinkle, twinkle, twinkle!</Text>
    </Paragraph>
    <Paragraph Type="Character" id="f20f75c6-4d8c-4d76-8f57-c54c145d6cd1">
      <Text>Clay</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="a757dc5d-c1f3-4e2b-8239-8b2d776d23bf">
      <Text>You’re right, Stardust. It does feel cold... </Text>
      <Text AdornmentStyle="-1">Brrr</Text>
      <Text>! How cold?</Text>
    </Paragraph>
    <Paragraph Type="Character" id="1b26cc81-c1d8-45e8-86e5-8e76a185f564">
      <Text>Rocket</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="8eb2e49f-e334-4839-be7b-5912cc48efcc">
      <Text>Temperature is thirty below zero! Even fungus here are ice cold!</Text>
    </Paragraph>
    <Paragraph Type="Character" id="ed267782-d961-44fd-a5b6-97f93843bc7a">
      <Text>CLAY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="c5ee2428-8082-449c-a061-9d855969f287">
      <Text>Ice is a...?</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" RightIndent="7.50" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="General" id="603c5f85-215b-49f7-a9ee-ed7ac6754c6b">
      <DualDialogue>
        <SpellCheckIgnoreLists>
          <IgnoredRanges/>
          <IgnoredWords/>
        </SpellCheckIgnoreLists>
        <Paragraph Type="Character" id="1a50e6e4-de38-4fa5-8660-e5c0b05702a9">
          <Text>RAY</Text>
        </Paragraph>
        <Paragraph Type="Dialogue" id="eec6820f-0ae2-4429-96b9-88eb122ed04b">
          <Text>Evil.</Text>
        </Paragraph>
        <Paragraph Type="Character" id="52bea605-497c-4172-9434-81c82411f5fe">
          <Text>KidS</Text>
        </Paragraph>
        <Paragraph Type="Dialogue" id="b32664a5-72d7-4e61-a429-e9bdab7a1df5">
          <Text>Solid!</Text>
        </Paragraph>
      </DualDialogue>
    </Paragraph>
    <Paragraph Type="Character" id="394ea903-f5b7-49e9-a39b-84210ae865cf">
      <Text>Clay</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="c5ee2428-8082-449c-a061-9d855969f287">
      <Text>Solid! It stays one shape. But when-</Text>
    </Paragraph>
    <Paragraph Type="Action" id="ac10f861-5e25-48ef-be38-4f260fbfae60">
      <Text>Clay holds a magnifying glass over the mushroom. Through the lens, we see the ice crystals vibrating.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="01dc0a29-8536-4212-b70d-94cd5bb2b3d4">
      <Text>Clay</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="99878c55-5ab1-417c-86ed-2b8188952696">
      <Text>The sun comes out. What happens to ice when it gets warm?</Text>
    </Paragraph>
    <Paragraph Type="Character" id="7ff9fc85-02b2-4904-b552-baac60bf3d10">
      <Text>Kids (V.O.)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="620be97d-9011-4899-bf59-3fb7c1129f83">
      <Text>It melts!</Text>
    </Paragraph>
    <Paragraph Type="Character" id="809fb7b4-f4ea-49ce-8c42-133cef18507a">
      <Text>CLAY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="dc101aee-e82f-4ed6-b86d-acdf6ec6e34c">
      <Text>It melts. It becomes... liquid! We’re going to follow the liquid trail to the Crystal Caves. Don’t forget your Stardust Walkie-Talkie.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="1dd81c86-a240-4877-beb7-aba2bee5f45d">
      <Text>Stardust and Rocket get out their </Text>
      <Text Style="AllCaps">walkie-talkies</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Scene Heading" id="572a8b88-7eee-4c4e-9d80-0a5772b88fa5">
      <SceneProperties Length="2/8" Page="18" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="CLAY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text Style="Bold+AllCaps">Back to the Room - ContINUOUS</Text>
    </Paragraph>
    <Paragraph Type="Action" id="94fc86e9-e7f3-4f8e-9e9e-31eabd66c5f9">
      <Text>Ray’s eyes widen. A spark of desperate inspiration hits her. She bolts upright and sprints towards the door.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="70f697d1-b00b-4944-8e80-d31cdffce46d">
      <Text>Clay (O.S.)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="cf9e3a08-9d04-49a2-8f9f-012ef272ffa2">
      <Text>Ready to explore?</Text>
    </Paragraph>
    <Paragraph Type="Scene Heading" id="f773e2eb-248d-45fa-bf85-ba07128c8444">
      <SceneProperties Length="2/8" Page="18" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="RAY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text Style="Bold+AllCaps">Ext. Kwan’s Apartment - Moments Later</Text>
    </Paragraph>
    <Paragraph Type="Action" id="61209150-25f6-4ad4-ab87-a7593a8e83bf">
      <Text>Ray reaches into the car backseat, and pulls out a special-edition </Text>
      <Text Style="AllCaps">Stardust Walkie-Talkie</Text>
      <Text> from a box. She faces camera.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="72189d55-c75f-40e8-bd7f-bc28b63e7516">
      <Text>RAY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="63379a7b-9934-4478-8747-ab00203f0e13">
      <Text>Ready to explore...</Text>
    </Paragraph>
    <Paragraph Type="Scene Heading" id="1eff6282-ac5e-46a0-b4e8-22eba9ef111a">
      <SceneProperties Length="3/8" Page="19" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="RAY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text Style="Bold+AllCaps">Int. Kwan’s Apartment - Moments Later</Text>
    </Paragraph>
    <Paragraph Type="Action" id="afc3b86b-bab1-488e-b28b-70d935d44116">
      <Text>Ray returns to the sofa, clutching the walkie-talkie. She turns a dial on her walkie-talkie. The show’s theme wheezes out of its tiny speaker. Her eyes lock on the TV. The upbeat theme plays over the credits. Ray watches the names scroll by: Created by River Matthews &amp; Schuyler Park.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="30d2ef2c-79c5-4893-ad67-0d6ef390ac7b">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="f1a3235e-7b6a-4402-9788-8eeb82b04eeb">
      <Text>Ray to Clay. Come in, Clay.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="ebcc3e8a-5e46-4dce-b194-b5a0dc8f0438">
      <Text>She looks at the screen where the credits remain frozen.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="32b1e647-bd7c-40a3-b792-aa7135066e48">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="2f8d50aa-0953-40f0-ac06-dc051b47f28d">
      <Text>We’re going to the art fair. And we’re not leaving without a job.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="e38a1782-03c9-4778-99a8-ede0aa018e7b">
      <Text>She sets the walkie-talkie down on a table, next to her termination letter.</Text>
    </Paragraph>
    <Paragraph Type="Scene Heading" id="675615da-4ed8-41f6-83e8-499f72b21ba2">
      <SceneProperties Length="3 2/8" Page="19" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="AUDIENCE">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="HANDLER">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="KIDS">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="KWAN">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="RAY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="RIVER">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text Style="Bold+AllCaps">Int. </Text>
      <Text AdornmentStyle="-1" Style="Bold+AllCaps">MSU</Text>
      <Text Style="Bold+AllCaps"> UNION - DAY</Text>
    </Paragraph>
    <Paragraph Type="Action" id="670467f0-4622-48c9-89a6-68c1dd08de61">
      <Text>On stage, Stardust pops up. Underneath, River puppeteers her in one hand and holds a microphone in the other hand.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="793f6ae1-88a4-4b28-891f-a9824fbcade0">
      <Text>RivER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="4eb2e62d-b7b1-4bb6-8862-7d39a15ad1b1">
      <Text>Twinkle, twinkle, twinkle! Welcome, </Text>
      <Text AdornmentStyle="-1">stardusters</Text>
      <Text>, to the art fair! I’m River Matthews.</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="aff691d5-ac62-4658-b871-9ebb45b744d9">
      <Text>(mic to Stardust)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="bd860cbc-b0b9-4b16-8603-1371d7f55903">
      <Text>And I’m your best friend, Stardust!</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="190f4868-d668-4bca-ae13-09a48d537079">
      <Text>(as herself)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="4eb2e62d-b7b1-4bb6-8862-7d39a15ad1b1">
      <Text>Thanks for inviting us to be the 2025 Master of Ceremony! How long ago has it been since Stardust and us last saw you? How many years?</Text>
    </Paragraph>
    <Paragraph Type="Character" id="31f1b7c3-57a9-4cf8-9b43-59b69e82108a">
      <Text>Audience</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="b24331c1-5786-4a53-b0a3-0cdd03b7792b">
      <Text>(Most with other numbers)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="59b8a152-2c3e-4758-a099-f8884463cd43">
      <Text>Twenty!</Text>
    </Paragraph>
    <Paragraph Type="Character" id="b8301d16-0c2c-4bb1-a683-014604631268">
      <Text>RiVER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="4eb2e62d-b7b1-4bb6-8862-7d39a15ad1b1">
      <Text>That’s right. Almost twenty years since we last blasted off. But look at you all, it’s like we never left the </Text>
      <Text AdornmentStyle="-1">Miniverse</Text>
      <Text>. Now, we landed on your world to celebrate the magic of discovery, the beauty of the cosmos, and, of course, the...</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="11aad428-0e1a-4138-8983-9e9102aa665a">
      <Text>(as Stardust)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="4eb2e62d-b7b1-4bb6-8862-7d39a15ad1b1">
      <Text Style="Italic">Stardust stuff</Text>
      <Text> that makes us, us! Twinkle, twinkle, twinkle!</Text>
    </Paragraph>
    <Paragraph Type="Action" id="68c78d46-e3c5-42c9-9c2b-6869583888d2">
      <Text>The ballroom is a maze of folding tables.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="3684f69f-d930-44ff-83ae-9c43aa2c207d">
      <Text>River (V.O.)</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="13afc23a-bab5-4c28-af4a-4c4f61450581">
      <Text>(as herself)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="84b3f144-e7ce-48c7-ab31-9e21e6872643">
      <Text>Remember, </Text>
      <Text AdornmentStyle="-1">stardusters</Text>
      <Text>: the universe is vastly dark, but it’s a light trip when we explore it </Text>
      <Text Style="Italic">together</Text>
      <Text>!</Text>
    </Paragraph>
    <Paragraph Type="Action" id="68c78d46-e3c5-42c9-9c2b-6869583888d2">
      <Text>Nearby, a paper on a music stand reads: $20 Autographs &amp; Photos with River Matthews and Stardust.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="56814fdb-261b-49f4-ada1-0f0952cb0132">
      <Text>River (V.O.)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="1c4ce236-5e49-4103-b1c5-73ce86e16a5c">
      <Text>Stardust hopes to meet every human on Earth. For autographs, we’ve got all the ink in the Solar System! Got enough smiles to go round?</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="a76d8ee7-f185-499d-8489-4a2adacf62d9">
      <Text>(as Stardust)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="6fd002ac-b831-4b5d-9881-55ea005f98f0">
      <Text>Twinkle, twinkle, twinkle!</Text>
    </Paragraph>
    <Paragraph Type="Action" id="131a2904-45e9-47da-b0af-b7ceaf5d1f48">
      <Text>The line is a slow-moving herd of </Text>
      <Text Style="AllCaps">parents</Text>
      <Text> and </Text>
      <Text Style="AllCaps">toddlers</Text>
      <Text>. Ray stands near the front, vibrating with manic energy. In her hands, she clutches a stack of </Text>
      <Text Style="AllCaps">resumes</Text>
      <Text>. Kwan stands behind.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="009a8df2-4f31-419b-9f25-f85ba503b07c">
      <Text Style="Bold+Underline+AllCaps">Ray Talking Head</Text>
    </Paragraph>
    <Paragraph Type="Character" id="f3005305-fbd1-4aa1-908b-14390ba125db">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="ea0ea29a-ee6c-4426-a8b2-251e71c2bce5">
      <Text>Many bring cookies. Some bring fan art. I bring entertainment. Cardstock, double-sided.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="3119994c-ee67-4752-9db3-9a17b896aef7">
      <Text>Ray holds up a resume. The font is </Text>
      <Text Size="10">tiny</Text>
      <Text> and </Text>
      <Text Style="AllCaps">aggressive</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="d677974f-cfd8-4a8b-ad96-f3a5d90a6b92">
      <Text Style="Bold+AllCaps">As we were</Text>
    </Paragraph>
    <Paragraph Type="Action" id="04f5163a-9572-4a5c-8c27-0e3b6739924f">
      <Text>Ray opens her wallet, saddened to see only Canadian bills. She sighs then clocks the camera.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="b1142d9f-03b3-4591-be77-36c8c4d7d374">
      <Text>From behind a velvet rope, River</Text>
      <Text Style="AllCaps"> </Text>
      <Text>(50, pure child wonder and mob boss all in one) signs away, looking weary. She glances up, takes in Ray’s disheveled appearance and Kwan’s fixed stare. A </Text>
      <Text Style="AllCaps">handler</Text>
      <Text> blocks her view.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="76008a05-aaa5-47f1-b058-711fa01aadf5">
      <Text>Handler</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="f004c52e-367c-4c47-b6e2-07770df2173a">
      <Text>Keep the path clear. Have twenty bucks ready...</Text>
    </Paragraph>
    <Paragraph Type="Action" id="b3c8a711-128c-499f-b613-2668b0a4d683">
      <Text>Ray holds up two Canadian twenty-dollar bills. The handler stares at the colorful money and let's out a dry laugh.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="80ffbe7e-6c09-4201-bbf8-6a76f2e7edf3">
      <Text>Handler</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="ac41c8ea-2cc0-423f-bb4b-ced974867290">
      <Text>This, I </Text>
      <Text AdornmentStyle="-1">gotta</Text>
      <Text> see how they do y’all’s Monopoly money.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="8a7c20e7-e443-4627-a7c6-01818f1373a4">
      <Text>They gesture the siblings forward. Ray hands one of the bills to Kwan as they reach the front of the line.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="c725ccec-ae06-460c-8baf-73e6e19b0e3b">
      <Text>RAY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="f4dd4369-abbf-4512-8391-3376079c0391">
      <Text>Hi, fellow </Text>
      <Text AdornmentStyle="-1">starduster</Text>
      <Text>. I’m Ray. Well- I’m Trini, but I go by Ray-</Text>
    </Paragraph>
    <Paragraph Type="Character" id="a21fa2e0-d756-473d-9a06-34cb543d0821">
      <Text>RIVER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="89611159-a65d-4f33-a28d-edb60c260577">
      <Text>That’s lovely, dear. </Text>
      <Text AdornmentStyle="-1">Gotta</Text>
      <Text> twenty?</Text>
    </Paragraph>
    <Paragraph Type="Action" id="525ca29f-936d-4484-b34d-690d0e0b1e07">
      <Text>Kwan holds up the Canadian bill. Ray reaches into her bag and prepares to pull out the walkie-talkie.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="f9a9ed8f-8ffe-479b-ab6d-3394e3709931">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="dae423b4-332f-433d-91ad-a488821986e7">
      <Text>Before exploring, we need our </Text>
      <Text AdornmentStyle="-1">walki</Text>
      <Text>-</Text>
    </Paragraph>
    <Paragraph Type="Action" id="525ca29f-936d-4484-b34d-690d0e0b1e07">
      <Text>River’s hand slips into the </Text>
      <Text Style="AllCaps">stardust puppet</Text>
      <Text> resting on the table. The puppet’s mouth playfully snaps open.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="35659586-e6f3-445f-a5c6-ffe96a29f2e1">
      <Text>River</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="ce050238-e2fa-4536-9170-2071be163e84">
      <Text>(as Stardust)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="ca453836-0d6b-4810-950b-91067437719f">
      <Text>Twinkle </Text>
      <Text AdornmentStyle="-1">twinkle</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">twinkle</Text>
      <Text>, kid! On another planet, everything is free. But here on Earth, stars like</Text>
      <Text Size="10"> </Text>
      <Text>bills!</Text>
    </Paragraph>
    <Paragraph Type="Action" id="d7de091e-91f1-4579-8953-a03307306614">
      <Text>Ray glances at the camera.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="60c4740e-36da-49ae-b258-e1218d932838">
      <Text>Kwan</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="6120519e-70f8-4a13-8784-6df7077c59ac">
      <Text>I’m a broke college student.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="6f9d926d-97bb-41e4-9d63-7d3c1e50101e">
      <Text>River</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="94abcf3d-6020-4abb-8b1f-e58d9b16e14b">
      <Text>Stardust does not discriminate on race, gender, origin, social class! What would you like autographed?</Text>
    </Paragraph>
    <Paragraph Type="Action" id="f0f4143e-c93e-4453-8ffd-93456bf3f4e6">
      <Text>Ray sets down her resume. River autographs it without a second thought. She passes back the resume back to Ray.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="d14e8796-a3eb-42f6-986d-c9856861c223">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="a013008c-fa31-42de-95c4-411adf4ad02f">
      <Text>Ya ain’t looking where ya signing?</Text>
    </Paragraph>
    <Paragraph Type="Character" id="50d641fc-033c-4e15-931b-be31af8eaabb">
      <Text>RiVER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="b0bd71dc-fb2d-4a48-8b48-cba135e20cee">
      <Text>Your menu looks nice, but we’re not hungry. Wanna photo?</Text>
    </Paragraph>
    <Paragraph Type="Action" id="49b8d960-bed1-46c7-8a14-32e0df4f7cb6">
      <Text>In line, the </Text>
      <Text Style="AllCaps">kids</Text>
      <Text> impatiently start chanting.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="048a1979-5dcc-41ea-a9ab-669fb4f0b2db">
      <Text>Kids</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="e7f72cda-b0b1-44d1-8d4b-2687ae72ccc2">
      <Text>Me! I wanna picture! Me! Me!</Text>
    </Paragraph>
    <Paragraph Type="Character" id="07572e33-9775-4a43-9c28-1a0c2302baf4">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="961af308-10d8-42e5-9caa-753e76680f02">
      <Text>Trust me you don’t.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="7a7cc1fe-c025-4230-a467-12a42a9d98b5">
      <Text>Kids</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="f7461c96-c62c-46a6-9161-35ba43e6f9d2">
      <Text>We don’t... trust you...</Text>
    </Paragraph>
    <Paragraph Type="Action" id="403128d7-70cc-4c6f-9459-0af96944fa85">
      <Text>The handler takes Kwan’s phone and their bills. They snap a picture of River, her puppet, smiling Kwan, and annoyed Ray.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="9fe35d8c-5e77-4c17-8875-4af5b92e5d39">
      <Text>River pulls her hand out of the puppet. The performance is over.  She scoffs then clocks the camera before looking coldly past them to the next person in line.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="26b08b67-7150-4589-8f36-7f17cda0993a">
      <Text>RIVER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="4ed07b5f-08bb-40d5-a6c2-58338d71894c">
      <Text>No need to beef. Next, please.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="818a8119-34ac-4ecc-84ea-5dfc1b607642">
      <Text>Ray stands frozen, gripping the walkie-talkie.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="901cbd61-f802-4f35-95e9-6c5e3cff618f">
      <Text Style="Bold+Underline+AllCaps">Ray talking head</Text>
    </Paragraph>
    <Paragraph Type="Action" id="dfb8ed09-4eca-4917-a769-7f8ddbd951e1">
      <Text>Behind Ray, River continues signing autographs and taking photos with fans in line. Ray points to River.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="cce0fdf1-a078-443d-9e5a-41f50d58fb32">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="7ee19104-8ff7-487c-b3fa-bf2dca4c9f73">
      <Text>How would you describe this person? Nuh uh. She’s a...</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="7978e1f8-772d-43d5-ae6a-9a3d86703fc5">
      <Text>(Holding her ear)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="b6b61f47-9c07-403a-8765-57c6f2d21db2">
      <Text>That’s right! A jerk! A piece of </Text>
      <Text AdornmentStyle="-1">sh</Text>
      <Text>-</Text>
    </Paragraph>
    <Paragraph Type="Action" id="6a94d69f-786e-41cd-bc5d-9ad3163a592f">
      <Text>Kwan steps in.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="f7af6cfb-1628-4e7d-b0a4-17e11c6b0742">
      <Text>KwAN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="bdc2269c-7ecc-47ec-96db-8c617438d9cb">
      <Text>Shh... Hold your peace! The kids in line don’t need that negativity.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="c14eab9e-1375-45e4-a6d7-b0cbff9fef47">
      <Text>RAY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="31a3e3e8-7deb-42e4-b3e1-907003f1b016">
      <Text>Kids deserve the truth. Let’s go, bruh.</Text>
    </Paragraph>
    <Paragraph Type="Scene Heading" id="897fe85c-dc2b-47a5-a45f-bf585eef6dd4">
      <SceneProperties Length="1 2/8" Page="22" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="KWAN">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="RAY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="SKYE">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text Style="Bold+AllCaps">Ext. </Text>
      <Text AdornmentStyle="-1" Style="Bold+AllCaps">MSu</Text>
      <Text Style="Bold+AllCaps"> Union - Moments LATER</Text>
    </Paragraph>
    <Paragraph Type="Action" id="c159608c-2c52-4857-951f-1d5d9621b9c9">
      <Text>Ray and Kwan head outside. Ray is trembling from humiliation, holding the walkie-talkie. Her resume flies out of her hand.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="79ab00c2-972c-4bc9-b6fc-339ea66006aa">
      <Text>Schuyler “Skye” Park (51, confident) catches Ray’s resume before it flies away. They read.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="b66eb267-2e60-4b01-a5e4-1d791ad10a3a">
      <Text>SkYE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="99b5a1df-298f-40fc-b655-8cf2e6e09d42">
      <Text>Impressive menu selection...</Text>
    </Paragraph>
    <Paragraph Type="Action" id="e1ed820c-4e34-4346-bb2d-f2c4955bc268">
      <Text>Ray glares at the camera.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="bcc6675d-1531-4854-a6a1-a490e3e1a26a">
      <Text>SkYE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="4aab3ef4-da14-44a8-81e9-84d7be1e1854">
      <Text>And an autograph from my best </Text>
      <Text AdornmentStyle="-1">frien</Text>
      <Text>-</Text>
    </Paragraph>
    <Paragraph Type="Action" id="e1ed820c-4e34-4346-bb2d-f2c4955bc268">
      <Text>Ray snatches back the resume.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="de01257c-23d9-43c7-b27c-c22713da557e">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="66248bdb-aa42-4c5c-9da7-4555921a78c7">
      <Text>Stardust is everyone’s best friend.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="e007404d-ddc6-4fb1-a7fd-f504ee92b182">
      <Text>SkYE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="f20d6d1a-f338-45b4-aa0b-9945490807d6">
      <Text>But seriously your resume’s missing “Ray, </Text>
      <Text Style="Italic">Plasma with the Facts</Text>
      <Text> host.”</Text>
    </Paragraph>
    <Paragraph Type="Character" id="23ec6590-46c4-4a8a-84f6-c491c0045241">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="e87f7e58-45f7-4616-9246-2a80d09697ce">
      <Text>You’re subscribed to my channel?!</Text>
    </Paragraph>
    <Paragraph Type="Character" id="0ed72db2-7b18-41a7-8c37-47e1bbdb13be">
      <Text>SKYE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="eb46994e-105e-4595-aaed-5dd71eb47f3a">
      <Text>I’ve seen all your episodes. The one about entropy had me fired up.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="58f679e4-a797-46a4-8ecb-ec26499d64fe">
      <Text>KWAN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="72440e3a-ff9a-44f1-85d1-0ae757974335">
      <Text>I’m surprised you’ve had fans in the wild...</Text>
    </Paragraph>
    <Paragraph Type="Character" id="496363bf-92fe-47a3-81c3-cd2afca10ee5">
      <Text>SkyE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="0fe27012-aaa4-49da-bbd8-b5c5eb3c690a">
      <Text>What are you holding?</Text>
    </Paragraph>
    <Paragraph Type="Action" id="2d146667-e218-479d-aa70-1e9624f5148f">
      <Text>Ray stows away the walkie-talkie in her clothes.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="98b40e66-0d28-42bd-a64a-c7b90e432e9d">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="ea177559-951f-47a7-b844-935a3a75f9f2">
      <Text>Nothing but dreams.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="f34df959-1016-4244-b97e-ec95974bf3bb">
      <Text>SkYE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="eb46994e-105e-4595-aaed-5dd71eb47f3a">
      <Text>So, emotional baggage...? Look, I’ve </Text>
      <Text AdornmentStyle="-1">gotta</Text>
      <Text> run. But if you wanna answer the question, I’ll be at The Peanut Barrel.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="fb8f1b90-bb9a-40bc-bfcd-718d811001f5">
      <Text>Kwan</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="55886955-9055-40b0-8eaa-8e6049febf44">
      <Text>Peanuts? We’re good.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="a53e4041-b220-45dd-b07b-7de3cb504909">
      <Text>Skye</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="166b5a6f-c968-4a88-b1bc-26bd335e22cc">
      <Text>Suit yourself. But if you wanna be a peanut-eating elephant in the room, River will be there. Stop by when she’s not a machine. And bring actual American cash for burgers.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="5e9d0d17-29bf-45d1-bde1-fe9d4f06e434">
      <Text>Skye walks away. Ray gives a perplexed look at the camera.</Text>
    </Paragraph>
    <Paragraph Alignment="Center" FirstIndent="0.00" Leading="Regular" LeftIndent="1.00" RightIndent="7.50" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="End of Act" id="8320508a-6b7a-43cd-9457-386c90d1a8a4">
      <Text>End of Act Two</Text>
    </Paragraph>
    <Paragraph Type="New Act" id="6b67055e-8e0a-4c01-b26e-48bdef828a9a">
      <Text>ACT Three</Text>
    </Paragraph>
    <Paragraph Type="Scene Heading" id="9c2bdf4e-9fcf-4eb8-8db9-b3039f7cf7c5">
      <SceneProperties Length="2 7/8" Page="24" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="KWAN">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="RAY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="RAY &amp; KWAN">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="RIVER">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="SKYE">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text Style="Bold+AllCaps">EXT. THE PEANUT BARREL - NIGHT</Text>
    </Paragraph>
    <Paragraph Type="Action" id="1c0e0372-683b-464a-bc4e-446ef84da2f3">
      <Text>Ray and Kwan get out of their car and step onto the patio.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="5cef3d34-a74f-4c51-ba18-157638563451">
      <Text>At a corner table, Skye is laughing. Beside them sits River. Without the table between her and her fans, she seems human. Skye spots Ray and Kwan. River looks up and recognizes them.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="50c8917d-5d36-438c-a858-0eb83db7d608">
      <Text>Skye</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="7a6e1897-db86-466d-b03c-acb5914e0e16">
      <Text>Welcome to planet peanut!</Text>
    </Paragraph>
    <Paragraph Type="Character" id="79a41286-44e0-49be-8c3d-7db180bd49f5">
      <Text>RIVER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="772436ea-f005-4624-9272-4334ed016a0a">
      <Text>The Canadians...</Text>
    </Paragraph>
    <Paragraph Type="Character" id="30b8b889-6adb-4244-9ede-02a0ae0c4d39">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="eca26361-2022-4784-a7c7-463458c6ca16">
      <Text>Skye mentioned cheap burgers here.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="f8621635-e0bb-499d-af2a-4f030791ed5d">
      <Text>Skye</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="3f0f9fcc-4676-4edf-a6cd-d14bcf6b0022">
      <Text>Please take a seat, unless you’re allergic to nuts </Text>
      <Text Style="Italic">like us</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="5aa91682-9609-491d-9c1d-461c4d7bb55c">
      <Text>Ray and Kwan sit. Kwan traces the deep grooves in the table.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="2fe88786-ede7-45f5-af25-2d8a82f767c5">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="c2e8b4fb-de52-4c53-9cbc-5024bb4c6911">
      <Text>Sorry about earlier. I’m just... an actor in transition.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="5e4a36cb-8114-4d2b-9578-36e7ccd029ba">
      <Text>RivER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="05704165-b0d2-49f9-9595-4f5773d96b4c">
      <Text>Wow. Actor-speak for “I set something on fire.”</Text>
    </Paragraph>
    <Paragraph Type="Character" id="e5b2ce47-041f-445d-8623-fee463fc52ef">
      <Text>RAY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="b71d1fa0-8c57-457d-bc89-02ac5d791b0d">
      <Text>You could say that... </Text>
      <Text Style="Italic">Sorry</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="36bed785-ae72-4c36-9778-659eeddd513c">
      <Text>Skye</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="c094dbc8-d5fc-4377-8a2c-e8c766080136">
      <Text>Multiple apologies? Now you’re really sounding Canadian.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="60594f7a-6160-475f-b549-abdeb85fe248">
      <Text>KwaN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="398a6586-cdbb-46a2-a1e2-56bfae8c1618">
      <Text>You sound familiar...</Text>
    </Paragraph>
    <Paragraph Type="Character" id="e063b385-df92-4776-adaf-5f259dc68350">
      <Text>River</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="b04359a9-35ae-4f76-9295-49156e4d1ec0">
      <Text>I voiced Stardust while Skye was the voice of the entire universe.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="6a58c1e7-e338-4108-a4e1-6438596a87fd">
      <Text>Ray &amp; Kwan</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="f163d35c-f1b4-400b-ac52-11242cd4dd03">
      <Text>Rocket? Rover? Robot? Satellite?</Text>
    </Paragraph>
    <Paragraph Type="Character" id="89fa05b2-fb4d-4f1c-97b6-ff8eefd25c43">
      <Text>Skye</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="cd6b7184-5e44-4a84-b50f-61d23d047674">
      <Text>Guilty on all counts. Though the credits say “Schuyler Park,” I’ve been deconstructing since then.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="f5d4e848-5259-4af7-9957-85aeb9dcf43e">
      <Text>Skye shows a side-by-side post on a phone: a male-presenting actor from 2006 versus their current vibrant non-binary self.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="49a20313-d86c-490f-a278-184438ab3dd5">
      <Text>Skye</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="16986dae-0b1b-4f19-9d5e-134711d98847">
      <Text>I’m not the only “special edition” here. You got the stuff?</Text>
    </Paragraph>
    <Paragraph Type="Action" id="d0020b84-51b9-4bcf-aaa1-349d9832e1d7">
      <Text>Ray sets the walkie-talkie on the table as a peace offering.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="22f423f1-e03a-403e-9f5d-1424632f728c">
      <Text>River</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="c605a6e0-a5ad-4b46-a619-44df3001e027">
      <Text>Wow... The Stardust Walkie-Talkie?</Text>
    </Paragraph>
    <Paragraph Type="Character" id="fe778324-72e1-495e-ae48-6777397e3071">
      <Text>SkyE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="6423079a-0d8d-48b4-a24e-dba9131bc06a">
      <Text>Only a handful ever manufactured. Rare as a solar eclipse.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="bf29ac7b-aea4-4188-9dde-ee1d1586693b">
      <Text>River</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="6bc4622d-9576-493f-8042-af9e7ac9df0d">
      <Text>None of the crew got one.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="17d3b0bf-de35-43ec-9d81-63336142b580">
      <Text>Skye</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="c0c2e3e6-ab14-46b3-8589-8eea3be5ef78">
      <Text>They threw every prop away.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="ebfcbe13-110b-4823-a544-35884d2dbfe8">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="578939e4-679a-436a-85d2-b0e3ab602eb3">
      <Text>My dad dumpster dives. He found it when the show ended and kept it, knowing how obsessed I was with your show. It’s been my north star.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="e9a49aa4-2eaa-40c0-b389-2df2f4b0c556">
      <Text>River puts the walkie-talkie to her face and wells up.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="06e1c292-5374-4ba7-9f21-b05083b3e5a8">
      <Text>RiVER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="6cc743b0-07c4-42ac-b118-31ab6c47da28">
      <Text>Well, “I’m super glad we’re forever buddies. Thanks for listening.”</Text>
    </Paragraph>
    <Paragraph Type="Character" id="33084a94-1c40-4396-ab30-40d067f4abd0">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="65019b3e-3166-4fc7-b748-e52fb155e1f5">
      <Text>My inner child cried watching Clay. </Text>
    </Paragraph>
    <Paragraph Type="Character" id="75e24566-abe7-4e05-a79e-bb9a5c6d7c20">
      <Text>Skye</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="6c8ee20b-75b9-462e-a8eb-02e54c52a4b7">
      <Text>Clay is proud of you. All of us.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="2167d86c-d207-4d09-a497-ba94016bc8a2">
      <Text>RaY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="370dd57f-c1ea-40a0-a24b-68ffb5c34177">
      <Text>It’s... so comforting. The way he talks to us like we’re still kids, like the world ain’t a dumpster fir-</Text>
    </Paragraph>
    <Paragraph Type="Character" id="c8b89c2a-0e6e-472c-8a9f-f8eef5193ba3">
      <Text>KwaN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="a0aa75a1-5bd4-4c02-b80e-d9e976149f64">
      <Text>I don’t understand the nostalgia.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="b79a04d7-e36c-4fce-a1dc-2b0c0bc4fbeb">
      <Text>RaY</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="9df1dc3b-af44-4301-bdbf-6468645e8765">
      <Text>(in Tagalog; subtitled)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="96c2a1b9-a186-4b31-8506-5ece7e61db2a">
      <Text>Shut up, Kwan.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="4e911f10-4bc2-4f34-bf8f-0c45cc16fc85">
      <Text>River</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="ece0afce-1527-4a82-a6d6-df2966a6de91">
      <Text>Tagalog?</Text>
    </Paragraph>
    <Paragraph Type="Character" id="5d394a3c-b45f-4fa5-bdc3-1ac87a7005f1">
      <Text>RAY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="5374a3c0-748c-4d68-8961-e9427321c57a">
      <Text>How’d ya know?</Text>
    </Paragraph>
    <Paragraph Type="Character" id="39a19835-86e5-478f-8389-74339d16daa8">
      <Text>RiVER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="bafd0d9e-74c5-405d-8f2c-ab52c57ff85c">
      <Text>Stardust is beloved in the Philippines. The studio provided some of the best translators.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="8722891a-2fdd-41c0-a8e8-e9ecf60d67a9">
      <Text>RaY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="d293a76d-db16-4f79-a59f-8f5228b92202">
      <Text>Is Titi the space beetle called Titi over there-?</Text>
    </Paragraph>
    <Paragraph Type="Character" id="54251ae8-5505-403d-b1a5-d64b9b13f743">
      <Text>RiVER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="cf723e40-78cf-4f43-805f-87514fa1ff49">
      <Text>Don’t get me started...</Text>
    </Paragraph>
    <Paragraph Type="Character" id="6e236169-f218-4897-9fbc-b147d66b8d32">
      <Text>KwAN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="6e0e3f1a-2a66-4e84-90f4-92bd499bc80f">
      <Text>Titi like in peni-</Text>
    </Paragraph>
    <Paragraph Type="Character" id="dff5a528-3fbf-4991-8431-815192ba7f78">
      <Text>River</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="4fd58be9-3128-4c55-9592-defac4d51be1">
      <Text>(in</Text>
      <Text Size="10"> </Text>
      <Text>bad</Text>
      <Text Size="10"> </Text>
      <Text>Tagalog;</Text>
      <Text Size="10"> </Text>
      <Text>subtitled)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="f494286e-8bb6-40a5-96df-b38c98e43956">
      <Text>I’m super glad we’re friends. Thanks for listening. I’ll take your menu- resume off your hands.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="ef0b7665-e8c0-4655-aa06-d655d0f0f9c2">
      <Text>Ray takes out the crumbled resume and hands it to River, feeling the weight of the moment. Her objective is done.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="12abd3be-70cc-49f2-959d-c1750d619de9">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="f64eb329-2317-4a66-8352-075b632c43aa">
      <Text>Well, bruh, time to get you crying once you see that video in the car.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="fd1964e7-a3a0-4a07-befb-8638e6dd5763">
      <Text>River</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="5ad288fd-a6c7-4370-81da-2b5254947e78">
      <Text>Get home safe cause... there will be a future for stardust like us.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="f28147db-7ef5-4167-875b-d81a1b239c9d">
      <Text>Ray looks puzzled. Is that a promise? River opens her arms.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="9d79c475-7510-4910-b3b3-97499fb63625">
      <Text>As Ray steps forward, her hand brushes the walkie-talkie. Her thumb finds the dial and switches it over to </Text>
      <Text Style="AllCaps">record</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="51274ae5-6a7c-477c-bbdf-00a913e340fa">
      <Text>RAY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="e497a875-eb6e-4504-8a79-179b039685ab">
      <Text>Looking forward to hearing more...</Text>
    </Paragraph>
    <Paragraph Type="Action" id="fb4cb628-c16d-4956-95e7-91d62532b94d">
      <Text>Ray sinks into the hug, holding the creator of her childhood to absorb some of that old magic. She smiles to the camera.</Text>
    </Paragraph>
    <Paragraph Type="Scene Heading" id="d1d50a89-a49e-4458-98b9-c88c8f35ddf3">
      <SceneProperties Length="3/8" Page="26" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="CLAY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="RAY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text Style="Bold+AllCaps">Int. Ray’s Car - MomentS LATER</Text>
    </Paragraph>
    <Paragraph Type="Action" id="7c663946-221b-4bb4-951a-5b6fae956cae">
      <Text>Ray drives through the dark streets. In the passenger seat, Kwan watches Clay’s message on her phone with teary eyes.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="b551088d-8866-4b37-80a4-ce06836ea7f1">
      <Text>CLAY (O.S.)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="df66aad8-99a1-4d11-b218-b3815e2df6c9">
      <Text>You look fabulous by the way. Whatever you’re doing, it’s working.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="aac06e6c-3941-4581-a6f2-0eea554852ba">
      <Text Style="Bold+Underline+AllCaps">Ray Talking Head</Text>
    </Paragraph>
    <Paragraph Type="Character" id="b9daa926-c527-4231-b457-052b337a3742">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="c449dcf9-5f5f-4703-a280-a6729df10a0a">
      <Text>I must get work soon...</Text>
    </Paragraph>
    <Paragraph Type="Scene Heading" id="269e2b51-6e11-4c72-ad2b-95b805c7d751">
      <SceneProperties Length="6/8" Page="27" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="RIVER">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="SKYE">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text Style="Bold+AllCaps">Int. Kwan’s Apartment - Night</Text>
    </Paragraph>
    <Paragraph Type="Action" id="9aa43a08-d6b4-4050-98dd-e435aeed85ca">
      <Text>Ray lies on the sofa, deep in her phone. She hesitates, then opens an app synced to the walkie-talkie. She taps </Text>
      <Text Style="AllCaps">play</Text>
      <Text>. The audio is layered with chatters and clatter of silverware.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="ed383739-7aa6-457b-9c4d-63ac2cfc977c">
      <Text>SkYE (V.O.)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="96eba855-c18e-4f14-900a-08bbce5c8fe4">
      <Text>The kids grew up. But even as adults, we’re still reaching them. You saw that girl’s face.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="4a0a8fcd-7c0c-4dda-a99a-2a45dcba0dbb">
      <Text>River (V.O.)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="67888961-08bc-43b0-89a5-98296734898a">
      <Text>And we’ll be reaching the next generation, too. Don’t you worry about that.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="7d7ab98c-6158-4dae-9b71-c2f5e162e22f">
      <Text>SkYE (V.O.)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="38766aa9-508d-4298-ac50-4d84ddb3d4d0">
      <Text>Wait— Are you pitching a new show?</Text>
    </Paragraph>
    <Paragraph Type="Character" id="faa77399-1ff4-41fa-a8d0-e78a2e0f02ab">
      <Text>RiVER (V.O.)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="cc49a081-3088-4a09-9f11-b1797baa3dc5">
      <Text>I’m not pitching anything. Don’t need to, cause ours worked.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="d7a5ab92-22a2-47a5-9b35-e639f497306b">
      <Text>SkYE (V.O.)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="5aabf05b-41d7-4245-ba53-cf7a34f6a8cb">
      <Text>Wait, so- We’re in the green?</Text>
    </Paragraph>
    <Paragraph Type="Character" id="2668d376-837e-45cc-92f8-3ed66c8a864e">
      <Text>RIVER (V.O.)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="7edb4c0f-2e3e-47b2-abf6-6b2a8ddbcbaa">
      <Text>Green as Mother Nature! Got the call today. The network gave us the greenlight. We’re doing it, Skye. A full revival of </Text>
      <Text Style="Italic">Stardust</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="0aa6e50e-6a9e-4a2a-bf1d-9d8a6d631a74">
      <Text>Ray gives a hopeful look to the camera.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="27ef10cf-2245-4348-a349-02b23dec5a1d">
      <Text>SkYE (V.O.)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="7c9b611a-3270-4888-9cfe-392039511815">
      <Text>So our autograph tour will not have been in vain.</Text>
    </Paragraph>
    <Paragraph Type="Scene Heading" id="269e2b51-6e11-4c72-ad2b-95b805c7d751">
      <SceneProperties Length="6/8" Page="27" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="RIVER">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="SKYE">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text Style="Bold+AllCaps">Int. The Peanut Barrel - Night (Flashback)</Text>
    </Paragraph>
    <Paragraph Type="Action" id="05f89c99-e42a-49d7-a4eb-c23f1bdff3d4">
      <Text>River throws her arms out with joy finally breaking through.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="35962260-2526-4a10-a797-1da8f59e1689">
      <Text>SKYE</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="b6f65aa5-7954-4c79-b58c-5dd7018d2dde">
      <Text>(Sadly)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="5af55dcb-5e80-42eb-995d-57f2af332b43">
      <Text>But my heart...</Text>
    </Paragraph>
    <Paragraph Type="Character" id="75d95930-d023-4112-aa87-110366cca12b">
      <Text>RiVER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="3a6033d8-8590-4e93-8380-4e3aee8e749b">
      <Text>You don’t seem excited?</Text>
    </Paragraph>
    <Paragraph Type="Character" id="a6fb40e2-c501-467c-b27e-c506f8baa816">
      <Text>SkYE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="69fc31fa-a9a3-4292-991c-85c16eb1a98e">
      <Text>It don’t matter if I am. Would Clay be?</Text>
    </Paragraph>
    <Paragraph Type="Action" id="ce8ce4ac-4572-4ada-a466-8d3c89f6dc28">
      <Text>The name hangs in the air like a cold front. River’s smile thins. She picks up a peanut and snaps the shell. </Text>
      <Text Style="AllCaps">Crack</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="386e7e88-5817-4637-a997-fe9648709d83">
      <Text>RiVER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="4eb5e0ac-30d0-481c-9aa7-3402c6b3b06e">
      <Text>We’re not asking Clay back.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="c79eee75-225b-454d-bfef-da5bc16f1ba4">
      <Text>She grabs a bag of peanuts and spills them across her plate.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="07723a29-f5f2-4e6a-ab9a-e8556d7929cc">
      <Text>SkYE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="789ee715-1751-4db9-83c0-d9e493d8c2d2">
      <Text>In 1999, we found Clay after a hundred auditions. This revival? It’ll be in the thousands.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="7fbfa379-a6e9-4922-9fd6-f36df86b4fdf">
      <Text>River</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="390a99d1-218b-4f2a-8c60-67bff29a0b52">
      <Text>And so we’ll sift through them all until we find the perfect peanut.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="38e1a125-f0cb-4010-bf8e-1a3186e7e058">
      <Text>River picks through the pile and holds up a flawless peanut.</Text>
    </Paragraph>
    <Paragraph Type="Transition" id="3fbcb9fe-1be6-45c0-905a-5f20fead280b">
      <Text>Dissolve to:</Text>
    </Paragraph>
    <Paragraph Type="Scene Heading" id="2e197cba-7e2c-4484-abb3-0b9f01ef6da3">
      <SceneProperties Length="4/8" Page="28" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="RAY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="RIVER">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="SKYE">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text Style="Bold+AllCaps">Int. Kwan'S APARTMENT - ConTINUOUS</Text>
    </Paragraph>
    <Paragraph Type="Action" id="9653f0da-dc0e-4e5e-9b51-862fbcdf0310">
      <Text>Ray sits upright, her eyes lighting up with a surge of hope.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="9446a3f2-71fe-4b8d-ad8d-919559edcde8">
      <Text>SkYE (V.O.)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="1c6c5715-af3c-490f-a20f-e6b9a139f07d">
      <Text>Actually, I think we just met our perfect candidate.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="0b8557bb-2b6e-40c9-b604-ee59d19ed1f5">
      <Text>River (V.O.)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="6cac7c1b-ad36-4516-9a2f-da0cc3ccf175">
      <Text>Nonsense. She’s completely unprofessional. The kids said it themselves. They don’t trust her.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="cef4be4f-1e6c-4c40-9415-aad2a6ffe7b6">
      <Text>The light dies in Ray’s eyes. She stares coldly at the camera. She slumps back, deflated.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="281c03ef-83a1-4108-9200-b58ff4405853">
      <Text>Skye (V.O.)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="d2716a8d-76c3-4668-b4c4-79261506428a">
      <Text>Don't write her off. Check out her channel first, “Plasma Facts.”</Text>
    </Paragraph>
    <Paragraph Type="Character" id="4ed62142-27a9-43dc-99fa-a778949f9e88">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="e252f41a-5ff1-42be-95ae-6f546d95f72b">
      <Text>“Plasma with the Facts.”</Text>
    </Paragraph>
    <Paragraph Type="Character" id="6ffe2fdc-8e8c-4217-b05f-2a65543ef85e">
      <Text>RiVER (V.O.)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="9df5dd0a-a7de-49c1-a4c6-02f556dcb947">
      <Text>I’ll deal with it in the morning. Based on her portfolio, Ray’s got </Text>
      <Text Style="Italic">Cat Scouts</Text>
      <Text> to fall back to.</Text>
    </Paragraph>
    <Paragraph Type="Scene Heading" id="2e14b9e4-f804-429a-9716-5529b9e32374">
      <SceneProperties Length="2/8" Page="29" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="SKYE">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text Style="Bold+AllCaps">Int. The PeanUT BARREL - Night (Flashback)</Text>
    </Paragraph>
    <Paragraph Type="Action" id="e5800021-da60-483a-aaf6-5aa392a9494b">
      <Text>River sets the walkie-talkie onto her empty plate. She lays Ray’s resume on top.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="57748337-93a7-442e-9a6c-fb3866d2855d">
      <Text>Skye</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="a4e46d9d-fe6c-4062-bd45-dd7602120d0b">
      <Text>You don’t want the walkie-talkie?</Text>
    </Paragraph>
    <Paragraph Type="Action" id="26a1eb6a-506d-4492-b57d-3f23386fe2d1">
      <Text>River and Skye stand to leave. A waiter swoops in, clearing the check, dishes, and the toy.</Text>
    </Paragraph>
    <Paragraph Type="Scene Heading" id="d0fe1a09-444e-4f9b-a131-435795e3ac77">
      <SceneProperties Length="3/8" Page="29" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="RAY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="RIVER">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text Style="Bold+AllCaps">Int. Kwan’s Apartment - ConTINUOUS</Text>
    </Paragraph>
    <Paragraph Type="Action" id="d56e688d-28bf-452c-ade2-4d077453345a">
      <Text>Ray stares at the phone with a look of pure betrayal crossing her face.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="3578044e-268a-4cf5-9f80-c849fc325968">
      <Text>River (V.O.)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="448276e2-9d5c-4ac4-a103-8b1ecfbb4028">
      <Text>It was a lovely gesture. But I’m done with this past.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="ab5b5181-ab71-4841-9d09-fc18106cc0bd">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="d5a527e6-e3ff-4a66-9fd3-09a633f7012e">
      <Text>Then why the hell are you bringing the show back?</Text>
    </Paragraph>
    <Paragraph Type="Action" id="42d784f5-25d4-4c91-a107-ff0c0a9abf97">
      <Text>Ray pauses the recording. She sits in the silence of the dark room for a moment before collapsing onto the sofa.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="7fcb8492-d71a-494d-8cfd-00d7bfea9257">
      <Text>As she closes her eyes, the flatscreen TV transforms. The wide display shrinks into a 4:3 frame. Ray stands, moving towards the light, and steps through the glass.</Text>
    </Paragraph>
    <Paragraph Type="Scene Heading" id="8496ff4c-32e4-40f5-ab75-3d547697cbeb">
      <SceneProperties Length="1 3/8" Page="29" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="KIDS">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="RAY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="RIVER">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text Style="Bold+AllCaps">Int. The Cosmos - ContINUOUS</Text>
    </Paragraph>
    <Paragraph Type="Action" id="34135a0e-905b-4ab6-938c-be85c716823f">
      <Text>Ray floats in a indigo-violet void, wearing a cosmic flight suit. Stardust streaks around her, leaving a glittering wake.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="91571a85-e976-42cb-8c69-2a271aa97ead">
      <Text>Ray looks into the camera. Her warm smile is unnerving. When she speaks, her voice is melodic and high-pitched, perfectly tuned for a toddler audience.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="b30c81ee-5461-4ca7-9f09-0f8647224fb4">
      <Text>RAY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="63a91bd0-76b6-405a-8d64-0dfc87932da0">
      <Text>Hi, </Text>
      <Text AdornmentStyle="-1">stardusters</Text>
      <Text>! Did you see that? Stardust just did a loop-de-loop! She’s just so excited to see you.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="c85cc6f5-4a44-44c2-a882-7ecfb10aa07a">
      <Text>THUMP </Text>
      <Text AdornmentStyle="-1">THUMP</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">THUMP</Text>
      <Text>. The sentient ROCKET drifts into view. The hatch hisses open, and Ray glides into the captain’s chair.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="85908c14-ec3b-4766-8e84-28ca62c5d5e0">
      <Text>On the console, a subscriber counter spins wildly, the numbers climbing into the millions like a jackpot.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="893b0bff-66fa-4b37-8e5d-5ebf8f45442f">
      <Text>RAY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="a7ee3fa9-b6dc-4936-b8f2-d761fda6adf7">
      <Text>Do you feel that? That little spark in your heart? That’s called...?</Text>
    </Paragraph>
    <Paragraph Type="Character" id="e1adf478-23a9-44fe-8042-d64b6c9834df">
      <Text>Kids</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="57923fea-6076-4f85-841b-a392f81ccc82">
      <Text>Potential!</Text>
    </Paragraph>
    <Paragraph Type="Character" id="9bc0e9e7-0c29-4954-8e1e-bc54ff15f042">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="af50cb32-b867-4589-b1a6-707c8d082d95">
      <Text>Kinetic energy?</Text>
    </Paragraph>
    <Paragraph Type="Character" id="5b99c9b0-618c-4375-a9ca-debb5c83a807">
      <Text>KidS</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="1be91f3f-c37a-4f89-8be5-8f28ca911ed8">
      <Text>Potential! Potential! Potential!</Text>
    </Paragraph>
    <Paragraph Type="Character" id="83c07857-0e3a-4a42-b448-2bcf3d8e5525">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="a7ee3fa9-b6dc-4936-b8f2-d761fda6adf7">
      <Text>Potential. Sometimes, life feels heavy... like a big, old rock. That’s a solid! But when we add a little wonder...</Text>
    </Paragraph>
    <Paragraph Type="Action" id="dff38cd9-3d80-48e7-b3e1-bf88475c87c8">
      <Text>She taps a holographic display. It explodes into a nebula.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="2dbdc851-c71d-444c-9eda-80fdd10e0e77">
      <Text>RAY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="d6423f84-572a-4f5b-ae09-bf8af26f8630">
      <Text>...it becomes a gas! It goes everywhere. Just like us. Today, we’re exploring the Fourth State. Can you say “Plasma”?</Text>
    </Paragraph>
    <Paragraph Type="Action" id="d545eb0c-83a2-492f-bc0c-d7c2d3f8d003">
      <Text>The cosmic light flickers. A giant, nightmarish </Text>
      <Text Style="AllCaps">Colonel Calico</Text>
      <Text> puppet looms in the void, its polyester fur beginning to smoke. River’s distorted voice booms through the stars:</Text>
    </Paragraph>
    <Paragraph Type="Character" id="4630ca05-3b87-4739-bd88-e43c6809bc22">
      <Text>RIVER (V.O.)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="b83c56f8-4f6d-44bd-ab0d-08ec2b729fc4">
      <Text>...Unprofessional... Done with this past...</Text>
    </Paragraph>
    <Paragraph Type="Action" id="dc1931e3-8600-407a-9303-ee907db8ef20">
      <Text>Ray’s smile does not waver. She does not even blink. She reaches out and grabs the stardust walkie-talkie. She speaks into it with terrifying, cheery poise.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="3629f103-dfe2-48c9-b9c4-5dfe021ac821">
      <Text>RAY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="6e341be7-da98-4614-ad86-8010e0fa3a22">
      <Text>Oh, River! I think someone forgot their listening ears! In this galaxy, we don't throw friends away. We recycle them.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="c9ccafd9-a705-4a5a-af65-e9e17a314e87">
      <Text>The flaming cat puppet vanishes into a cloud of sparkling stardust. Ray leans forward until her face fills the frame, appearing on a billion imaginary screens at once.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="8d974ab9-4ca8-4d13-8c95-010e8b9b2556">
      <Text>RAY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="a3dd9ad4-8b97-4d38-a65f-39ab886fc669">
      <Text>This is Ray, your host. And I’m never going to leave you. Are you ready to explore?</Text>
    </Paragraph>
    <Paragraph Type="Transition" id="b4afbec5-cc01-4326-8742-ecdb9ba90deb">
      <Text>DISSOLVE TO:</Text>
    </Paragraph>
    <Paragraph Type="Scene Heading" id="84f05ddc-b5c7-45fc-86d8-a91d54bbab2b">
      <SceneProperties Length="1 1/8" Page="31" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="AURORA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="RAY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text Style="Bold+AllCaps">INT. KWAN’S APARTMENT - Morning</Text>
    </Paragraph>
    <Paragraph Type="Action" id="cdef2235-5341-4aab-a9cf-8feb01ea16ce">
      <Text>Ray bolts upright on the sofa, gasping as the remnants of her fever dream linger.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="b3adc480-6bd9-42fa-99f5-7d6ca98f1978">
      <Text>RaY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="051192e8-64e4-43c3-a412-22de7a633329">
      <Text>I’m ready to explore...</Text>
    </Paragraph>
    <Paragraph Type="Action" id="6b971f1a-4373-4a1a-8cf8-6b5e5528364c">
      <Text>Later, Ray sits with her laptop. On her phone, the recording of River plays one last time: “She seems unprofessional.” Ray winces, looking down at her breakfast: a snack wrap.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="92929333-620b-4de4-8162-e2ea9767f50a">
      <Text>RAY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="b00e9702-48c0-47bf-b129-cbab53c43518">
      <Text>Unprofessional? I’ll show you professional.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="0462c3f3-0eb3-4a83-aa05-af115f645205">
      <Text>She cracks her knuckles and opens her video channel. The “Plasma with the Facts” stats stare back: a measly few hundred subscribers.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="02e8b57a-16b6-4685-b58a-319b08c21b9b">
      <Text>Montage:</Text>
    </Paragraph>
    <Paragraph Type="Action" id="91f880ad-19fe-4ff6-8630-d834aafe38be">
      <Text>- Ray’s mouse darts across the screen as she sets her more chaotic videos to private: “Cat Scouts is a cult,” “Canada is a nightmare,” and “We are all puppets.”</Text>
    </Paragraph>
    <Paragraph Type="Action" id="1614a56c-b59a-42f9-b7fd-232f008e4f29">
      <Text>- She deletes her bio: “Actor looking for a (big) break. I like stars and snacks.”</Text>
    </Paragraph>
    <Paragraph Type="Action" id="2eab1cdd-1463-480b-9ace-8691f496a97e">
      <Text>- She types: “An award-winning science communicator dedicated to making the world understandable for all.”</Text>
    </Paragraph>
    <Paragraph Type="Action" id="eb0c9640-0f47-40bf-b25a-81903fa0f650">
      <Text>- She drags Kwan’s sleek planetarium animation into her channel banner and swaps her profile picture for a beach photo she ran through an AI generator with the prompt: “Make her look more like Mr. Rogers.”</Text>
    </Paragraph>
    <Paragraph Type="Action" id="44478bbb-f3b7-48e7-87b0-a7476832a837">
      <Text>- She toggles her contact email to "visible."</Text>
    </Paragraph>
    <Paragraph Type="Action" id="76236f85-d073-4908-9042-0eb998dc8591">
      <Text>End Montage</Text>
    </Paragraph>
    <Paragraph Type="Action" id="8126179f-4f6e-4bf8-b88c-a48081b946fb">
      <Text>In the sidebar, a thumbnail for her rival, Ms. Aurora (29), catches her eye. Ray clicks.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="e1d40ff7-23ef-42fc-bb7c-64d82852bb7a">
      <Text Style="Bold+AllCaps">On the screen:</Text>
      <Text> Ms. Aurora wears a dazzling lab coat, holding a beaker of colorful liquid. Her smile is perfect white.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="7f23671f-7fa4-4a4a-9ec6-16fe185f59fa">
      <Text>Aurora</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="fbc24c94-5afc-41e4-85c9-6265d964f281">
      <Text>Hey, my little </Text>
      <Text AdornmentStyle="-1">novas</Text>
      <Text>! Ready for a stellar day of discovery? Today, we’re talking about “Adhesion.” That’s a big word for sticking together. Just like we’ll be!</Text>
    </Paragraph>
    <Paragraph Type="Action" id="952c8c9e-b6cd-40c9-a0db-2c95716bd2b0">
      <Text>Aurora blows a handful of bio-degradable glitter at the camera. A digital graphic of a smiling sun pops up with a “ding!” Ray’s eyes track the view count: 4.2 Million.</Text>
    </Paragraph>
    <Paragraph Type="Scene Heading" id="7290c86d-c1b3-4299-b783-a02c00c123a6">
      <SceneProperties Length="2/8" Page="32" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="RAY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text Style="Bold+AllCaps">Back to the room - Continuous</Text>
    </Paragraph>
    <Paragraph Type="Action" id="6094f55e-5a90-45f3-ba55-d340f0224f28">
      <Text>Ray stares at the screen. Aurora is everything Ray is trying to be: polished, profitable, and perfectly safe.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="2d74cbd0-1e3c-4902-8287-5e6257cd6cc5">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="5e345232-c32f-481f-83af-bb37ed8d8d3d">
      <Text>You’re a glue stick, Aurora.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="976eb871-3187-4c84-aaee-d19065a65cd0">
      <Text>She scrolls to the comments: “My toddler won't stop watching!” and “If Mr. Rogers and Clay from Stardust Stuff had a kid, this would be her!”</Text>
    </Paragraph>
    <Paragraph Type="Scene Heading" id="9cd576fe-2da3-4848-a9a6-1f77647431a1">
      <SceneProperties Length="5/8" Page="32" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="AURORA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="RAY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="STARDUST">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text Style="Bold+AllCaps">Int. Ray’s Mind - ConTINUOUS</Text>
    </Paragraph>
    <Paragraph Type="Action" id="96901904-ba9e-409e-940c-2f8f4a39c892">
      <Text Style="Bold+AllCaps">On the screen:</Text>
      <Text> Ms. Aurora, wearing the iconic cosmic vest, hosts the Stardust Stuff revival. Stardust zips around her.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="120edbb3-146a-4511-ad3b-dfb8d489124f">
      <Text>She performs a flawless demonstration of molecular adhesion using two pieces of polished glass and a drop of water.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="fa3571ae-eaec-4787-ae3e-fead1fcf434f">
      <Text>Aurora</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="01182c5a-4184-40c2-8294-4e07393d2570">
      <Text>See these two slides? They’re perfectly smooth. On their own, they’re just individuals. But add one tiny drop of water, one moment of shared wonder, and the hydrogen bonds create a suction so strong you cannot pull them apart. That’s adhesion, explorers.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="4f834b30-f608-40c5-ba68-6fe983c3b04e">
      <Text>Stardust</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="03e43662-ff28-4431-9adc-949f93bd6987">
      <Text>Twinkle, twinkle, twinkle...</Text>
    </Paragraph>
    <Paragraph Type="Character" id="d62ccd0d-d88b-4fe1-8735-4bc2054b32b7">
      <Text>AurORA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="edc0cdd6-2c4d-4bb2-93a7-d3e15f97f1f1">
      <Text>Right you are, Stardust. It’s the universe’s way of telling us we’re stronger when we stick together.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="73b1d888-5c8c-4900-b687-063697a26ca0">
      <Text>Ray (V.O.)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="b774fc9e-81a5-42b1-a787-680c61c2433c">
      <Text>Ugh... She’s </Text>
      <Text AdornmentStyle="-1">freakin</Text>
      <Text>’ perfect...</Text>
    </Paragraph>
    <Paragraph Type="Scene Heading" id="824d1893-9879-46aa-a4e3-17fb75e198af">
      <SceneProperties Length="1/8" Page="33" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="KWAN">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text Style="Bold+AllCaps">Back to the room - Continuous</Text>
    </Paragraph>
    <Paragraph Type="Action" id="96901904-ba9e-409e-940c-2f8f4a39c892">
      <Text>Everyone is cheering around the TV screen, especially Kwan.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="cfa98dde-53eb-45ae-827e-fda681b63ca9">
      <Text>KwaN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="8766a0d9-0bd5-4823-9288-1d6d8a078517">
      <Text>Ms. Aurora!</Text>
    </Paragraph>
    <Paragraph Type="Scene Heading" id="5b260204-9090-47f2-9302-dc295e6eb6fd">
      <SceneProperties Length="7/8" Page="33" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="KWAN">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="RAY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text Style="Bold+AllCaps">Int. Kwan’s APARTMENT - ConTINUOUS</Text>
    </Paragraph>
    <Paragraph Type="Character" id="f5020b74-f9e0-4655-9985-166bcc8dd417">
      <Text>Kwan</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="f08ebec3-c690-4c20-97fb-b649d68f5f5d">
      <Text>I was her eightieth subscriber. I love her “Fun Fact” segments.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="c43c570a-4f9c-40e0-b62b-1dc2933b7de9">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="d8489271-ba7e-4d5b-8dcb-6578f685541f">
      <Text>Wanna hear a fun fact? She auditioned for the voice of Tabby on Cat Scouts. And you know who actually got the part...</Text>
    </Paragraph>
    <Paragraph Type="Character" id="b32d98cb-a78a-46e1-9a45-3441fa0992dc">
      <Text>KwaN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="b697d115-ea7c-40a4-bdef-5e9052c5b09c">
      <Text>Ah. Well, Ms. Aurora’s voice doesn’t make me lose my mind quite like yours does.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="2a08d79f-e2bc-4e97-a606-8f7c556a329a">
      <Text>RAY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="86c31711-fb1d-4eef-b087-83effd233391">
      <Text>Shut up, you dumb brat.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="462a1baf-9aaa-42a9-b6f3-07ae2e173a55">
      <Text>KwaN</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="6f794fbe-4693-4263-a728-24be3d702b9e">
      <Text>(Heading for the door)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="7d94cea7-e635-46c0-8a52-d0a3885ac433">
      <Text>Whatever show you end up hosting, that should be your catchphrase.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="4fcbb56a-a962-4eb7-9f76-32269c1dc717">
      <Text>Kwan exits the apartment.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="3ca79716-28cb-4d79-86e8-a6ecaf23b294">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="72553f58-efba-4da3-a80f-4cf1808a3c76">
      <Text>I have a show! “Plasma with the Facts!”</Text>
    </Paragraph>
    <Paragraph Type="Character" id="e1995f74-a317-412c-bd5d-9ab134224b15">
      <Text>KwaN (O.S.)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="1bf2e698-3225-4c41-a07e-dd998c7eb71e">
      <Text>Fun fact: it needs a ton of work.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="7e85c672-e39e-4f4b-add6-587a5cc70585">
      <Text>RaY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="242e5fcb-7ff8-4624-82ee-659e4a580125">
      <Text>No matter... We’re all peanuts in this audition. River has seen me more than she’s seen you, Ms. A.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="0378638c-4cd3-4d36-a3ba-542132aeca31">
      <Text>On the screen, a “+1” graphic floats above Ms. Aurora’s subscriber count.</Text>
    </Paragraph>
    <Paragraph Type="Scene Heading" id="1eec999f-ec19-4061-a2f0-636ce9ab1404">
      <SceneProperties Length="3/8" Page="33" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="RIVER">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="SKYE">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text Style="Bold+AllCaps">Int. Cafe - Same Time</Text>
    </Paragraph>
    <Paragraph Type="Action" id="036459c2-910b-4620-a09c-a1e2603ccddb">
      <Text>On a laptop screen, a cursor clicks “subscribed” on Ms. Aurora’s channel. River sits across from Skye.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="b7c132cb-93da-4284-98bf-581b20ea2c25">
      <Text>River</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="6925b286-bee0-40f8-8fda-65214b320763">
      <Text>Skye, thanks for suggesting “Plasma with the Facts.” That rabbit hole actually led me to a real gem.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="c0401023-8cac-4dac-b5ab-b31536dd1426">
      <Text>River turns the laptop towards Skye. On the screen, Ms. Aurora performs a science demonstration.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="6c79e761-aa10-403f-bbd1-6c809b1f7107">
      <Text>SkYE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="e9913d9a-855c-4e0f-a80c-184a0219c424">
      <Text>Ms. Aurora, huh? Let’s see if we can find her contact info.</Text>
    </Paragraph>
    <Paragraph Type="Scene Heading" id="b973ad23-f6c0-4bc1-a6df-270dbe125393">
      <SceneProperties Length="1/8" Page="34" Title="">
        <SceneArcBeats/>
      </SceneProperties>
      <Text Style="Bold+AllCaps">Int. The PeaNUT BARREL - Day</Text>
    </Paragraph>
    <Paragraph Type="Action" id="2e2bd5c8-816b-4f6c-908d-69c7ee103feb">
      <Text>Ray approaches the counter. After a brief word with the cashier, they hand over the walkie-talkie to her.</Text>
    </Paragraph>
    <Paragraph Type="Scene Heading" id="8b0eebf4-fa97-4bc2-878a-3510aa568730">
      <SceneProperties Length="7/8" Page="34" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="AURORA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="KWAN">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="RAY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text Style="Bold+AllCaps">Int. Kwan’s Apartment - Evening</Text>
    </Paragraph>
    <Paragraph Type="Action" id="cfc8d873-c663-4834-94c2-46c899882c7d">
      <Text>Ray hunches over her laptop, watching tutorial videos on recording professional self-tapes. Kwan enters.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="f0972ad8-bd3e-454f-a7c8-a9f951985680">
      <Text>Kwan</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="2196d839-5b87-4f8b-b05f-a23a5ff3c3a2">
      <Text>Watcha watching?</Text>
    </Paragraph>
    <Paragraph Type="Character" id="9bd2d3ee-66f4-47a7-a8cb-8893b736ed22">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="d177faed-1398-45a2-8798-73968d68264d">
      <Text>Self-tape tutorials.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="2ee21745-953c-49fe-81ba-80ababf19bdd">
      <Text>KwAN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="bd05211f-0363-460b-b983-4679b6278b9f">
      <Text>Don’t you act professionally?</Text>
    </Paragraph>
    <Paragraph Type="Character" id="9d1e23c1-bc47-493c-a301-bb2f749812d8">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="02ceb547-a672-4525-b650-dbcb448e17a1">
      <Text>I’m used to in-person auditions. I need to prepare myself if they ask for self-tapes from thousands.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="c82f5807-fb8d-4186-a1cf-92d63f146dbe">
      <Text>KwAN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="f0581a36-4f70-476c-a809-043dfbd0baac">
      <Text>Well, I wanted to show you this in person...</Text>
    </Paragraph>
    <Paragraph Type="Action" id="5022796e-2580-4f0c-bc7b-070dacd87711">
      <Text>Kwan takes the laptop and pulls up Ms. Aurora’s latest upload: “New Stuff from Stardust.”</Text>
    </Paragraph>
    <Paragraph Type="Action" id="e77df72e-7574-464c-81ff-1d8c56358cc0">
      <Text Style="Bold+AllCaps">On the screen:</Text>
      <Text> Ms. Aurora walks out of a local library, filming herself.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="497fce60-0279-4afb-9e9e-ed5b8e6d4c45">
      <Text>Aurora</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="5c9e2ec7-7107-4d8b-b97b-b7dc87a34f0b">
      <Text>Hello, Supernovas. Support your local libraries. I just got a surprise call from... Well, you know who...</Text>
    </Paragraph>
    <Paragraph Type="Action" id="d78b1346-2110-41a5-b603-d50f1b655e1c">
      <Text>Aurora does a perfect Stardust impression.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="c4029197-4d99-4716-a38a-cddd6f4da84c">
      <Text>Aurora</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="bb27e275-710d-4c01-9c50-abec13fab5c2">
      <Text>Twinkle, twinkle, twinkle! You’ve guessed it! The voice behind your childhood. I can’t say much yet, NDAs and all, to my loyal fans... the future is us. Stars are us!</Text>
    </Paragraph>
    <Paragraph Type="Action" id="53b1dbfb-ba2c-459b-a51e-463ad8ed3591">
      <Text>The video cuts to black.</Text>
    </Paragraph>
    <Paragraph Type="Scene Heading" id="532cf24c-ec22-49d6-9073-0e4af629ba77">
      <SceneProperties Length="1 5/8" Page="35" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="CLAY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="KWAN">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="RAY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text Style="Bold+AllCaps">Back to the room - ContinUOUS</Text>
    </Paragraph>
    <Paragraph Type="Character" id="73079957-48ed-4428-8575-5aa18c7ae38d">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="1f9c078c-c37d-434a-b18b-4f79d9443248">
      <Text>They’re not even entertaining auditions?! They just picked her?!</Text>
    </Paragraph>
    <Paragraph Type="Character" id="756cdcb8-5f87-4b68-9cc7-35db296c1b82">
      <Text>KwAN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="0febb661-5236-4e98-935d-cbebd1712ff0">
      <Text>I’m sorry, Ray. Look at the bright side: at least you don't have to wait around to be rejected.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="57ff7ffa-a38f-4e7c-8ba5-54da0eb05133">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="f457ec30-4ebe-45e7-9c64-18e740760aa4">
      <Text>Bruh, try using some of that astronomy wisdom for kindness once in a while.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="010b0395-22b0-41a0-b363-475bbedb3719">
      <Text>KwAN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="8a8f9628-9484-4327-80d1-1ffd57e354ce">
      <Text>Here’s some wisdom: Clay quit. You won't.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="161a2364-3013-49b0-ba01-d6e2a48a37f2">
      <Text>Kwan heads to his room.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="00bdef35-f3d2-4da1-85c5-d030bd08d078">
      <Text Style="Bold+Underline+AllCaps">Ray Talking Head</Text>
    </Paragraph>
    <Paragraph Type="Character" id="5ca5a0de-3c53-4221-acb4-46dfceed8d1b">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="aea7f83a-572b-4719-96ec-806752d4a004">
      <Text>You’re right... cause I don’t know how to quit.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="e3f10102-13fe-41eb-9848-d81c4ff036d7">
      <Text Style="Bold+AllCaps">As we were</Text>
    </Paragraph>
    <Paragraph Type="Action" id="d40459f1-8ebf-4b9c-a03c-a6ed1e9c9533">
      <Text>Ray grabs her phone and calls her father.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="95b5594d-955e-4baa-a923-cf31a3ddb304">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="9df1dc3b-af44-4301-bdbf-6468645e8765">
      <Text>(in Tagalog; subtitled)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="11042e5f-b441-46f7-9673-12949dd75fb9">
      <Text>Hey dad... You know, Kwan and I, we never have a good time. We have a great time... Remember that stuff you found in a dumpster? Which one? The one where you found the walkie-talkie... Besides that, what else did you find...? Folders? You kept those? Do they have phone numbers? Any phone number from Clay...? Kay. You see the name, Billy Clayton Dubois... That’s got to be him. No, I’m not trying to go out with him. I just need some advice... Yeah, your advice is more than enough, dad... Alright, text me his number.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="be82d39a-c29c-4bb9-80fc-4d9668f5e44e">
      <Text Style="Bold+Underline+AllCaps">Ray Talking Head</Text>
    </Paragraph>
    <Paragraph Type="Character" id="b13dd677-49b6-4935-8f06-cf013b9a7230">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="67e54690-850e-4407-9911-2b3489efeb04">
      <Text>I’ve never been so glad to have a trashy father.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="3d87433e-fbd3-477f-84c0-435f9e27f624">
      <Text>Kwan (O.S.)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="2eae636b-9dd9-49a6-9bb2-d5bd7ba082ea">
      <Text>Don’t call our dad trashy!</Text>
    </Paragraph>
    <Paragraph Type="Character" id="6eb9b314-7370-4832-ab04-45dc762f5a46">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="18eb929f-a224-489d-b2b1-e7925124d423">
      <Text>Don’t worry. I didn’t forget to call you trashy too!</Text>
    </Paragraph>
    <Paragraph Type="Action" id="7efda623-d942-4c4c-b08b-04b1db37a6a5">
      <Text Style="Bold+AllCaps">As we were</Text>
    </Paragraph>
    <Paragraph Type="Action" id="0132003f-ebae-401a-b37f-746e983ab4d9">
      <Text>Her phone pings. She dials the number immediately.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="85081ff8-77dc-401c-b839-25de1572f268">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="cb4c91c7-a608-4188-bb83-4590f1f81af3">
      <Text>Clay?</Text>
    </Paragraph>
    <Paragraph Type="Character" id="1e0a5950-adad-4ab2-ae6d-e8cee81dbdc0">
      <Text>Clay (V.O.)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="02535460-7527-4d22-9637-7a7090a04624">
      <Text>No one says Clay?! Go away!</Text>
    </Paragraph>
    <Paragraph Type="Action" id="cf714e39-6629-40c7-96ea-4e84b815c899">
      <Text>The phone hangs up.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="ec2c80c9-9643-4c88-a2f0-862ad8d3e184">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="41e30d5a-7bd7-4afb-a6a2-26e887cd8d76">
      <Text>This is not the Clay I know...</Text>
    </Paragraph>
    <Paragraph Type="Action" id="3fff6846-ffde-4ae2-a972-8387753e2256">
      <Text>Ray tries calling back, but it goes straight to voicemail. Determined, she marches towards Kwan’s bedroom.</Text>
    </Paragraph>
    <Paragraph Type="Scene Heading" id="67375d66-2061-4d9d-b14b-8638ca31fa7b">
      <SceneProperties Length="2/8" Page="36" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="KWAN">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="RAY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text Style="Bold+AllCaps">Int. Kwan’s Bedroom - ConTINUOUS</Text>
    </Paragraph>
    <Paragraph Type="Action" id="c5006613-5aaf-40c0-96e2-9c8aa48cdf4c">
      <Text>Kwan sits at his desk, mesmerized by a star mapping software on his monitor. His phone sits within reach.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="6404e260-31a7-4dad-8962-b301ff6b9d57">
      <Text>RaY (O.S.)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="41e30d5a-7bd7-4afb-a6a2-26e887cd8d76">
      <Text>Kwan, can I borrow your phone?</Text>
    </Paragraph>
    <Paragraph Type="Character" id="82f7300a-b8f7-4628-9e9c-681acf3d17fa">
      <Text>KwaN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="6d84b733-e03d-4292-a24e-d3375dc7ae5c">
      <Text>Nope.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="95910fb2-fbc7-40ed-8ee9-92bacf39b38e">
      <Text>Ray ignores him and grabs the phone anyway.</Text>
    </Paragraph>
    <Paragraph Type="Scene Heading" id="55df7301-9156-4fc0-9770-a4ca88593e9a">
      <SceneProperties Length="2/8" Page="36" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="RAY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text Style="Bold+AllCaps">Int. Kwan’s ApARTMENT - ConTINUOUS</Text>
    </Paragraph>
    <Paragraph Type="Action" id="e904754f-c3c0-45c9-be4a-762035df242c">
      <Text>Ray paces as she dials Billy’s number. The line clicks open.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="7fda2420-4e07-47b8-af59-dd6576af1dbf">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="6c6e745b-3eb5-449d-b52b-b608263d35ef">
      <Text>Mr. Dubois...? Okay, thanks for answering, Billy... I’m Trini Reyes and I’m curious about your journey since... Um... I’m here in East Lansing... New York? Sure- I can make it out there.</Text>
    </Paragraph>
    <Paragraph Type="Scene Heading" id="a2a19c49-1083-498a-9ac6-179c26219489">
      <SceneProperties Length="3/8" Page="37" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="KWAN">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="RAY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text Style="Bold+AllCaps">Int. Kwan’s Apartment - MomeNTS LATER</Text>
    </Paragraph>
    <Paragraph Type="Action" id="622c3983-dd11-43b1-98c9-15e45544eb5c">
      <Text>Ray walks back and tosses the phone into Kwan’s lap.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="3065db68-97a8-4dec-8d72-99d53c700138">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="0358cf53-3ba6-43dc-a0d4-34f3aef8dbdd">
      <Text>I’ve got an opportunity in New York.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="fa5dde6a-6379-4ff6-9a1c-29c9e536ba79">
      <Text>KwaN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="affcfc06-8041-4172-a333-84c767e00c53">
      <Text>An audition?</Text>
    </Paragraph>
    <Paragraph Type="Character" id="5c8af40b-66ea-42ac-948e-4b26a6d7fe21">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="b6e37ad4-f2fd-4b6f-b266-3f1e56409c71">
      <Text>Mentorship? Well, at least hoping for someone’s blessing...</Text>
    </Paragraph>
    <Paragraph Type="Action" id="acf1ed1e-10a4-4211-aff5-40559a563727">
      <Text>Ray gives a thumbs up to the camera and disappears from the doorway.</Text>
    </Paragraph>
    <Paragraph Alignment="Center" FirstIndent="0.00" Leading="Regular" LeftIndent="1.00" RightIndent="7.50" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="End of Act" id="8320508a-6b7a-43cd-9457-386c90d1a8a4">
      <Text>End of Act Three</Text>
    </Paragraph>
    <Paragraph Type="New Act" id="6b67055e-8e0a-4c01-b26e-48bdef828a9a">
      <Text>ACT Three</Text>
    </Paragraph>
    <Paragraph Type="Scene Heading" id="5e6d3c1f-7fe7-478f-a18c-1e6008989ff5">
      <SceneProperties Length="2/8" Page="38" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="RAY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>Ext. Clay’s Apartment - Day</Text>
    </Paragraph>
    <Paragraph Type="Action" id="335fc8ba-7fff-4038-b4b7-b9c741814a6c">
      <Text>Ray </Text>
    </Paragraph>
    <Paragraph Type="Character" id="7d398149-2f5e-41f0-85fa-5592240d6155">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="c622f75b-1ea8-4a37-93c3-5e4e336510c9">
      <Text>Clay... Stardust is in trouble. She needs your help.</Text>
    </Paragraph>
    <Paragraph Type="End of Act" id="ac7bcb5e-4e49-481f-8d62-ced164042c52">
      <Text>End of Pilot</Text>
    </Paragraph>
  </Content>


<?xml version="1.0" encoding="UTF-8" standalone="no" ?>
<FinalDraft DocumentType="Script" Template="No" Version="6">

  <DocumentRef DateTime="20250719T225100" id="311bf653-30ed-4d65-a49b-1d9bc7012bab">
    <XRef DateTime="20250719T224917" id="326d3bbb-277d-4966-b8b4-fc0c38660087"/>
  </DocumentRef>

  <Content>
    <Paragraph Type="New Act" id="6b67055e-8e0a-4c01-b26e-48bdef828a9a">
      <Text>Hot Open</Text>
    </Paragraph>
    <Paragraph Type="Scene Heading" id="6353e508-3b10-494d-afbb-ca218dde3018">
      <SceneProperties Length="1 1/8" Page="1" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="AURORA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="DIRECTOR">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="RAY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text Style="Bold+AllCaps">Ext. Theater Camp Amphitheater - Day (Summer 2014)</Text>
    </Paragraph>
    <Paragraph Type="Action" id="45e35927-67a8-44f1-89aa-0b99dad99afc">
      <Text>The stage is a place of the highest drama and lowest budgets. </Text>
    </Paragraph>
    <Paragraph Type="Action" id="45e35927-67a8-44f1-89aa-0b99dad99afc">
      <Text>The </Text>
      <Text Style="AllCaps">campers</Text>
      <Text> sit in the audience seats. Aurora (17), poised and polished, sits front row. Ray (17) slides into the row behind her, breathless and shaking with nervous energy. </Text>
    </Paragraph>
    <Paragraph Type="Character" id="6e5bcbcf-47af-46be-a722-bde9c66c92da">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="5a086580-8945-4108-ab0b-d4420fc1d8d7">
      <Text>(to camera)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="2738ef4f-ee53-4b36-b099-168ae5f61d4c">
      <Text>Last year at theater camp. Time to go out with a </Text>
      <Text Style="AllCaps">pan</Text>
      <Text>! I’m a shoo-in for Peter Pan. Senior privileges, let’s </Text>
      <Text AdornmentStyle="-1">goooooooo</Text>
      <Text>!</Text>
    </Paragraph>
    <Paragraph Type="Action" id="950c959c-aea5-43e7-9443-6229b45ae64e">
      <Text>The </Text>
      <Text Style="AllCaps">director</Text>
      <Text> (60s, miserable) trudges in with a clipboard.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="aa28a90e-bf99-4d52-b018-04084efdf17a">
      <Text>DirECTOR</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="415f7adc-a591-4a57-aff8-71b9f0e76e2e">
      <Text>This here is the 2014 cast of </Text>
      <Text Style="Italic">Peter Pan</Text>
      <Text>. Let’s start naming ensemble...</Text>
    </Paragraph>
    <Paragraph Type="Action" id="5a59f5a1-ef14-4e45-bb26-e09372ed876a">
      <Text Style="AllCaps">Montage</Text>
      <Text> of name-reading. Most campers stand and cheer. Ray’s smile grows tighter with each role. Aurora turns to Ray.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="a0a873b4-fd1b-4c40-8ecf-d0813f9671e6">
      <Text>Aurora</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="752c5e17-1b3f-4e3f-9eef-99c9a087cb97">
      <Text>You’re getting that Peter Pan role.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="917d6ab5-0f55-4c50-b192-591c7a7413b3">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="ce9a4bd5-6221-478c-8e33-99c2062dcf5f">
      <Text>Funny, can’t say the sam- </Text>
      <Text Style="Italic">I mean ya would’ve made a fine pirate, matey</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="eb914b65-a0af-42d8-bbe2-188840c52dca">
      <Text>Aurora smirks at the camera and makes a hook with her hand.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="b1961e99-5d48-4b85-b7ed-74820a7061d9">
      <Text>Director</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="8931267b-bc2b-4bb1-ad34-b14a6836d2bc">
      <Text>And finally... soaring in as our lead, Peter Pan... </Text>
      <Text Style="Italic">try-nye ree-yes</Text>
      <Text>?</Text>
    </Paragraph>
    <Paragraph Type="Action" id="eba98bc7-3fcb-4ff4-8340-2410a247721a">
      <Text>Ray awkwardly grins at the camera then celebrates anyways.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="fd6bf935-db66-4765-96f3-b48e4600322c">
      <Text>AurorA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="19f617ac-075b-4356-be7c-f1f15e7f4ae6">
      <Text>It’s pronounced </Text>
      <Text Style="Italic">Trini Reyes</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="067d4b33-de88-4bbd-b080-0ed9f48cccf6">
      <Text>DirectOR</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="b995e906-82ee-487b-b053-5fee9208ccf6">
      <Text>Whatever. Anywho, your “I’m Flying” audition landed you this role.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="df9bc129-cbea-4a87-b9eb-072726c9ddf7">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="122f9697-c62f-4679-bcda-29db3118d149">
      <Text>Wuh- But I sang “I’ve Gotta Crow”?</Text>
    </Paragraph>
    <Paragraph Type="Character" id="8e59cb6c-0407-41b8-b074-cf51820c4695">
      <Text>Director</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="594f9efc-4fb4-4435-ab23-ba3e2cc91d3b">
      <Text>No needa be a sour croc, Aurora.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="12ed5a01-a032-49b8-be8f-2223398d676b">
      <Text>AuRORA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="43eb3990-ad32-496b-ad5c-6db0355ba610">
      <Text>I’m Aurora. She’s Ray.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="8cb23440-07e7-4599-b064-61dcf9aab760">
      <Text>Director</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="1d835912-f93c-4c5f-b816-2f3c8b55ec70">
      <Text>Oh neverlands- I musta gotten you two mixed up. Aurora, you’re Peter.</Text>
    </Paragraph>
    <Paragraph Type="Scene Heading" id="b8b02112-1ffe-4448-98ba-d6a66cc5fadf">
      <SceneProperties Length="4/8" Page="2" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="AURORA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="RAY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text Style="Bold+AllCaps">Ext. Theater Camp Amphitheater - MomENTS LATER</Text>
    </Paragraph>
    <Paragraph Type="Action" id="3397588d-ddd7-43a7-aadb-e367be078846">
      <Text>Behind Ray, the Director gives Aurora some notes.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="0e5e0b0f-7aa8-47a1-b6e1-74565b2d87fe">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="0f940b5e-e800-429c-a564-0ac0d25a430f">
      <Text>(to camera)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="c0714ef4-609e-4b73-bc52-28416e16fc06">
      <Text>I’ve been here for years and this codfish couldn’t remember my name? </Text>
      <Text Style="Italic">Aurora outshines me again</Text>
      <Text>. Well, guess I’ll be spending my last year selling concessions...</Text>
    </Paragraph>
    <Paragraph Type="Action" id="c3baaaf0-506a-4e50-8151-299076702d8d">
      <Text>Ray’s gloominess catches Aurora’s attention.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="c285a70e-3c8c-47b7-816d-24bb30df4340">
      <Text>Aurora</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="80405208-0be3-4544-9431-7e284ecff1a1">
      <Text>(to camera)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="462e2c62-e817-4ce4-89b2-a0b400e29cd3">
      <Text>Poor Ray. Whenever she is on stage, she is sunshine personified. </Text>
      <Text Style="Italic">Ooh</Text>
      <Text>, I’ve got an idea tinkering in me.</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="2a0714bb-8c2e-47e5-a8d3-e1cc22a1c056">
      <Text>(to Director)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="fce5c6fe-252a-4f57-8705-9dcd1831462e">
      <Text>Director! As the leader of the Lost Boys, I got a concession of my own.</Text>
    </Paragraph>
    <Paragraph Type="Scene Heading" id="864571ec-4649-438f-8cb8-30e4ba8b6aa9">
      <SceneProperties Length="4/8" Page="2" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="AURORA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="RAY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text Style="Bold+AllCaps">Ext. Theater Camp - Evening</Text>
    </Paragraph>
    <Paragraph Type="Action" id="93e91741-c761-47f4-a726-1c7db362bda2">
      <Text>The sun sets behind the pines. Ray looks ready to throw a punch while Aurora looks ready to give a hug.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="78e78d1c-c97b-4511-8b3e-4c2eee1fd331">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="af1eca42-a6b3-43f9-b1d2-c96022d30ebb">
      <Text>...I’m your sidekick...?</Text>
    </Paragraph>
    <Paragraph Type="Character" id="915f7aed-aa79-45e4-99fb-f47988fb13fb">
      <Text>AuroRA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="cb32675a-86cf-4d15-963f-9ae94ea4bd97">
      <Text>The way I see it, I’m </Text>
      <Text Style="AllCaps">your</Text>
      <Text Size="10"> </Text>
      <Text>sidekick! You’re freaking Tinker Bell! A star-</Text>
    </Paragraph>
    <Paragraph Type="Character" id="bfb42c4a-99b0-415e-b69f-430482a78995">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="a7b4d619-fa1d-47b5-8769-c51b00238978">
      <Text>Where’s the crew member assigned to the laser pointers? And the Director is often set in their ways. How’d you pull this off?</Text>
    </Paragraph>
    <Paragraph Type="Character" id="51d90590-9456-4c26-8ae5-531f51a99a78">
      <Text>Aurora</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="ad42c210-e055-4224-8f9e-8d92141fb47d">
      <Text>Here’s a pointer: it helps to have a family who funds this camp. The Starlings always got Reyes’s back.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="7524b90b-354a-4381-a35f-196bc6216a83">
      <Text>Aurora hugs Ray while Ray looks menacingly at the camera.</Text>
    </Paragraph>
    <Paragraph Type="Scene Heading" id="4b71002c-43e1-4443-b8d8-73d0a3ca247c">
      <SceneProperties Length="1 6/8" Page="3" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="AURORA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="DIRECTOR">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="RAY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="TOOTLES THESPIAN">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="WENDY THESPIAN">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text Style="Bold+AllCaps">Int. Theater Camp Amphitheater - Night </Text>
    </Paragraph>
    <Paragraph Type="Action" id="5e738f18-e241-49b7-a95d-1789ba17b399">
      <Text>Most seats are empty as no one cares about theatre anymore. Kwan (12) sits front row, filming on a camcorder.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="91ba2a59-8d82-4552-83f2-0e03c1ca0e8b">
      <Text>On stage, the play is a train wreck. Most forgot their lines.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="91ba2a59-8d82-4552-83f2-0e03c1ca0e8b">
      <Text>Draped in black, Ray wanders about, holding a glowing orb. Aurora, as Peter Pan, is making pipes with a dull knife by a fake campfire. She’s distractingly theatrical.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="56cce6ee-be3e-47bb-9e40-e28a012c47a4">
      <Text>Tootles Thespian</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="d1202999-eb74-40a9-a48d-5bf1c5c65b1e">
      <Text>Am I in... uh.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="9cc4fe51-a770-4fcf-ac9b-fad42ab3128c">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="6435e480-4d93-4af7-89cd-483b81b1caa3">
      <Text Style="Italic">Story</Text>
      <Text>. Your line is “</Text>
      <Text Style="Italic">story</Text>
      <Text>.”</Text>
    </Paragraph>
    <Paragraph Type="Character" id="c95c01f6-9fa1-4e1e-a49c-885cf92f6031">
      <Text>TooTLES THESPIAN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="ebeca58d-9544-40bd-b8b4-2a3b7842de1c">
      <Text>Ah! Nibs, I am in a story.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="d945a558-3b52-44b0-bd38-abf65472884b">
      <Text>Aurora</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="d4e26a83-0be7-4a97-82e2-fcd8b8b10422">
      <Text>A little less-</Text>
    </Paragraph>
    <Paragraph Type="Character" id="ad6d787a-280a-4350-941a-9cc6bb87aedf">
      <Text>Wendy Thespian</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="99e5bd34-9e75-4071-b990-e4004b73ff80">
      <Text>Now I want you to consider the um-</Text>
    </Paragraph>
    <Paragraph Type="Action" id="56ad9caf-b011-42a5-8a3f-63cd326360ba">
      <Text>Ray lunges at Wendy, thrusting the glowing orb in her face.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="e992a0e5-5f89-4ec7-9dca-3d4868dfc841">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="85435596-e26b-4d1a-afb7-432d2c28547c">
      <Text>F-E-E-L-I-N-G. </Text>
      <Text Style="Italic">Feeling-</Text>
    </Paragraph>
    <Paragraph Type="Character" id="603f7a12-761e-4b5c-a094-c8a0580d5fea">
      <Text>WenDY THESPIAN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="3f85d755-551b-42ad-b673-f6fedf0b89f6">
      <Text>...</Text>
      <Text Style="Italic">feeling</Text>
      <Text> of the unhappy-</Text>
    </Paragraph>
    <Paragraph Type="Character" id="e8210bd8-ed76-4c51-907e-770a7cf8e6b7">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="98b1ab60-a8d9-4eff-9cb8-ee74ae73f9d6">
      <Text>(to camera)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="dd5bd1f4-b58d-446c-b5ca-4fbe8d81f124">
      <Text>You see anyone here put feelings in their performance? Be honest... Ya right! Everyone’s dead inside.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="01a47087-06b9-494e-81eb-98636cc4c8f2">
      <Text>The Director goes to the edge of the stage.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="9cb7ee6a-8bd8-4a73-960b-18e3b61415a9">
      <Text>Director</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="b411dc0a-dd6e-4f7c-aa21-dbc90087ebdf">
      <Text>No need to get all children’s program-y. It’s creepy. I suggest a little less improvisation here.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="478abf95-9030-41df-80f3-6a7affefe3b7">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="2819ef59-0895-4194-b85d-d9581c38c4dc">
      <Text>The line was “A little less noise there.” But Aurora missed her lines because Wendy here bulldozed it.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="4c34d6c5-282f-45dd-b5b7-49b64183ca6c">
      <Text>AurorA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="3c17fc44-9ff3-48d5-a0a2-99e59dc24c02">
      <Text>The only lost boy here is you.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="21e5b44d-f8ec-446a-b5dd-417290f83772">
      <Text>Director</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="7e260162-027d-419c-a87e-5945a81eecc2">
      <Text>Hey hey Sweeney Todd and Mrs. Lovett, let’s settle this.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="4fab2f32-646d-4b66-9f53-5c2f264cd20d">
      <Text>Wendy pulls out their play booklet.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="9011ca7e-9954-46e4-9b6c-6f7758c0b2a3">
      <Text>WenDY THESPIAN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="be066fcf-7e3b-4b66-a2c7-62c42c4c5a94">
      <Text>I don’t remember those characters being in this play...</Text>
    </Paragraph>
    <Paragraph Type="Character" id="168adcf4-8b87-43b4-8e0a-d566de5c0d75">
      <Text>Director</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="970b6866-f3cc-46c9-a7b2-7955d991e442">
      <Text>Guys, dolls, just, um, uh-</Text>
    </Paragraph>
    <Paragraph Type="Character" id="4587219f-38c3-4763-b945-e37095917599">
      <Text>AurorA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="2efc2257-5fcb-41b0-b5b2-f8230b912a52">
      <Text>Don’t tinker with your role in this world, Ray.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="07b26b8c-57bc-4d1a-a670-6efbf8885f4d">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="dcf6e76b-fb6d-4e6a-996b-ac6be71ac6bf">
      <Text>I’m nobody’s sidekick. I’ll never ever be one to you, Aurora. This </Text>
      <Text Style="Italic">Peter Pan</Text>
      <Text> production is panned!</Text>
    </Paragraph>
    <Paragraph Type="Action" id="a5f5739c-0039-4200-8a0a-78dcd004b2d1">
      <Text>Ray violently tosses her orb prop into the fake fire set. It catches on real fire.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="a5f5739c-0039-4200-8a0a-78dcd004b2d1">
      <Text>Everyone panics while the Director sighs and sits back down.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="b300979d-1af9-403a-95e1-408a390e21f7">
      <Text>DireCTOR</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="62e26293-dfcf-4f73-9fe4-3b67e4da6c9b">
      <Text>Who cares? Don’t get paid enough.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="b3d74276-ce78-4c2d-a32a-cd93f4c0ae40">
      <Text>Aurora</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="fbf32321-052a-4842-97ab-06a536ff8d1d">
      <Text>(to camera)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="7dcd6610-11c4-47b9-9b1c-0eedf8b7d62d">
      <Text>Only you can prevent wild dramas!</Text>
    </Paragraph>
    <Paragraph Type="Action" id="18daa3d8-6d32-465b-9a18-ed8e27abbd91">
      <Text>Kwan looks through the camcorder, grinning. </Text>
    </Paragraph>
    <Paragraph Type="Action" id="18daa3d8-6d32-465b-9a18-ed8e27abbd91">
      <Text Style="Bold+AllCaps">On the camcorder monitor</Text>
      <Text>: Ray tries to stomp out the fire. She then blocks the camera.</Text>
    </Paragraph>
    <Paragraph Type="Transition" id="d0448a90-1f9f-44c4-8fcb-e98eee78b5f9">
      <Text>Cut to BLACK.</Text>
    </Paragraph>
    <Paragraph Alignment="Center" FirstIndent="0.00" Leading="Regular" LeftIndent="1.00" RightIndent="7.50" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="End of Act" id="8320508a-6b7a-43cd-9457-386c90d1a8a4">
      <Text>End of Hot Open</Text>
    </Paragraph>
    <Paragraph Type="Action" id="da01c2de-c79d-48e1-83a9-43aad66ad49e">
      <Text Style="Bold+AllCaps">Main Titles</Text>
    </Paragraph>
    <Paragraph Type="New Act" id="1b7e5dc9-80e1-45fb-9e46-269c17b41982">
      <Text>ACT One</Text>
    </Paragraph>
    <Paragraph Type="New Act" id="de99c433-90c9-40e2-94df-982b6ae9abea">
      <Text>ACT Two</Text>
    </Paragraph>
    <Paragraph Type="New Act" id="3a62b1c3-42ad-4949-a0d8-121e87e439d5">
      <Text>ACT Three</Text>
    </Paragraph>
    <Paragraph Type="Scene Heading" id="f8e26f32-71ab-4cd7-b50d-e493d06a3ec6">
      <SceneProperties Length="1/8" Page="7" Title="">
        <SceneArcBeats/>
      </SceneProperties>
      <Text>Begin Main Titles</Text>
    </Paragraph>
    <Paragraph Type="Scene Heading" id="f8e26f32-71ab-4cd7-b50d-e493d06a3ec6">
      <SceneProperties Length="1 3/8" Page="7" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="AURORA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="CLAY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="KIDS">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="RAY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="ROCKET">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="STARDUST">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="STARPOWER">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="STARS">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>Ext. </Text>
      <Text AdornmentStyle="-1">Miniverse</Text>
      <Text> - The Cosmos (Animated)</Text>
    </Paragraph>
    <Paragraph Type="Action" id="49223ad7-68ea-4b39-873b-a0dae5ec67b7">
      <Text>Pitch black. Suddenly, </Text>
      <Text Style="AllCaps">smiling stars</Text>
      <Text> pop out like lightbulbs.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="666d3eee-95d6-435c-81a7-382558019e90">
      <Text>Stars</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="15b464b0-1abd-4baf-8648-8034d0178174">
      <Text>(in unison)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="46bfdbf0-ec9c-4a34-aea3-b70a08e48cb8">
      <Text Style="AllCaps">Star</Text>
      <Text>(dust)-</Text>
      <Text Style="AllCaps">power! Star</Text>
      <Text>(dust)-</Text>
      <Text Style="AllCaps">power!</Text>
    </Paragraph>
    <Paragraph Type="Action" id="b8572112-5796-480c-8972-6ad680067436">
      <Text Style="AllCaps">Stardust</Text>
      <Text>, an animated whimsical, green mudpuppy, and </Text>
      <Text AdornmentStyle="-1" Style="AllCaps">StarPower</Text>
      <Text>, an animated stoic pink axolotl, soar from behind the stars. They stop to form a heroic pose in the center.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" RightIndent="7.50" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="General" id="b592db6f-328b-42dd-8e24-623b31711c73">
      <DualDialogue>
        <SpellCheckIgnoreLists>
          <IgnoredRanges/>
          <IgnoredWords/>
        </SpellCheckIgnoreLists>
        <Paragraph Type="Character" id="ea878aae-ac65-4fdd-84b5-ba1e020925ac">
          <Text>Stardust</Text>
        </Paragraph>
        <Paragraph Type="Dialogue" id="7241fdd9-6b53-4b1a-b386-473373dad906">
          <Text>Twinkle </Text>
          <Text AdornmentStyle="-1">twinkle</Text>
          <Text> </Text>
          <Text AdornmentStyle="-1">twinkle</Text>
          <Text>!</Text>
        </Paragraph>
        <Paragraph Type="Character" id="86871fd6-b217-4b17-aad8-550ad2b943ff">
          <Text AdornmentStyle="-1">Starpower</Text>
        </Paragraph>
        <Paragraph Type="Dialogue" id="3e48caef-eb4b-4555-a0e8-326b1f345834">
          <Text>Bubble </Text>
          <Text AdornmentStyle="-1">bubble</Text>
          <Text> </Text>
          <Text AdornmentStyle="-1">bubble</Text>
          <Text>!</Text>
        </Paragraph>
      </DualDialogue>
    </Paragraph>
    <Paragraph Type="Action" id="81555397-92c3-4130-bdf8-00f7973e2ef4">
      <Text>A ROCKET SHIP with a smiling, animated face overtakes the frame. </Text>
      <Text Style="AllCaps">Aurora</Text>
      <Text> (30, live-action, dazzling in her gold shirt and celestial overalls), sings from the Rocket’s window.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="9ab0f43e-5665-4754-8122-6070dfa174e4">
      <Text>Aurora</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="820214d1-164a-409f-8ceb-cb3dbcb0262a">
      <Text Style="AllCaps">Let’s explore the miniverse and make a trillion friends</Text>
    </Paragraph>
    <Paragraph Type="Action" id="58ef73db-2b1c-4d9c-aad1-a27698647a67">
      <Text>The Rocket blasts towards a nearby planet. On the surface, </Text>
      <Text Style="AllCaps">Ray</Text>
      <Text> (30, live-action, surviving in her brown and pink jacket) sprints across a cratered landscape.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="aaefc3b8-545c-4d19-ba53-f999fe69f092">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="fa28bd5d-22c1-455b-b67b-ea7c23173d16">
      <Text Style="AllCaps">Just like the universe it never ever ends</Text>
    </Paragraph>
    <Paragraph Type="Action" id="d77caf3b-a24d-4934-9134-dbca7e9a37d9">
      <Text>Ray runs past Aurora and Stardust, who are helping an </Text>
      <Text Style="AllCaps">alien villager</Text>
      <Text> read a holographic map in the dark.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="7f50d43d-6030-4fe6-b1e7-112f105bffa0">
      <Text>Aurora</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="ba9caf35-afd0-4d3e-9942-3d5a742a1a55">
      <Text Style="AllCaps">Let’s help a small villager with directions when we can</Text>
    </Paragraph>
    <Paragraph Type="Action" id="974cb88f-5292-4570-885e-4bf03285e342">
      <Text Style="AllCaps">Boom</Text>
      <Text>. The sun ignites, bathing the atmosphere in light. The camera pulls back at lightspeed to reveal StarPower is now a gargantuan much larger than star systems. She gently nudges a stray star into the center of the star system.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="5cebdd9f-ffc2-46eb-8f6d-92ccf53b3dfb">
      <Text>Ray (V.O.)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="68b09e87-d940-4d16-a026-672dae9feead">
      <Text Style="AllCaps">Much like we can help planets find their star giant</Text>
    </Paragraph>
    <Paragraph Type="Action" id="b72f66e3-5732-47b2-9776-6753aacca51e">
      <Text>The camera pulls back even further, returning to the Stars.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="570a04a0-92a2-4143-ac11-5dff94016394">
      <Text>Stars</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="435b555a-441f-4ef0-9ab8-9e4ad86a694e">
      <Text>(Repeating)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="f8e930b1-4290-4c79-b3ce-27fee0df8e1c">
      <Text Style="AllCaps">Stardust plus Starpower!</Text>
    </Paragraph>
    <Paragraph Type="Action" id="b922142b-7d2e-4c57-a767-45e2b141840f">
      <Text>The Rocket streaks across the screen. Aurora and Ray appear side-by-side in the window and </Text>
      <Text Style="AllCaps">fist bump</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="ad4f6519-6995-446f-93c4-ff76275a534f">
      <Text>AuroRA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="b85d84e6-5c5d-4d0f-ac86-e994766afb27">
      <Text Style="AllCaps">Aurora...</Text>
    </Paragraph>
    <Paragraph Type="Character" id="fc366b7c-32e4-4061-9dc6-e1e453704bc1">
      <Text>RAY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="00c1e529-7be5-4149-a94a-0d2246eb942d">
      <Text Style="AllCaps">...Ray.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="baa05101-e123-4ae0-8f43-d24693a8ff59">
      <Text>Stardust and StarPower spiral around the window.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" RightIndent="7.50" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="General" id="ba7ac6a7-17ff-4441-b848-69d0aff0b6a9">
      <DualDialogue>
        <SpellCheckIgnoreLists>
          <IgnoredRanges/>
          <IgnoredWords/>
        </SpellCheckIgnoreLists>
        <Paragraph Type="Character" id="ea878aae-ac65-4fdd-84b5-ba1e020925ac">
          <Text>Stardust</Text>
        </Paragraph>
        <Paragraph Type="Dialogue" id="7241fdd9-6b53-4b1a-b386-473373dad906">
          <Text>Twinkle </Text>
          <Text AdornmentStyle="-1">twinkle</Text>
          <Text> </Text>
          <Text AdornmentStyle="-1">twinkle</Text>
          <Text>!</Text>
        </Paragraph>
        <Paragraph Type="Character" id="86871fd6-b217-4b17-aad8-550ad2b943ff">
          <Text AdornmentStyle="-1">Starpower</Text>
        </Paragraph>
        <Paragraph Type="Dialogue" id="136cd67d-ddb1-4da5-8a3b-3fa54aa6f0dd">
          <Text>Bubble </Text>
          <Text AdornmentStyle="-1">bubble</Text>
          <Text> </Text>
          <Text AdornmentStyle="-1">bubble</Text>
          <Text>!</Text>
        </Paragraph>
      </DualDialogue>
    </Paragraph>
    <Paragraph Type="Action" id="6b7efd2f-5b6f-4086-a863-1f067e8539d5">
      <Text>Dust and Power’s trails form the </Text>
      <Text Style="AllCaps">StarPOwer logo</Text>
      <Text>. The logo settles over the swirling </Text>
      <Text Style="AllCaps">Milky Way Galaxy</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Scene Heading" id="69045bfd-3757-4582-ab5d-fb956c12d95a">
      <SceneProperties Length="5/8" Page="8" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="AURORA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="KIDS">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="ROCKET">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="STARDUST">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>End Main Titles</Text>
    </Paragraph>
    <Paragraph Type="Action" id="2148e567-368b-43c2-8f98-c25a4b39daf6">
      <Text>The logo’d Milky Way Galaxy crack open like a </Text>
      <Text Style="AllCaps">popup book</Text>
      <Text>. Rocket pops out from the pages.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="748fe493-071f-4b2d-b8dc-9e66bbe38e2c">
      <Text>Aurora appears in the rocket’s window and waves enthusiastically.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="ad5da471-b7c3-4d78-98c2-26e751239ce6">
      <Text>AurORA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="5c2edfcf-967d-4dc7-9379-0b681a1042d0">
      <Text>Planets, comets, and galaxies everywhere! It’s me, Aurora! Have you seen our best friend, Stardust?</Text>
    </Paragraph>
    <Paragraph Type="Action" id="eeb237ab-df23-478f-b40a-69b2f90d3f09">
      <Text>Stardust soars out from behind a star and loops around the ship.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="c68e5431-9051-4285-8437-7e5009cbbe94">
      <Text>Stardust</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="af782bb0-7bd6-4705-b26b-fb6a7ea6d1f5">
      <Text>Twinkle twinkle twinkle!</Text>
    </Paragraph>
    <Paragraph Type="Character" id="8046f8c3-c582-4d98-94ba-2b6f0788680c">
      <Text>Kids (V.O.)</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="9c4e7093-702d-4d32-bd35-0c051b22d8a9">
      <Text>(in unison)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="bd419307-8c3a-495d-8d23-47fe1d94104e">
      <Text>There she is!</Text>
    </Paragraph>
    <Paragraph Type="Action" id="306c14ec-fd57-4917-b334-0b00fa3f9853">
      <Text>Aurora ducks back inside.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="c7e30fa4-19fb-4176-b23c-1f541976e9cb">
      <Text>Rocket</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="7f69c111-1f12-43bb-9a7b-01821c8dced8">
      <Text>Come on in, starkids!</Text>
    </Paragraph>
    <Paragraph Type="Action" id="0a48a32b-7286-4758-b434-a9918d9bbf6c">
      <Text>The camera follows Stardust as she dives through the window.</Text>
    </Paragraph>
    <Paragraph Type="Scene Heading" id="fa188c92-c872-404a-ad0b-cf417b84b208">
      <SceneProperties Length="1 4/8" Page="9" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="AURORA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="AURORA &amp; RAY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="KIDS">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="RAY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="STARPOWER">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>Int. Rocket - ContinUOUS</Text>
    </Paragraph>
    <Paragraph Type="Action" id="c0d108d5-45ae-4147-b57d-1ad64af36b5f">
      <Text>Inside, the cockpit set is filled with colorful buttons. Aurora searches the cabin.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="c24b2bc2-647e-4a6c-8b50-feb30797a913">
      <Text>Aurora</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="e1197009-603a-40be-bc6d-6a0d656ccb47">
      <Text>(to camera)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="b4025e30-8c2f-4767-b3fb-b2b1d867636e">
      <Text>Hi! We're so glad you're here! We’re almost ready to land. Stardust? Stardust?</Text>
    </Paragraph>
    <Paragraph Type="Action" id="edc1f33b-684c-4d29-ba4a-a3312d19cc73">
      <Text>Stardust giggles and ducks underneath a nearby table.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="3eaac186-a7fc-4177-95ab-4fa6607b04ec">
      <Text>Aurora</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="35f5ad05-4bc8-4566-a818-6d1a357f75f6">
      <Text>(to camera)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="37b17ab6-23ca-47b9-8a00-c2d1e753932d">
      <Text>Did you see Stardust?</Text>
    </Paragraph>
    <Paragraph Type="Action" id="7f4b7144-2d17-4096-82d5-7245fb3804be">
      <Text>Ray walks in with a medical kit.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="14f64058-99fd-44e1-bafc-088d0c6cf261">
      <Text>Kids (V.O.)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="f2486fa3-773e-47da-bc51-f16e6c756269">
      <Text>Right there! Under the table!</Text>
    </Paragraph>
    <Paragraph Type="Action" id="40054e4f-a121-4f6b-905a-99f5e7993a8a">
      <Text>Aurora mimics hand-goggles, and faces Ray.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="0e612482-23ad-4e39-96a5-0625e1ff4986">
      <Text>AurorA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="7ba3546c-0bb0-4101-abb8-56ef667d884d">
      <Text>It’s my sidekick, Ray! Ray, have you seen Stardust?</Text>
    </Paragraph>
    <Paragraph Type="Character" id="d290901f-a2ef-4b49-8203-d9de5f6bd004">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="bf5c8b94-5b0c-4c4c-be72-edf2a2e3e8e8">
      <Text>I have not seen Stardust, Aurora. But I </Text>
      <Text Style="Italic">have </Text>
      <Text>seen StarPower.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="1d9ed371-bd8d-4ac0-9b81-58461435cdbe">
      <Text>Ray taps the wall by the window. StarPower‘s giant eye fills the window.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="7ee4b24a-541c-4816-885c-ab20da12e001">
      <Text>Aurora</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="067f3269-e3be-4e75-82f6-998ff16ad509">
      <Text>Have you seen Stardust?</Text>
    </Paragraph>
    <Paragraph Type="Character" id="5e3f8438-bd17-483d-9615-e99bf3797529">
      <Text>StarPOWER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="54b5f615-c051-4c9f-b553-a4754cb61348">
      <Text>Bubble bubble bubble!</Text>
    </Paragraph>
    <Paragraph Type="Action" id="0f37ad18-7274-4441-965c-8a6b6c2407c6">
      <Text Style="AllCaps">Plop</Text>
      <Text>. StarPower shrinks to Stardust’s size and zips inside to join Stardust under the table.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="edf8ce1e-3035-42b7-8b5a-7a8d98b01fe3">
      <Text>RAY</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="0132b332-7340-4579-840c-51d9a4b5a6c8">
      <Text>(to camera)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="e7cf21ab-cd55-4036-9055-1039704f3508">
      <Text>Under the table! Like you starkids said!</Text>
    </Paragraph>
    <Paragraph Type="Action" id="147aa457-bd4d-4328-bca0-ebd2a294efdc">
      <Text>Stardust and StarPower swirl around Ray’s medkit.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="d1c97149-423c-4686-a384-2c3f56a95ae7">
      <Text>AurorA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="f5546d7d-951f-4be7-bbd6-baa54ceb2aa6">
      <Text>Oh! Ray, why do you have your medkit? Is someone sick?</Text>
    </Paragraph>
    <Paragraph Type="Character" id="a4f1436c-8254-4902-b97a-b4d1291396c5">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="c27a0949-31ee-465e-b9d8-d2098da3f129">
      <Text>Our galaxy is, Aurora.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="955f337e-d896-45ff-b5c5-03e758cc4950">
      <Text>AuRORA</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="183c741d-7472-46f0-8633-1e9769127b31">
      <Text>(to camera)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="83cb9a0f-40cc-4b8d-af4e-2d579be4e532">
      <Text>Oh no! Remind us... what is the name of our galaxy?</Text>
    </Paragraph>
    <Paragraph Type="Character" id="9f37acce-76c9-4cc1-ae1d-1e28eb32d9de">
      <Text>KidS (V.O.)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="4e0f01b8-e5fc-453a-8721-bd5ea2a681cc">
      <Text>Milky Way!</Text>
    </Paragraph>
    <Paragraph Type="Character" id="9374fae4-41a6-443a-8f02-018142a3aa6f">
      <Text>Aurora</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="51edc974-9011-473b-95be-1ec9587d8627">
      <Text>Is it... Triangulum?</Text>
    </Paragraph>
    <Paragraph Type="Character" id="a63ccf4d-e909-4596-95f3-d39c2e761143">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="f4909f3d-a451-4d8b-b462-e3f7e0465a0f">
      <Text>Andromeda?</Text>
    </Paragraph>
    <Paragraph Type="Character" id="2ced62b9-003f-444f-9ffd-d6363e24be15">
      <Text>KidS (V.O.)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="0de68878-27f1-44bf-809d-66dd0471600b">
      <Text>Milky Way! Milky Way! Milky Way!</Text>
    </Paragraph>
    <Paragraph Type="Character" id="87f59e3b-c775-4722-adc3-d950f569796a">
      <Text>Aurora &amp; Ray</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="0eea844d-8b98-49dc-8966-4ac487ff6c4c">
      <Text>Ah! Milky Way!</Text>
    </Paragraph>
    <Paragraph Type="Scene Heading" id="0147d697-9830-47fa-b7f6-ef63ef0dce0a">
      <SceneProperties Length="3/8" Page="10" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="AURORA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="KIDS">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="RAY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>Ext. Deep Space - ConTINUOUS (Animated)</Text>
    </Paragraph>
    <Paragraph Type="Action" id="b87ce438-e573-4255-968b-70039780884e">
      <Text>The camera pulls back to show the </Text>
      <Text Style="AllCaps">Milky Way Galaxy</Text>
      <Text>. They have drooping animated eyes and a thermometer tucked in the mouth.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="8e0d6594-b010-46c4-a66a-1c7437b94dac">
      <Text>Kids (V.O.)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="141dcefc-9b8f-48bd-8b76-769d657428e7">
      <Text>Aww...</Text>
    </Paragraph>
    <Paragraph Type="Character" id="11dae4ca-9551-4a29-8855-01a1a3e87f71">
      <Text>Aurora</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="2ca5c1ff-2446-4197-aafb-5d3909fe4c6f">
      <Text>Milky Way isn’t feeling well...</Text>
    </Paragraph>
    <Paragraph Type="Character" id="c28f190b-f80b-4064-ba32-92452b80a206">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="1a7f9895-6d8f-43a0-a545-75b586ae97f8">
      <Text>Nothing is well until our gal is all better.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="caf867f0-d030-4138-908c-e2726bff1308">
      <Text>The camera zooms back in.</Text>
    </Paragraph>
    <Paragraph Type="Scene Heading" id="00ec125c-8a8e-48e6-bd8f-d9b359ff0601">
      <SceneProperties Length="2 2/8" Page="10" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="AURORA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="AURORA &amp; RAY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="AURORA, RAY, &amp; KIDS">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="KIDS">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="RAY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="ROCKET">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="STARDUST">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="STARPOWER">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>Int. Rocket - ContinUOUS</Text>
    </Paragraph>
    <Paragraph Type="Character" id="9e01a7ed-db6f-4a25-b5e1-c68195c95a62">
      <Text>Aurora</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="e6bb3b73-4fdd-4887-95f5-8818ad5f6d15">
      <Text>(to camera)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="d33b46ae-84a0-40c1-b9fb-b85f57d86174">
      <Text>Let’s see why Milky Way has a fever! Everyone, put on your stethoscope ears.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="0f961a87-d5ea-4fdb-a38b-4812e325d4c3">
      <Text>Aurora cups her hands around her ears. Ray opens the medkit, pulling out a glittery </Text>
      <Text Style="AllCaps">stethoscope</Text>
      <Text>. She presses it against the cabin wall everywhere until they pick up the </Text>
      <Text Style="AllCaps">thumps</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="99f9cc6e-36f6-4002-87af-5f0a0616d8dc">
      <Text>Glitter-thump. Glitter-thump.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="e339a972-67c8-4017-9488-4699ae6c34f8">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="6023b550-4ef4-4f22-a077-afe8c5b37488">
      <Text>The sound is coming from Milky Way’s nose nebula.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="8790920c-49f8-44f0-a54d-9f0b71c8546c">
      <Text>Rocket (V.O.)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="4960df41-6fdf-43ec-a2b5-06147c51330e">
      <Text>I’ve got the coordinates! Ready to Z-Z-Zoop?!</Text>
    </Paragraph>
    <Paragraph Type="Character" id="31078101-c16d-41d0-a3bf-b19dae75bd45">
      <Text>AurORA</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="8ce6a998-ddd1-4fab-9e30-5933ea2ecb55">
      <Text>(Grinning)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="39554e71-e0ff-42e2-8ce0-3358fba67179">
      <Text>Pull the lever?</Text>
    </Paragraph>
    <Paragraph Type="Character" id="08c1ab7a-6ec0-44d8-92e7-97e61071f34f">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="28dee545-b743-4618-82bd-1a3ad9597680">
      <Text>Pull the lever.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="8854d5c7-c98e-4bf0-9dd4-8eb0f4e7a8cd">
      <Text>Aurora and Ray signal to Stardust and StarPower. The two zoom to the control panel and yank a lever. The ship begins to hum and vibrate with energy.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="f1b70896-faab-48ba-a8d4-c29c4cf9e235">
      <Text>The crew quickly dives into their seats and click their rainbow seatbelts into place.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="45bf98de-1543-46c3-8ffc-4774df8e3686">
      <Text>AurORA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="662599ae-c8c9-485c-98f9-8c2228a732c8">
      <Text>Buckle up, starkids! We’re blasting off!</Text>
    </Paragraph>
    <Paragraph Type="Action" id="491af422-1a77-4666-a1fd-672fcc7e3465">
      <Text>The Rocket blasts off into the unknown.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="2c2478ab-14bf-46fd-8682-fcce2701cef6">
      <Text Style="Underline+AllCaps">"Rocket Zoop" Song</Text>
    </Paragraph>
    <Paragraph Type="Character" id="8cce50d7-10e5-47cf-bb41-b4509e3b74df">
      <Text>Aurora &amp; Ray</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="ea31a2cd-e6ef-4367-87dd-a9f5392d089f">
      <Text Style="AllCaps">Be safe and buckle up
The Miniverse has bumps
While heading out into space
Let’s visit a brand new place!</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" RightIndent="7.50" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="General" id="6adf9245-cf2a-40db-94b5-1b963f237b1b">
      <DualDialogue>
        <SpellCheckIgnoreLists>
          <IgnoredRanges/>
          <IgnoredWords/>
        </SpellCheckIgnoreLists>
        <Paragraph Type="Character" id="161c9d8f-528a-46b9-8466-2cff7126cac5">
          <Text>StarDUST</Text>
        </Paragraph>
        <Paragraph Type="Dialogue" id="ab1c1c21-4cd3-4a71-bb0b-403fc330cfbc">
          <Text>Twinkle </Text>
          <Text AdornmentStyle="-1">twinkle</Text>
          <Text> </Text>
          <Text AdornmentStyle="-1">twinkle</Text>
          <Text>!</Text>
        </Paragraph>
        <Paragraph Type="Character" id="7c02d556-5d4b-4775-ae67-ba212802d7b8">
          <Text AdornmentStyle="-1">Starpower</Text>
        </Paragraph>
        <Paragraph Type="Dialogue" id="e4e66a6b-1b87-4c87-b7a0-cba0f2f88738">
          <Text>Bubble </Text>
          <Text AdornmentStyle="-1">bubble</Text>
          <Text> </Text>
          <Text AdornmentStyle="-1">bubble</Text>
          <Text>!</Text>
        </Paragraph>
      </DualDialogue>
    </Paragraph>
    <Paragraph Type="Character" id="9e7e0a69-55a0-4166-bc4e-d6c9469b9188">
      <Text>AurorA &amp; Ray</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="6905eb4e-cd3f-4072-88bc-1a4bd3e80ca5">
      <Text AdornmentStyle="-1" Style="AllCaps">Zoop</Text>
      <Text Style="AllCaps"> </Text>
      <Text AdornmentStyle="-1" Style="AllCaps">zoopity</Text>
      <Text Style="AllCaps"> </Text>
      <Text AdornmentStyle="-1" Style="AllCaps">doop</Text>
      <Text Style="AllCaps"> </Text>
      <Text AdornmentStyle="-1" Style="AllCaps">zoop</Text>
      <Text Style="AllCaps">!
Watch the Rocket zip past by
</Text>
      <Text AdornmentStyle="-1" Style="AllCaps">Zoop</Text>
      <Text Style="AllCaps"> </Text>
      <Text AdornmentStyle="-1" Style="AllCaps">zoopity</Text>
      <Text Style="AllCaps"> </Text>
      <Text AdornmentStyle="-1" Style="AllCaps">doop</Text>
      <Text Style="AllCaps"> </Text>
      <Text AdornmentStyle="-1" Style="AllCaps">zoop</Text>
      <Text Style="AllCaps">!
We are moving faster than light</Text>
    </Paragraph>
    <Paragraph Type="Character" id="728517d0-e9d7-4062-b3f4-3c8148a02295">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="f35315c2-5710-42a0-938d-1aba2ea88639">
      <Text Style="AllCaps">Space is Clear!</Text>
    </Paragraph>
    <Paragraph Type="Character" id="ba91770a-b487-47a9-b3eb-8973296dea82">
      <Text>Aurora</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="8456cfe9-1b82-43a2-a124-c3a2476d18fc">
      <Text Style="AllCaps">Glitter steer!</Text>
    </Paragraph>
    <Paragraph Type="Character" id="518b1c28-2ea9-4ecd-af2c-bea35a65b9ea">
      <Text>Aurora, Ray, &amp; Kids (V.O.)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="39255806-00e2-4ffb-ae25-96a45a41185d">
      <Text Style="AllCaps">Our Rocket is finally here
</Text>
      <Text AdornmentStyle="-1" Style="AllCaps">Zoop</Text>
      <Text Style="AllCaps"> </Text>
      <Text AdornmentStyle="-1" Style="AllCaps">zoopity</Text>
      <Text Style="AllCaps"> </Text>
      <Text AdornmentStyle="-1" Style="AllCaps">doop</Text>
      <Text Style="AllCaps"> </Text>
      <Text AdornmentStyle="-1" Style="AllCaps">zoop</Text>
      <Text Style="AllCaps">!</Text>
    </Paragraph>
    <Paragraph Type="Action" id="bb75104b-5a14-4335-9c9b-02c82086dfd5">
      <Text Style="Underline+AllCaps">End of "Rocket </Text>
      <Text AdornmentStyle="-1" Style="Underline+AllCaps">Zoop</Text>
      <Text Style="Underline+AllCaps">" Song</Text>
    </Paragraph>
    <Paragraph Type="Action" id="dcedbdb7-4314-4f45-b8f5-572a5915cad8">
      <Text>The Rocket comes to a smooth halt in a vast stretch of space.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="dcedbdb7-4314-4f45-b8f5-572a5915cad8">
      <Text>The crew unbuckles, leaning in to listen to the hull. From outside, the sound of heavy hops vibrate through the metal.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="b492ccfb-aaf5-476a-a8ef-acb26eaf6fab">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="5cc13ce8-4c53-40a8-90e6-6fc7ba74fa2a">
      <Text>Milky Way sounds dusty.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="ce0495d7-8921-4b9b-9129-9c35f9d3e6a7">
      <Text>Aurora</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="51f6cf07-36b1-42e5-af2a-b0fe96cd9f9c">
      <Text>Wait a minute! The Milky Way can't be that dusty, they aren’t that old! Or are they?</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="b849beae-f4a4-4fcc-81d8-fe685f2f02eb">
      <Text>(to camera)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="2bb55247-3ac9-4d18-9471-48b280a02ea3">
      <Text>They are 13.6... Thousand or million years old?</Text>
    </Paragraph>
    <Paragraph Type="Character" id="5a21d18e-5938-4f87-ae8b-0bace045017b">
      <Text>Kids (V.O.)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="34b07a81-c508-409c-8144-b00eeac32688">
      <Text>Thousand, million, thousand, mil-!</Text>
    </Paragraph>
    <Paragraph Type="Character" id="bea81702-369b-4f2e-b15b-ee8732cfc67c">
      <Text>Aurora</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="ffc26291-6a5d-4668-b8a3-83ba986aa1b5">
      <Text>Milky Way is 13.6 billion years young.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="b065aa7b-59f0-4ced-bb33-ca679188f442">
      <Text>Kids (V.O.)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="79694b08-e027-4eb7-8747-a033d28af9a8">
      <Text>Woah... Billion?!</Text>
    </Paragraph>
    <Paragraph Type="Character" id="b930e947-d11a-40e6-becc-0c6da06f5fb9">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="9498c605-7232-407f-a36a-f53cccf96a90">
      <Text>That’s a lot of time to collect dust!</Text>
    </Paragraph>
    <Paragraph Type="Character" id="1d8b3a74-999f-4ea9-a6d5-7d94f9532f0d">
      <Text>AurorA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="4f449f67-b5c3-4fb8-a461-0e3b8a817f40">
      <Text>Space dust isn't like the dust under your bed, starkids. It’s made of tiny pieces of rocks, metals, and even carbon left over from stars who’ve aged well a long, long time ago!</Text>
    </Paragraph>
    <Paragraph Type="Character" id="b11ccabb-8341-41e6-89ff-7daca0ebabb3">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="e8ec8df0-d9ee-471e-9d39-779a8df58068">
      <Text>Oh, this is not your average space dust either, Aurora!</Text>
    </Paragraph>
    <Paragraph Type="Character" id="6f25f173-4666-4ab2-be53-ffd512f2304c">
      <Text>Aurora</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="b613cfbd-c94c-4e38-8331-62e17f96905e">
      <Text>What are they, Ray?</Text>
    </Paragraph>
    <Paragraph Type="Character" id="d2703d9d-bc0d-4798-81ec-9a0f17503227">
      <Text>RAY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="0241f531-2841-42c0-b0e8-ddb7a40255be">
      <Text>Stardust Bunnies!</Text>
    </Paragraph>
    <Paragraph Type="Action" id="06cc8ad6-637a-4fa0-90dd-d0cebcf48431">
      <Text>Ray points out the window.</Text>
    </Paragraph>
    <Paragraph Type="Scene Heading" id="5f97de5e-c182-4fa8-a5b6-ba46b86a68d0">
      <SceneProperties Length="2/8" Page="13" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="AURORA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>Ext. Miniverse - Nose Nebula (Animated)</Text>
    </Paragraph>
    <Paragraph Type="Action" id="04bf5d91-0335-4420-8045-c6f12b75b9bc">
      <Text>Floating around are sentient giant </Text>
      <Text Style="AllCaps">stardust bunnies</Text>
      <Text>, hopping around.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="acb408e7-249b-49f4-83f4-1411865281ce">
      <Text>AURORA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="438adb5a-8663-4a80-ae3c-30a9e3d7c1e6">
      <Text>Oh no! The Milky Way has stardust bunnies stuck in their nose! All that hopping is making them sneeze!</Text>
    </Paragraph>
    <Paragraph Type="Scene Heading" id="86d16b15-502a-498b-957c-f90844852005">
      <SceneProperties Length="2/8" Page="13" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="KIDS">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>Ext. Deep Space - ContinUOUS (Animated)</Text>
    </Paragraph>
    <Paragraph Type="Action" id="f35fb842-f55d-4b33-bbce-81b8f052dd51">
      <Text>The Milky Way’s nose, represented by a nebula, twitches. They sneeze.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="b25815cc-b604-4f68-9fde-4af49f6977be">
      <Text>Kids (V.O.)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="0c05adcb-7151-4628-b728-076c88c4b9ea">
      <Text>ACHOO!</Text>
    </Paragraph>
    <Paragraph Type="Action" id="1feae320-0005-43a5-bcdc-a2229f68dbf2">
      <Text>The camera zooms back in. The Stardust Bunnies hop out of reach.</Text>
    </Paragraph>
    <Paragraph Type="Scene Heading" id="188780d8-f852-4b04-9b98-7abceecac4b6">
      <SceneProperties Length="4/8" Page="13" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="AURORA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="RAY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="STARDUST">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="STARPOWER">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>Int. Rocket - ConTINUOUS</Text>
    </Paragraph>
    <Paragraph Type="Action" id="03e9bc48-fe93-43dd-97b2-4ee29eafc935">
      <Text>The Rocket shakes. Stardust and StarPower tumble out from under the table, spinning like tops.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="e4ab6835-3797-414c-9e93-19d7349a7991">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="e13eee83-d117-417d-b243-74fb948d5cba">
      <Text>If the Milky Way keeps sneezing, we’ll never be able to land our ship. It’s too bumpy!</Text>
    </Paragraph>
    <Paragraph Type="Character" id="b114960d-b383-415b-9bc3-f47b55ef387e">
      <Text>Aurora</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="62cde734-ceb8-488e-970a-21f18aa7b4ea">
      <Text>(to camera)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="16c5fc83-df52-4bc0-bd22-a32e118c3bec">
      <Text>We need to help clean up the stardust bunnies! But they hopped so high up. How can we reach the top of a galaxy?</Text>
    </Paragraph>
    <Paragraph Type="Action" id="f7a75595-e346-4755-b6cc-8f315659ebf7">
      <Text>Stardust taps StarPower on her shoulder.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" RightIndent="7.50" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="General" id="95951c9d-d56a-4548-a7bd-6359f8f05a1f">
      <DualDialogue>
        <SpellCheckIgnoreLists>
          <IgnoredRanges/>
          <IgnoredWords/>
        </SpellCheckIgnoreLists>
        <Paragraph Type="Character" id="ea878aae-ac65-4fdd-84b5-ba1e020925ac">
          <Text>Stardust</Text>
        </Paragraph>
        <Paragraph Type="Dialogue" id="7241fdd9-6b53-4b1a-b386-473373dad906">
          <Text>Twinkle </Text>
          <Text AdornmentStyle="-1">twinkle</Text>
          <Text> </Text>
          <Text AdornmentStyle="-1">twinkle</Text>
          <Text>!</Text>
        </Paragraph>
        <Paragraph Type="Character" id="86871fd6-b217-4b17-aad8-550ad2b943ff">
          <Text AdornmentStyle="-1">Starpower</Text>
        </Paragraph>
        <Paragraph Type="Dialogue" id="136cd67d-ddb1-4da5-8a3b-3fa54aa6f0dd">
          <Text>Bubble </Text>
          <Text AdornmentStyle="-1">bubble</Text>
          <Text> </Text>
          <Text AdornmentStyle="-1">bubble</Text>
          <Text>!</Text>
        </Paragraph>
      </DualDialogue>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" RightIndent="7.50" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="General" id="fb4e5966-e4dd-41f7-9b3d-9013d387107c">
      <DualDialogue>
        <SpellCheckIgnoreLists>
          <IgnoredRanges/>
          <IgnoredWords/>
        </SpellCheckIgnoreLists>
        <Paragraph Type="Character" id="177cdf83-6f81-447c-9e4c-fcac3f9b4998">
          <Text>Aurora</Text>
        </Paragraph>
        <Paragraph Type="Dialogue" id="a4f0e20a-d9e3-478c-aee8-5b87f10ff6da">
          <Text>Twinkle-Power!</Text>
        </Paragraph>
        <Paragraph Type="Character" id="d42239dd-2e3a-451f-8813-ca4ed11c419e">
          <Text>Ray</Text>
        </Paragraph>
        <Paragraph Type="Dialogue" id="1b1fda02-abec-4688-a3b1-51b4ae0e9168">
          <Text>Bubble-Power!</Text>
        </Paragraph>
      </DualDialogue>
    </Paragraph>
    <Paragraph Type="Scene Heading" id="3bc44312-89ef-44c8-8c8c-df07a72e510d">
      <SceneProperties Length="1/8" Page="13" Title="">
        <SceneArcBeats/>
      </SceneProperties>
      <Text>Ext. Miniverse - Nose Nebula - ContINUOUS (Animated)</Text>
    </Paragraph>
    <Paragraph Type="Action" id="00fccf7b-6bb9-4ccb-bc6e-a4924a095b85">
      <Text>StarPower flies out the window and begins to grow.</Text>
    </Paragraph>
    <Paragraph Type="Scene Heading" id="07806a38-2d3c-4a27-89bd-6afce9a8f79e">
      <SceneProperties Length="2/8" Page="14" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="AURORA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>Int. Rocket - ContinUOUS</Text>
    </Paragraph>
    <Paragraph Type="Character" id="94ca69e9-34b9-426d-b292-68e6b16f91b6">
      <Text>Aurora</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="6dccfd2e-d41a-4f3f-b3a5-ce88fea10d47">
      <Text>(to camera)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="ab270235-4388-41dc-94a3-151d35b33fe9">
      <Text>StarPower needs more room to grow! Starkids, stretch your arms out wide!</Text>
    </Paragraph>
    <Paragraph Type="Action" id="efc4efe5-c246-456b-9d41-9897ea2de6d8">
      <Text>Aurora stretches out her arms.</Text>
    </Paragraph>
    <Paragraph Type="Scene Heading" id="cb2c20b4-a31b-4efc-b798-a3b42bbd75b6">
      <SceneProperties Length="3/8" Page="14" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="AURORA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="KIDS">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>Ext. Miniverse - Nose Nebula - ContinUOUS (Animated)</Text>
    </Paragraph>
    <Paragraph Type="Character" id="c7a31494-ab4e-4935-bace-08a5f6a04581">
      <Text>Aurora (V.O.)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="12a6939c-b9d5-4f89-8054-b285cb359abf">
      <Text>Wider! Even wider!</Text>
    </Paragraph>
    <Paragraph Type="Action" id="5ae65d08-812e-450e-959b-f0f3e05b4f3d">
      <Text>StarPower stretches across the void, transforming into a cosmic pink titan, with her gills shining like an aurora.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="4f3f42e8-7dc8-4982-8d38-889edb444be1">
      <Text>Kids (V.O.)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="2e403215-352e-4231-9bc3-d68683d4acdc">
      <Text>She is a giant!</Text>
    </Paragraph>
    <Paragraph Type="Character" id="b7c665ca-0d37-40f9-9f01-ffcdcccccbbb">
      <Text>AurorA (V.O.)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="63a8318d-fd8f-4c49-bc46-b71c2952f35a">
      <Text>Thank you for lending a helping arm, starkids!</Text>
    </Paragraph>
    <Paragraph Type="Action" id="12b34a53-1668-4e65-8292-180d79b4f8c5">
      <Text>The Stardust Bunnies look up. Their twitching noses freeze in fear. They try to hop away, but StarPower gently scoops a cluster of them into her massive palms.</Text>
    </Paragraph>
    <Paragraph Type="Scene Heading" id="5dc87f85-5398-49b6-94f3-86577cf39171">
      <SceneProperties Length="7/8" Page="14" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="AURORA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="AURORA &amp; RAY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="KIDS">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="MILKY WAY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="RAY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>Int. Rocket - Continuous</Text>
    </Paragraph>
    <Paragraph Type="Action" id="03af96db-24ca-4fd3-ade2-bbbbefdaed23">
      <Text>Aurora and Ray press their faces against the glass, dwarfed by the scale of their friends outside.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="e4fc205e-c923-4afb-82da-58aa49977357">
      <Text>AURORA</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="3c74d6df-613b-44b2-8309-33dcab47187d">
      <Text>(to camera)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="d04c0b4b-7d94-4f22-8f5e-44705608983e">
      <Text>Look! StarPower is using her super-size to catch the Stardust Bunnies!</Text>
    </Paragraph>
    <Paragraph Type="Character" id="690f7503-ccf3-421f-a7d9-e757e025c78a">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="c4ecba25-48c1-4e42-adff-2e76fcda20d3">
      <Text>But they’re so wiggly! Bunnies can get hurt if they move too much. We need to help her keep them still.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="6daa1aa1-5f5b-4694-9b27-946eb62a7a8e">
      <Text>AurORA</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="7e45fdbf-de42-4d82-9e4f-45d75a2a0f72">
      <Text>(to camera)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="a66b9c78-2466-43ee-a872-8875d5fd39ba">
      <Text>Let’s sing them a lullaby!</Text>
    </Paragraph>
    <Paragraph Type="Action" id="aa5c23e0-2b91-4cc2-9a67-e9c2170782fa">
      <Text>Stardust rushes out with her miniature marimba and mallets.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="033a4aaa-8913-4989-9153-a4af9740ff14">
      <Text>RAY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="6a12231d-b49d-4e80-903b-33bffd9f96e2">
      <Text>Stardust. On the count of four. One... two... three... four...</Text>
    </Paragraph>
    <Paragraph Type="Action" id="b9b4fbd5-713e-46d3-a470-0a08dcc53f57">
      <Text Style="Underline+AllCaps">"Hop to Nap" Song</Text>
    </Paragraph>
    <Paragraph Type="Character" id="e172d95e-0bb4-495a-aca7-1d46551de0c2">
      <Text>Aurora</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="a1dd999e-d274-4f0d-9b82-e67327703d20">
      <Text Style="AllCaps">Bunny, you don’t need to be running
Bunnies, everything is now sunny
Stop and relax
Please hop to nap</Text>
    </Paragraph>
    <Paragraph Type="Character" id="65adecdc-b9f9-46dc-aa38-bcd366423ff5">
      <Text>Aurora &amp; Ray</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="3d35dad2-e852-4437-a23c-cbc5f9b49cf2">
      <Text Style="AllCaps">Stop and relax
Please hop to nap</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" RightIndent="7.50" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="General" id="30155dca-785f-448d-8c60-828fa1e422a0">
      <DualDialogue>
        <SpellCheckIgnoreLists>
          <IgnoredRanges/>
          <IgnoredWords/>
        </SpellCheckIgnoreLists>
        <Paragraph Type="Character" id="f7006ff3-7465-4328-9d1e-563115c75c39">
          <Text>Aurora &amp; Ray</Text>
        </Paragraph>
        <Paragraph Type="Dialogue" id="ed0da965-843f-4dda-b5a9-5c6253259859">
          <Text Style="AllCaps">Stop and relax
Please hop to nap</Text>
        </Paragraph>
        <Paragraph Type="Character" id="7bf829b3-2cf4-4849-a16d-a7765b58dcfb">
          <Text>Kids (V.O.)</Text>
        </Paragraph>
        <Paragraph Type="Dialogue" id="d1682df3-ac21-4e7b-8d2b-dded97413faa">
          <Text Style="AllCaps">Stop and relax
Please hop to nap</Text>
        </Paragraph>
      </DualDialogue>
    </Paragraph>
    <Paragraph Type="Action" id="31943926-d89c-4ea8-88a0-ee961c34e86b">
      <Text Style="Underline+AllCaps">End of "hop to Nap" Song</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" RightIndent="7.50" SpaceBefore="24" Spacing="1" StartsNewPage="No" Type="Scene Heading" id="29dabb3b-68e4-4a54-8566-a9e95c0f822b">
      <SceneProperties Length="2/8" Page="15" Title="">
        <SceneArcBeats/>
      </SceneProperties>
      <Text>Ext. Miniverse - Nose Nebula - ContinUOUS (Animated)</Text>
    </Paragraph>
    <Paragraph Type="Action" id="fbaeb649-5a9f-4cf2-8b35-274ecc9472b3">
      <Text>The vibrations ripple through the vacuum of space.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="fbaeb649-5a9f-4cf2-8b35-274ecc9472b3">
      <Text>The Stardust Bunnies stop struggling, with their long ears drooping as they fall into a cosmic nap.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="d88049fd-cb67-4910-abb3-5a673e8322e8">
      <Text>StarPower uses her tail to sweep the remaining Stardust Bunnies into a neat pile.</Text>
    </Paragraph>
    <Paragraph Type="Scene Heading" id="b981295e-608a-4b0f-b03f-6bcc26d64943">
      <SceneProperties Length="2/8" Page="15" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="MILKY WAY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>Ext. Deep SPACE - ContINUOUS (animated)</Text>
    </Paragraph>
    <Paragraph Type="Action" id="46032c87-be98-42e6-a586-a8fe82653806">
      <Text>The Milky Way’s animated face relaxes. The thermometer pops out of its mouth with a cheerful </Text>
      <Text Style="AllCaps">pluck</Text>
      <Text>!</Text>
    </Paragraph>
    <Paragraph Type="Character" id="1181e4ab-d6c0-4c70-960d-6c887769db70">
      <Text>MILKY WAY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="fd4d2ff3-a369-4fba-95dd-5d3960acd29d">
      <Text>Ahhh... much better. My nebula feels clear!</Text>
    </Paragraph>
    <Paragraph Type="Scene Heading" id="eceb5487-5732-4674-a341-dc64fccc7140">
      <SceneProperties Length="1 2/8" Page="15" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="AURORA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="KIDS">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="RAY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="STARDUST">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="STARPOWER">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>Int. Rocket - ConTINUOUS</Text>
    </Paragraph>
    <Paragraph Type="Action" id="65760f0f-85cf-4d60-b55a-e95e62c36d64">
      <Text>The shaking stops. The cockpit levels out, glowing with a soft gold light. StarPower, now normal size, flies back in.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="930d7b23-51f5-4d87-a3ba-dac782f6b0fb">
      <Text>AURORA</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="cf5864b5-ba89-4061-ac00-947ee5d87847">
      <Text>(to camera)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="858df57b-5db2-49ae-8b35-fe507902b30a">
      <Text>We did it! With a little help from our giant friend and your amazing twinkling!</Text>
    </Paragraph>
    <Paragraph Type="Action" id="a74f0386-fee4-447d-97c7-6b70c8831ebb">
      <Text>They high-five and high-fin in mid-air.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" RightIndent="7.50" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="General" id="c9483bed-6fb2-4bae-90db-9e5aef3225b2">
      <DualDialogue>
        <SpellCheckIgnoreLists>
          <IgnoredRanges/>
          <IgnoredWords/>
        </SpellCheckIgnoreLists>
        <Paragraph Type="Character" id="ea878aae-ac65-4fdd-84b5-ba1e020925ac">
          <Text>Stardust</Text>
        </Paragraph>
        <Paragraph Type="Dialogue" id="7241fdd9-6b53-4b1a-b386-473373dad906">
          <Text>Twinkle </Text>
          <Text AdornmentStyle="-1">twinkle</Text>
          <Text> </Text>
          <Text AdornmentStyle="-1">twinkle</Text>
          <Text>!</Text>
        </Paragraph>
        <Paragraph Type="Character" id="86871fd6-b217-4b17-aad8-550ad2b943ff">
          <Text AdornmentStyle="-1">Starpower</Text>
        </Paragraph>
        <Paragraph Type="Dialogue" id="136cd67d-ddb1-4da5-8a3b-3fa54aa6f0dd">
          <Text>Bubble </Text>
          <Text AdornmentStyle="-1">bubble</Text>
          <Text> </Text>
          <Text AdornmentStyle="-1">bubble</Text>
          <Text>!</Text>
        </Paragraph>
      </DualDialogue>
    </Paragraph>
    <Paragraph Type="Character" id="6368f221-6f3e-46d0-a67d-b57bcd1358da">
      <Text>Aurora</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="a5c23be2-1a5b-449a-9ca6-535cefb317e6">
      <Text>You’re right, Stardust and StarPower. Let’s find a home for the Stardust Bunnies.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="9b2105ef-2145-46d8-8548-73325cb36e7a">
      <Text>The Rocket glides alongside a lavender asteroid belt with nebulas in view.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="002af6e7-8cd5-451e-9681-e7f6a90f8cd9">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="c744a412-09cb-4d07-8487-6eac6591557b">
      <Text>The Stardust Bunnies need a place where they can hop and play without tickling any more galaxy noses. </Text>
    </Paragraph>
    <Paragraph Type="Character" id="200eb741-b949-4963-82d5-c626bad4682e">
      <Text>AurorA</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="32b7436f-a153-4fb7-8619-383c425f4eca">
      <Text>(to camera)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="5a98ce35-51f3-4cdd-8da6-50b6ce88fb97">
      <Text>Do you see a place that looks soft and bouncy?</Text>
    </Paragraph>
    <Paragraph Type="Action" id="c488695e-618e-4aa7-bfde-5d8acb22ac26">
      <Text>Aurora gestures to the window, where a moon, a planet with rings, and a nebulous field loom in deep space.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="c8b8b839-165b-4777-a277-204ccdce5f75">
      <Text>Aurora</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="4a6c8e64-e119-477d-8903-8b680d57e391">
      <Text>Should we release the bunnies on a moon?</Text>
    </Paragraph>
    <Paragraph Type="Character" id="27a94bd4-0b96-4713-ba18-dde2808991cc">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="3efdc1d4-3f99-44ad-b88c-86ac2664eac3">
      <Text>It’s full of craters.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="8f0b2104-eac5-44c4-8c67-1045e92615c9">
      <Text>Aurora</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="36ab9407-f280-40fc-be93-723b6c9ced77">
      <Text>Should we drop them off on a ring planet?</Text>
    </Paragraph>
    <Paragraph Type="Character" id="0bfed5c3-5577-4352-afbe-00fc4fbc2cbb">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="edc94743-ca5b-47dc-a4a7-6ad87af795f3">
      <Text>They might slip on the ring.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="aa763922-def5-4e0b-a75e-5e03838ba862">
      <Text>Aurora</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="46026cf8-2995-46f8-be79-6ddecf01e266">
      <Text>How about the Cotton Candy Nebula?</Text>
    </Paragraph>
    <Paragraph Type="Character" id="5090f538-b232-4568-90d0-98e5e46e1d8a">
      <Text>Kids (V.O.)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="b262960f-e774-4ce5-8b9c-38655bfc6df1">
      <Text>Cotton Candy!</Text>
    </Paragraph>
    <Paragraph Type="Character" id="d11a3a2e-372e-4d0b-a94a-2cf56d23ab70">
      <Text>AurorA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="adc8eddd-392d-4a06-9096-7a3780f18fa6">
      <Text>The ring planet?</Text>
    </Paragraph>
    <Paragraph Type="Character" id="65cd6c8a-3cf1-4af1-b793-be35af833625">
      <Text>KidS (V.O.)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="dea82074-b4b4-4f3d-916d-a0dd65866858">
      <Text>The Cotton Candy Nebula!</Text>
    </Paragraph>
    <Paragraph Type="Character" id="1c2fac52-4d24-4fe8-aabd-22f1788f6f01">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="293de48a-c62f-4631-87bc-eb9495a8ca4e">
      <Text>The softest place in the Miniverse!</Text>
    </Paragraph>
    <Paragraph Type="Action" id="e9c114e1-ff05-4212-a1d0-685de72485f1">
      <Text>Aurora pulls a glittery lever labeled GENTLE TRACTOR BEAM.</Text>
    </Paragraph>
    <Paragraph Type="Scene Heading" id="bea3294d-d3e3-421b-abfe-66d819c094ae">
      <SceneProperties Length="3/8" Page="17" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="AURORA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="KIDS">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="RAY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>Ext. Miniverse - Nose Nebula - ContINUOUS (animated)</Text>
    </Paragraph>
    <Paragraph Type="Action" id="1e1d8e83-5fde-45f6-8c7d-d8260dca63ee">
      <Text>A swirling beam of rainbow light shoots out from the Rocket's nose.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="8c3203d7-ec21-42d9-9059-c174ccf9cda5">
      <Text>Outside, the slumbering bunnies begin to float, following the rainbow trail like a parade.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="3b54af64-7e94-487c-9950-a09e99dd7a6d">
      <Text>Aurora</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="7144b50f-1f82-4b46-b342-d352a860927a">
      <Text>(to camera)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="cabdd9d7-bed1-43f0-b10b-2a93714c79cb">
      <Text>Help us lead them home!</Text>
    </Paragraph>
    <Paragraph Type="Character" id="3be6590d-3c6d-479d-b8e0-0c5d9e425db8">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="fc78eaf8-d7f3-4d4d-85fb-875d006d98dc">
      <Text>Wave your arms like a magic wand!</Text>
    </Paragraph>
    <Paragraph Type="Action" id="30c6752b-3760-47f5-970f-7bd55bcdd675">
      <Text>Aurora and Ray wave their arms around.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="e7dcbd17-4c6a-4758-aed0-e6b21dc7429b">
      <Text>Kids (V.O.)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="c292e2a3-1e0b-4d13-950a-f8cbb3cec67f">
      <Text>Whoosh! Whoosh!</Text>
    </Paragraph>
    <Paragraph Type="Scene Heading" id="bc3ae379-e52d-4890-9ae3-0487811403c5">
      <SceneProperties Length="2/8" Page="17" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="MILKY WAY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>Ext. Cotton Candy Nebula - Moments Later (Animated)</Text>
    </Paragraph>
    <Paragraph Type="Action" id="6e5faaa3-803d-40d8-a50e-ad7c1d85cd89">
      <Text>The Stardust Bunnies land softly in a pink, puffy cloud. One wakes up, nibbles on a stray bit of cosmic dust, and does a happy backflip.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="ed632da0-aa34-4399-b9aa-6f50c6365988">
      <Text>Milky Way (V.O.)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="c55d135a-9ea2-4b42-a6da-c24801f7072f">
      <Text>Thanks, tiny neighbors! Enjoy your new home!</Text>
    </Paragraph>
    <Paragraph Type="Scene Heading" id="fe81c464-cb4f-4fa7-a157-da61df41ff45">
      <SceneProperties Length="1 2/8" Page="17" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="AURORA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="KIDS">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="MILKY WAY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="RAY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="ROCKET">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="STARDUST">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="STARPOWER">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>Int. Rocket - Continuous</Text>
    </Paragraph>
    <Paragraph Type="Action" id="af18b0e5-9045-41b5-a4d4-912d8849ce1b">
      <Text>Ray closes her medkit.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="9a02ab63-b62a-4089-b8db-f804151f14a9">
      <Text>RAY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="a305fb7e-c732-4949-8f08-aeb3d2613acd">
      <Text>Patient stable. Galaxy healthy. Mission accomplished!</Text>
    </Paragraph>
    <Paragraph Type="Character" id="3339eecf-aaa4-4e7e-8668-c2e1380aafe7">
      <Text>AURORA</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="85b32a05-bac2-4c2b-a810-9bd3f7b8fb0d">
      <Text>(to camera)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="26c91d93-5a67-4dd9-8446-9ca393e14f87">
      <Text>We make a great team, starkids.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="60d12ac7-e8e0-4e98-b6b1-39a7eb4d4d79">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="7ff60dda-9acf-436f-b371-3d6a5e6a96cf">
      <Text>We helped Stardust and StarPower...</Text>
    </Paragraph>
    <Paragraph Type="Character" id="591e4526-abc5-4be4-ac5c-1acd4f8c60d7">
      <Text>AurORA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="9f667ba2-ca14-430c-8a81-a73c80769482">
      <Text>...saved the bunnies...</Text>
    </Paragraph>
    <Paragraph Type="Character" id="e0d233ca-79e9-48d0-9bf4-ed5ef9cd7d9b">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="12572442-a482-4571-8398-f0c6c5073795">
      <Text>...and kept our galaxy mucus-free!</Text>
    </Paragraph>
    <Paragraph Type="Character" id="d28b6cec-112e-44a0-9834-a063574e43ef">
      <Text>AURORA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="12d8314a-50a8-4004-928c-ad6034a2019a">
      <Text>Now that the Milky Way is feeling better...</Text>
    </Paragraph>
    <Paragraph Type="Character" id="7c49c70b-d6e5-4a34-890c-9657301e951f">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="dd65e3de-02cb-4dca-8f73-178837d4f1a8">
      <Text>...it’s time to celebrate!</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" RightIndent="7.50" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="General" id="b317c5d3-6e88-4552-98ff-83dec8c62ed3">
      <DualDialogue>
        <SpellCheckIgnoreLists>
          <IgnoredRanges/>
          <IgnoredWords/>
        </SpellCheckIgnoreLists>
        <Paragraph Type="Character" id="ea878aae-ac65-4fdd-84b5-ba1e020925ac">
          <Text>Stardust</Text>
        </Paragraph>
        <Paragraph Type="Dialogue" id="7241fdd9-6b53-4b1a-b386-473373dad906">
          <Text>Twinkle </Text>
          <Text AdornmentStyle="-1">twinkle</Text>
          <Text> </Text>
          <Text AdornmentStyle="-1">twinkle</Text>
          <Text>!</Text>
        </Paragraph>
        <Paragraph Type="Character" id="86871fd6-b217-4b17-aad8-550ad2b943ff">
          <Text AdornmentStyle="-1">Starpower</Text>
        </Paragraph>
        <Paragraph Type="Dialogue" id="136cd67d-ddb1-4da5-8a3b-3fa54aa6f0dd">
          <Text>Bubble </Text>
          <Text AdornmentStyle="-1">bubble</Text>
          <Text> </Text>
          <Text AdornmentStyle="-1">bubble</Text>
          <Text>!</Text>
        </Paragraph>
      </DualDialogue>
    </Paragraph>
    <Paragraph Type="Character" id="df4fc029-cd84-4b58-8394-fcc05a8860b9">
      <Text>AuRORA</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="4cd9ebea-4e96-4822-9899-fa0fd831f2f0">
      <Text>(to camera)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="361f8a04-89fc-4b08-a2f5-ea82c5abb7c5">
      <Text>What’s the best way to celebrate a healthy galaxy?</Text>
    </Paragraph>
    <Paragraph Type="Action" id="d1bc752e-289e-42be-8851-2a300680ab8e">
      <Text>Ray presses the stethoscope against the cabin wall.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="a57d7964-5d17-48ff-8bb2-b603c0ba0b43">
      <Text>Milky WAY (V.O.)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="bd2b27cb-48ca-4d8a-a9d1-db49a44a8002">
      <Text>Dance! Dance! Dance!</Text>
    </Paragraph>
    <Paragraph Type="Character" id="ac2372bd-be98-4419-afd2-a210eeb4f3b2">
      <Text>Kids (V.O.)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="ec76db71-3931-4331-8b34-5c9ef38679b9">
      <Text>A DANCE PARTY!</Text>
    </Paragraph>
    <Paragraph Type="Character" id="54ae1d6b-d9d8-4f39-af4d-f2f02b3e9338">
      <Text>Aurora</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="af58a164-9725-4a55-a398-36722ba7aba4">
      <Text>You read my mind!</Text>
    </Paragraph>
    <Paragraph Type="Character" id="e5980feb-5db5-4b65-90e2-a3eca9e827a8">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="7eae64b6-db4c-4185-91b6-77522bd44bab">
      <Text>Rocket, hop to it!</Text>
    </Paragraph>
    <Paragraph Type="Character" id="c8059ebe-0837-4d52-9a4e-d26b6cdbc6c4">
      <Text>RockET</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="afdafc54-b3bc-47a8-908e-43f231eca042">
      <Text>Hopping right up!</Text>
    </Paragraph>
    <Paragraph Type="Action" id="5e30bccf-fcec-4828-a1fc-e3db8a66e47b">
      <Text>The cockpit lights turn into a disco ball.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="6b521b69-9866-4877-a6a2-343f6f718efc">
      <Text>Aurora and Ray hop like bunnies together while Stardust and </Text>
      <Text AdornmentStyle="-1">StarPower</Text>
      <Text> spread glitter around the cabin.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="604d816d-6279-48ce-9067-b048347d84dd">
      <Text>The </Text>
      <Text AdornmentStyle="-1">StarPower</Text>
      <Text> logo flashes as the music eventually winds down.</Text>
    </Paragraph>
    <Paragraph Type="Transition" id="29616ab5-bf7b-4533-8d0f-704f29b5ba32">
      <Text>Cut to black.</Text>
    </Paragraph>
    <Paragraph Alignment="Center" FirstIndent="0.00" Leading="Regular" LeftIndent="1.00" RightIndent="7.50" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="End of Act" id="1d686bb2-d1c8-465d-b94b-e6b312d4c003">
      <Text Style="Underline+AllCaps">The End</Text>
    </Paragraph>
    <Paragraph Type="New Act" id="ae5a6baf-fc45-4113-80fa-2ea4960dadce">
      <Text>Tag</Text>
    </Paragraph>
  </Content>

